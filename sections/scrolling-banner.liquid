{%- liquid
  assign section_prefix_class = 'scrolling-banner'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  
  capture container_class
    if section.settings.section_full_width
      echo 'container-fluid'
      else
        echo 'container'
    endif
  endcapture

  assign marquee_direction = 'backward'
  if section.settings.marquee_direction == 'marquee_forward'
    assign marquee_direction = 'forward'
  endif
-%}
{%- style -%}
  .scrolling-banner .marquee-component_col{
    padding: 0 20px;
  }

  .scrolling-banner .marquee-component_col,
  .scrolling-banner_column{
    display: flex;
  }

  .scrolling-banner .marquee-component{
    align-items: center;
  }

  .scrolling-banner_column{
    width: 100%;
    margin-top: auto;
    margin-bottom: auto;
    align-items: center;
    gap: 37px;
  }

  .scrolling-banner .container-fluid{
    --cp-spacer-left: 0;
    --cp-spacer-right: 0;
  }

  .scrolling-banner_image-wrap{
    width: 24px;
    height: 24px;
    position: relative;
    overflow: hidden;
  }

  .scrolling-banner_image-wrap img{
    border-radius: inherit;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
  }

  .scrolling-banner_text-wrap{
    flex-grow: 1;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .scrolling-banner_heading,
  .scrolling-banner_space:after{
    display: block;
  }

  a.scrolling-banner_column{
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .scrolling-banner_space:after{
    content: "";
    border: 1px solid var(--section-foreground-color);
    width: 12px;
  }

  .scrolling-banner_label{
    background: var(--label-bg);
    color: var(--label-fg);
    font-size: 1.3rem;
    line-height: 2.1rem;
    padding: 8px 9px;
    border-radius: 6px;
    min-width: 87px;
  }

  .--stencil-text{
    -webkit-text-fill-color: var(--section-background-color);
    -webkit-text-stroke: 1px var(--section-heading-color);
  }

  .scrolling-banner_label {
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .scrolling-banner_column.--padding-top-bottom {
    padding-top: 8px;
    padding-bottom: 8px;
  }

  .scrolling-banner_dot{
    flex-shrink: 0;
    display: block;
    width: 3px;
    height: 3px;
    border-radius: 100%;
    background-color: var(--section-heading-color);
  }

  .scrolling-banner_heading.--text-font-family {
    padding-top: 7px;
    padding-bottom: 7px;
  }
{%- endstyle -%}
<div class="global-block {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }}" style="--section-radius-small: 10px; --section-radius-large: 999px; --section-padding-top: {{ section.settings.section_top_padding }}px; --section-padding-bottom: {{ section.settings.section_bottom_padding }}px;">
  <div class="{{ container_class }}">
    <div class="{{ section_prefix_class }}_wrapper {{ section_scheme_class }}">
      <marquee-component data-direction="{{ marquee_direction }}" data-pause-on-hover="{{ section.settings.marquee_on_hover }}" data-speed="{{ section.settings.marquee_speed | plus: 15 }}">
        <div class="marquee-component marquee-component--h-scroll">
          {%- for block in section.blocks -%}
            <div class="marquee-component_col">
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" {% if block.settings.open_new_window %}target="_blank"{% endif %} class="{{ section_prefix_class }}_column">
                {% else %}
                  <div class="{{ section_prefix_class }}_column">
                {%- endif -%}
                <div class="{{ section_prefix_class }}_text-wrap">
                  {% if block.settings.from_label != blank %}
                    <div class="{{ section_prefix_class }}_label h --fw-bold --align-center" style="--label-fg: {{ block.settings.tag_fg }}; --label-bg: {{ block.settings.tag_bg }}">
                      {{- block.settings.from_label -}}
                    </div>
                  {%- endif -%}
                  {%- if block.settings.heading != blank -%}
                    <strong class="{{ section_prefix_class }}_heading {% unless section.settings.heading_family == 'text' %}{{ section.settings.block_heading_size }}{% else %}{{ section.settings.block_text_size }}  --text-font-family{% endunless %} {{ section.settings.block_heading_weight }} {% if block.settings.stencil_text %}--stencil-text{% endif %}">{{- block.settings.heading -}}</strong>
                  {%- endif -%}
                </div>
                {%- if block.settings.image != blank -%}
                  <div class="{{ section_prefix_class }}_image-wrap">
                    {%- liquid
                      capture image_alt
                        if block.settings.image.alt != blank
                          echo block.settings.image.alt
                          else
                            echo block.settings.heading | escape
                        endif
                      endcapture

                      assign image_height = 38 | divided_by: block.settings.image.aspect_ratio | round
                    -%}
                    {{- block.settings.image | image_url: width: 49 | image_tag:
                      alt: image_alt,
                      width: 38,
                      height: image_height,
                      widths: '38, 49',
                      sizes: '(max-width: 767px) 38px, 49px',
                      loading: 'lazy'
                    -}}
                  </div>
                  {%- else -%}
                  <div class="{{ section_prefix_class }}_space"></div>
                {%- endif -%}
                {%- if block.settings.link_url != blank -%}
                  </a>
                {%- else -%}
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </marquee-component>
    </div>
  </div>
</div>

{% schema %}

{
  "name": "t:sections.scrolling_banner.name",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "heading_family",
      "label": "t:settings_schema.typography.settings.f_family.label",
      "options": [
        {
          "value": "text",
          "label": "t:text.name"
        },
        {
          "value": "heading",
          "label": "t:heading.name"
        }
      ],
      "default": "heading"
    },
    {
      "type": "select",
      "id": "block_heading_size",
      "label": "t:sizes.heading.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sizes.heading.options.opt_1.label"
        },
        {
          "value": "h2",
          "label": "t:sizes.heading.options.opt_2.label"
        },
        {
          "value": "h3",
          "label": "t:sizes.heading.options.opt_3.label"
        },
        {
          "value": "h4",
          "label": "t:sizes.heading.options.opt_4.label"
        }
      ],
      "default": "h4",
      "visible_if": "{{ section.settings.heading_family == 'heading' }}"
    },
    {
      "type": "select",
      "id": "block_text_size",
      "label": "t:sizes.text.label",
      "options": [
        {
          "value": "text-size--small",
          "label": "t:sizes.text.options.opt_1.label"
        },
        {
          "value": "text-size--medium",
          "label": "t:sizes.text.options.opt_2.label"
        },
        {
          "value": "text-size--large",
          "label": "t:sizes.text.options.opt_3.label"
        },
        {
          "value": "text-size--xlarge",
          "label": "t:sizes.text.options.opt_4.label"
        }
      ],
      "default": "text-size--xlarge",
      "visible_if": "{{ section.settings.heading_family == 'text' }}"
    },
    {
      "type": "select",
      "id": "block_heading_weight",
      "label": "t:weight.heading.label",
      "options": [
        {
          "value": "--fw-bold",
          "label": "t:weight.heading.options.opt_1.label"
        },
        {
          "value": "--fw-semi-bold",
          "label": "t:weight.heading.options.opt_5.label"
        },
        {
          "value": "--fw-medium",
          "label": "t:weight.heading.options.opt_2.label"
        },
        {
          "value": "--fw-normal",
          "label": "t:weight.heading.options.opt_3.label"
        },
        {
          "value": "--fw-light",
          "label": "t:weight.heading.options.opt_4.label"
        }
      ],
      "default": "--fw-bold"
    },
    {
      "type": "header",
      "content": "t:layout.content"
    },
    {
      "type": "checkbox",
      "id": "section_full_width",
      "label": "t:sections.full_width.label",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "default": "scheme3",
      "label": "t:color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:scroll.content"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "t:scroll.settings.speed.label",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 15,
      "unit": "sec"
    },
    {
      "type": "select",
      "id": "marquee_direction",
      "label": "t:scroll.settings.direction.label",
      "options": [
        {
          "value": "marquee_backward",
          "label": "t:scroll.settings.direction.options.opt_1.label"
        },
        {
          "value": "marquee_forward",
          "label": "t:scroll.settings.direction.options.opt_2.label"
        }
      ],
      "default": "marquee_backward"
    },
    {
      "type": "checkbox",
      "label": "t:scroll.settings.on_hover.label",
      "id": "marquee_on_hover",
      "default": false
    },
    {
      "type": "header",
      "content": "t:spacing.content"
    },
    {
      "type": "range",
      "id": "section_top_padding",
      "label": "t:spacing.settings.top.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_bottom_padding",
      "label": "t:spacing.settings.bottom.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "name": "t:sections.scrolling_banner.blocks.banner.name",
      "type": "banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:image.label",
          "info": "t:sections.scrolling_banner.blocks.banner.settings.image.info"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:heading.label",
          "default": "Your scrolling text here"
        },
        {
          "type": "text",
          "id": "from_label",
          "label": "t:sections.scrolling_banner.blocks.banner.settings.from_label.label",
          "default": "From"
        },
        {
          "type": "color",
          "id": "tag_bg",
          "label": "t:sections.scrolling_banner.blocks.banner.settings.from_label.settings.bg_color.label",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "tag_fg",
          "label": "t:sections.scrolling_banner.blocks.banner.settings.from_label.settings.fg_color.label",
          "default": "#0a0a0a"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "t:sections.scrolling_banner.blocks.banner.settings.url.label"
        },
        {
          "type": "checkbox",
          "id": "open_new_window",
          "label": "t:target_blank.label",
          "default": false
        },
        {
          "type": "header",
          "content": "t:sections.scrolling_banner.blocks.stencil.name",
          "info": "t:sections.scrolling_banner.blocks.stencil.setting.info"
        },
        {
          "type": "checkbox",
          "id": "stencil_text",
          "label": "t:sections.scrolling_banner.blocks.stencil.name",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.scrolling_banner.name",
      "blocks": [
        {
          "type": "banner",
          "settings": {
          }
        },
        {
          "type": "banner",
          "settings": {
          }
        },
        {
          "type": "banner",
          "settings": {
          }
        },
        {
          "type": "banner",
          "settings": {
          }
        }
      ]
    }
  ]
}
{% endschema %}
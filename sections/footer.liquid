                              <a
                                class="{{ section_prefix_class }}_navlist-link-text --fw-medium --word-break {% if link.current %}--active{% endif %}"
                                href="{{ link.url }}"
                              >
                                {{- link.title | escape -}}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          {%- when 'view_3' -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'menu' -%}
                  <div
                    class="{{ section_prefix_class }}_col {{ section_prefix_class }}_col--menus grid_col {{ section_prefix_class }}_col--menus-view-3 --align-{{ section.settings.menus_text_alignment }}"
                    {{ block.shopify_attributes }}
                  >
                    <div class="menu-strip_col {{ section_prefix_class }}_menu-strip footer_menu-block" {{ block.shopify_attributes }}>
                      {%- assign menu_heading_text = block.settings.menu_heading | default: block.settings.menu.title -%}
                      {%- if menu_heading_text != blank -%}
                        <h6 class="footer_menu-heading">
                          <button
                            type="button"
                            class="footer_menu-heading-btn"
                            data-footer-menu-toggle
                            aria-expanded="false"
                          >
                            <span>{{- menu_heading_text | escape -}}</span>
                            <span class="footer_menu-arrow" aria-hidden="true"></span>
                          </button>
                        </h6>
                      {%- endif -%}
                      {%- if block.settings.menu.links != blank -%}
                        <ul class="list-unstyled {{ section_prefix_class }}_navlist">
                          {%- for link in block.settings.menu.links -%}
                            <li class="{{ section_prefix_class }}_navlist-link">
                              <a
                                class="{{ section_prefix_class }}_navlist-link-text --fw-medium --word-break {% if link.current %}--active{% endif %}"
                                href="{{ link.url }}"
                              >
                                {{- link.title | escape -}}
                              </a>
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}
                    </div>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
        {%- endcase -%}
      </div>
      {%- if section.settings.footer_top_layout == 'view_3' -%}
        <div class="view_3-bottom-col">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'description' -%}
                <div
                  class="{{ section_prefix_class }}_col {{ section_prefix_class }}_col--uptoDate"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.form_description != blank -%}
                    <div class="{{ section_prefix_class }}_form-description --word-break {{ block.settings.form_description_size }} {{ block.settings.form_description_weight }}">
                      {{- block.settings.form_description -}}
                    </div>
                  {%- endif -%}
                  {%- if section.settings.footer_top_layout == 'view_2' -%}
                    <div class="{{ section_prefix_class }}_pay-methods-wrap">
                      {%- render 'payment-icons', prefix_class: section_prefix_class -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- when 'method' -%}
                {%- liquid
                  capture follow_exists
                    if shop.features.follow_on_shop? and block.settings.follow_on_shops
                      echo 'true'
                    endif
                  endcapture

                  capture enable_social_list
                    if settings.social_instagram_link != blank
                      echo 'true'
                    elsif settings.social_linkedin_link != blank
                      echo 'true'
                    elsif settings.social_facebook_link != blank
                      echo 'true'
                    elsif settings.social_youtube_link != blank
                      echo 'true'
                    elsif settings.social_twitter_link != blank
                      echo 'true'
                    elsif settings.social_snapchat_link != blank
                      echo 'true'
                    elsif settings.social_pinterest_link != blank
                      echo 'true'
                    elsif settings.social_tiktok_link != blank
                      echo 'true'
                    elsif settings.social_tumblr_link != blank
                      echo 'true'
                    elsif settings.social_vimeo_link != blank
                      echo 'true'
                    else
                      echo 'false'
                    endif
                  endcapture

                  capture social_exists
                    if enable_social_list == 'true' and block.settings.show_social_links
                      echo 'true'
                    endif
                  endcapture
                -%}
                {%- if follow_exists == 'true' or social_exists == 'true' -%}
                  <div
                    class="{{ section_prefix_class }}_col {{ section_prefix_class }}_col--methods"
                    {{ block.shopify_attributes }}
                  >
                    {%- if social_exists == 'true' -%}
                      <div class="{{ section_prefix_class }}_socials">
                        {%- render 'social-icons',
                          prefix_class: section_prefix_class,
                          social_icons_enable: true,
                          social_extra_class: '--align-left'
                        -%}
                      </div>
                    {%- endif -%}
                    {%- if follow_exists == 'true' -%}
                      <div class="{{ section_prefix_class }}_follow-link">
                        {% # theme-check-disable %}
                        {{- shop | login_button: action: 'follow' -}}
                        {% # theme-check-enable %}
                      </div>
                    {%- endif -%}
                  </div>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
<script>
  (() => {
    if (window.__footerMenuAccordionBound) return;
    window.__footerMenuAccordionBound = true;

    document.addEventListener('click', (event) => {
      const toggle = event.target.closest('[data-footer-menu-toggle]');
      if (!toggle) return;
      if (!window.matchMedia('(max-width: 767px)').matches) return;

      const menuBlock = toggle.closest('.footer_menu-block');
      if (!menuBlock) return;

      const isOpen = menuBlock.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  })();
</script>
<div class="global-block footer-bottom {{ section_prefix_class }}-{{ section.id }} {{ section_bottom_scheme_class }} {% if section.settings.show_top_bdr %}--bdr-top{% endif %} {% if section.settings.footer_bottom_layout == 'view_2' %}--view-2{% endif %} {% if section.settings.footer_bottom_layout == 'view_3' %}--view-3{% endif %}">
  <div class="container">
    <div class="footer-bottom_wrapper {% unless section.settings.show_payment_icons %}--flex-center{% endunless %} {% if section.settings.show_payment_icons or local_exists == 'true' %}--justify-between{% else %}--justify-center{% endif %}">
      <span class="{{ section_prefix_class }}_text --word-break">
        {%- liquid
          assign copyright_text_clean = section.settings.copyright_text
          assign copyright_text_clean = copyright_text_clean | replace: '&lt;p&gt;', '' | replace: '&lt;/p&gt;', ''
          assign copyright_text_clean = copyright_text_clean | remove: '<p>' | remove: '</p>' | strip
        -%}
        &copy; {{ 'now' | date: '%Y' }}
        {%- if copyright_text_clean != blank -%}
          , {{- copyright_text_clean -}}
        {%- else -%}
          , {{- shop.name | link_to: routes.root_url -}}
        {%- endif -%}
      </span>
      {%- if section.settings.show_payment_icons and section.settings.footer_bottom_layout == 'view_3' -%}
        <div class="{{ section_prefix_class }}_pay-methods-wrap">
          {%- render 'payment-icons', prefix_class: section_prefix_class -%}
        </div>
      {%- endif -%}
      <div class="footer-bottom_pay-localizations">
        {%- if local_exists == 'true' -%}
          <div class="localization-wrapper --align-middle {% if section.settings.show_payment_icons and section.settings.footer_bottom_layout == 'default' %}margin-bottom{% endif %}">
            {%- liquid
              assign lfid = section.id | prepend: 'language-form-'
              assign if_id_no_script = section.id | prepend: 'language-form-' | append: '-noscript'

              assign resid = section.id | prepend: 'country-form-'
              assign res_id_no_script = section.id | prepend: 'country-form-' | append: '-noscript'
            -%}
            {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
              <div class="localization-wrapper_drop --margin">
                <noscript>
                  {%- form 'localization', id: if_id_no_script, class: 'localization-form' -%}
                    <h2 class="visually-hidden" id="{{ if_id_no_script }}-lang-heading">
                      {{- 'localization.country_label' | t -}}
                    </h2>
                    <div class="custom-select">
                      <select
                        name="locale_code"
                        aria-labelledby="{{ if_id_no_script }}-lang-heading"
                        class="dropdown-component_opener dropdown-localization_opener --align-left"
                      >
                        {%- for language in localization.available_languages -%}
                          <option
                            value="{{ language.iso_code }}"
                            lang="{{ language.iso_code }}"
                            {% if language.iso_code == localization.language.iso_code %}
                              selected
                            {% endif %}
                            class="dropdown-component_btn-submit dropdown-localization_btn-submit {% if language.iso_code == localization.language.iso_code %}active{% endif %}"
                          >
                            {{ language.endonym_name | capitalize }}
                          </option>
                        {%- endfor -%}
                      </select>
                    </div>
                    <button class="button button--primary visually-hidden">
                      {{- 'localization.update_language' | t -}}
                    </button>
                  {%- endform -%}
                </noscript>
                {%- form 'localization', id: lfid, class: 'localization-form' -%}
                  {%- render 'language-localization', localPosition: section.id, id: lfid, section_id: section.id -%}
                {%- endform -%}
              </div>
            {%- endif -%}
            {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
              <div class="localization-wrapper_drop">
                <noscript>
                  {%- form 'localization', id: res_id_no_script, class: 'localization-form' -%}
                    <div class="custom-select">
                      <h2 class="visually-hidden" id="{{ res_id_no_script }}-country-heading">
                        {{- 'localization.country_label' | t -}}
                      </h2>
                      <select
                        name="country_code"
                        aria-labelledby="{{ res_id_no_script }}-country-heading"
                        class="dropdown-component_opener dropdown-localization_opener --align-left"
                      >
                        {%- for country in localization.available_countries -%}
                          <option
                            value="{{ country.iso_code }}"
                            {% if country.iso_code == localization.country.iso_code %}
                              selected
                            {% endif %}
                            class="dropdown-component_btn-submit dropdown-localization_btn-submit{% if country.iso_code == localization.country.iso_code %} active{% endif %}"
                          >
                            {{- country.name }} ({{ country.currency.iso_code }}
                            {{ country.currency.symbol -}}
                            )
                          </option>
                        {%- endfor -%}
                      </select>
                    </div>
                    <button class="button button--tertiary visually-hidden">
                      {{- 'localization.update_country' | t -}}
                    </button>
                  {%- endform -%}
                </noscript>
                {%- form 'localization', id: resid, class: 'localization-form' -%}
                  {%- render 'country-localization', localPosition: section.id, id: resid, section_id: section.id -%}
                {%- endform -%}
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          <div class="footer-bottom_col --empty footer-bottom_col--links">&nbsp;</div>
        {%- endif -%}
        {%- if section.settings.show_payment_icons and section.settings.footer_bottom_layout == 'default' -%}
          <div class="{{ section_prefix_class }}_pay-methods-wrap">
            {%- render 'payment-icons', prefix_class: section_prefix_class -%}
          </div>
        {%- endif -%}
      </div>
      {%- if section.settings.footer_bottom_layout == 'view_2' -%}
        {%- if follow_exists == 'true' -%}
          <div class="{{ section_prefix_class }}_follow-link">
            {% # theme-check-disable %}
            {{- shop | login_button: action: 'follow' -}}
            {% # theme-check-enable %}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</div>

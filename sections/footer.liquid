                  >
                    <div class="menu-strip_col {{ section_prefix_class }}_menu-strip footer_menu-block" {{ block.shopify_attributes }}>
                      {%- assign menu_heading_text = block.settings.menu_heading | default: block.settings.menu.title -%}
                      {%- if menu_heading_text != blank -%}
                        <h6 class="footer_menu-heading">
                          <button
                            type="button"
                            class="footer_menu-heading-btn"
                            data-footer-menu-toggle
                            aria-expanded="false"
                          >
                            <span>{{- menu_heading_text | escape -}}</span>
                            <span class="footer_menu-arrow" aria-hidden="true"></span>
                          </button>
                        </h6>
                      {%- endif -%}
                      {%- if block.settings.menu.links != blank -%}

{%- liquid
  assign section_prefix_class = 'featured-product'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign product = section.settings.featured_product
  assign selected_variant = product.selected_or_first_available_variant
  assign current_values = selected_variant.options
  assign media_template_attr = 'data-media-template-' | append: product.id | append: '-' | append: section.id
  assign media_static_attr = 'data-change-media' | append: product.id | append: '-' | append: section.id
  assign featured_image = product.featured_media
  if product.selected_or_first_available_variant.featured_media
  assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif
  assign variant_media = product.selected_or_first_available_variant.featured_media

  assign product_json_id = 'ProductCardJson-' | append: product.id | append: '-' | append: section.id
  assign form_id = 'featured-product-atc-form' | append: product.id | append: '-' | append: section.id
  assign product_form_installment_id = 'main-form-installment' | append: product.id | append: '-' | append: section.id
  assign price_render_attr = 'data-render-price'
  assign sku_render_attr = 'data-render-sku'
  assign stock_render_attr = 'data-render-stock'
  assign stock_badge_render_attr = 'data-render-stock-badge'
  assign qty_render_attr = 'data-render-qty'
  assign stockbar_render_attr = 'data-render-stockbar'
  assign pickup_render_attr = 'data-render-pickup'
  assign share_render_attr = 'data-render-share'
  assign media_slider_attr = 'data-change-slide-' | append: section.id
  assign media_static_attr = 'data-change-media' | append: section.id
  assign error_render_attr = 'data-render-main-error' | append: section.id

  capture container_class
    if section.settings.section_full_width
      echo 'container-fluid'
      else
        echo 'container'
    endif
  endcapture

  capture product_title
    if product.title != blank
      echo product.title
      else
        echo 'product.title' | t
    endif
  endcapture

  capture product_clean_url
    if product.url contains '?'
      assign parts = product.url | split: '?'
      echo parts[0]
      else
        echo product.url
    endif
  endcapture

  capture additional_class
    if variant_media == featured_image
      echo 'same-media'
    else
      echo 'diff-class'
    endif
  endcapture

  capture quantity_input_exist
    for block in section.blocks
      case block.type
        when 'quantity_input'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture loading_attr
    unless section.index != 1
      echo 'eager'
      else
        echo 'lazy'
    endunless
  endcapture

  assign media_size = section.settings.product_media_size

  capture featured_media_size
    if media_size == 'adapt'
      echo featured_image.preview_image.aspect_ratio | default: '1'
      else 
        echo '1'
    endif
  endcapture

  capture variant_media_size
    if media_size == 'adapt'
      echo variant_media.preview_image.aspect_ratio | default: '1'
      else 
        echo '1'
    endif
  endcapture

  assign sizes_attr = '(max-width: 414px) calc(100vw - 98px), (max-width: 991px) calc(100vw - 128px), (max-width: 1259px) calc((100vw * 60 / 100) - 15px), calc((var(--cp-width-px) * 60 / 100) - 15px)'
-%}
{%- style -%}
  .featured-product{
    --q-align-value: var(--mobile-q-align);
  }

  .featured-product .heading-head{
    margin-bottom: 31px;
  }

  .featured-product .product-variant_options-wrap{
    gap: 0;
  }

  .featured-product .product-variant-option{
    border: 1px solid var(--section-border-color);
    margin-left: -1px;
  }

  .featured-product .product-variant_fieldset .product-variant_options-wrap{
    gap: 12px;
  }

  .featured-product .product-variant_fieldset .product-variant-option{
    margin-left: 0;
    border: none;
  }

  .form__message,
  .error-email,
  .contact-form_wrapper,
  .contact-form .two-form-group,
  .collapsible-row_opener,
  .product-pickup_text-wrap,
  .product-common_btn-whatsapp .button_icn-wrapper{
    display: flex;
  }

  .product-common_btn-whatsapp .button_icn-wrapper{
    justify-content: center;
  }

  .form-group,
  .share-button-wrap,
  .dropdown-component--share,
  .locator-row--iframe,
  .featured-product_col--media{
    position: relative;
  }

  .form__message,
  .error-email,
  .product-common_btn-whatsapp .button_icn-wrapper{
    align-items: center;
  }

  .form__message,
  .error-email {
    gap: 10px;
  }

  .form__message {
    font-weight: 400;
    font-size: 1.8rem;
    line-height: 2.8rem;
  }

  .recipient-fields .form__message{
    justify-content: end;
    font-size: 1.2rem;
  }

  .newsletter-form_results-wrap,
  .form__message svg,
  .errors-list_link {
    color: var(--section-error-color);
  }

  .success-message .image,
  .errors-list,
  .modal-component--question-ask .form-group--name,
  .modal-component--question-ask .form-group--email,
  .dropdown-component_share-wrapper,
  .product-pickup--link{
    margin-bottom: 10px;
  }

  .errors-list_link,
  .product-pickup_opener-link.button--link:hover,
  .product-common_details-btn{
    text-decoration: none;
  }

  .error-email {
    right: 0;
  }

  .error-email,
  .contact__field-error {
    font-size: 1.4rem;
    line-height: 2.1rem;
  }

  .success-message,
  .product-common_details-btn{
    text-align: center;
  }

  .success-message {
    margin-top: 39px;
    font-size: 2rem;
    line-height: 3.3rem;
    color: var(--section-success-color);
  }

  .success-message p ,
  .locator-row--iframe iframe,
  .locator-row--iframe svg{
    margin: 0;
  }

  .success-message_icn {
    margin-bottom: 14px;
  }

  .form-group textarea,
  .error-email,
  .product-pickup_showcase-list,
  .product-common_slider-switcher{
    margin-top: 10px;
  }

  .form-wrapper_btn-wrap{
    margin-top: 19px;
  }

  .form-wrapper_button {
    --button-padding-y: 1.1rem;
    --button-padding-x: 1.6rem;
    --button-font-size: 1.4rem;
    --button-line-height: 2rem;
    --button-font-family: var(--body-font-family);
  }

  .modal-component--question-ask .error-email{
    position: static;
    justify-content: end;
  }

  .featured-product{
    overflow: visible;
  }

  .featured-product_wrapper{
    display: flex;
    flex-direction: column-reverse;
  }

  .featured-product_wrapper,
  .form-wrapper_button,
  .contact-form_col-form,
  .locator-row--iframe iframe,
  .locator-row--iframe svg,
  .product-common_details-btn,
  .featured-product_col--description,
  .featured-product_col--description.--description-width.--full-width{
    width: 100%;
  }

  .modal-component--question-ask .modal-component_head{
    margin-bottom: 20px;
  }

  .contact-form{
    --q-align-value: var(--mobile-q-align);
  }

  .contact-form .container-fluid{
    --cp-spacer-left: 0;
    --cp-spacer-right: 0;
  }

  .contact-form .form-group textarea {
    resize: none;
    --input-height: 208px;
  }

  .contact-form .form-group input{
    --input-height: 4.6rem;
  }

  .contact-form .two-form-group{
    gap: 19px;
  }

  .contact-form_form-wrapper .form-group--email,
  .contact-form_form-wrapper .form-group--name{
    margin-bottom: 30px;
    width: 50%;
  }

  .contact-form_wrapper {
    flex-wrap: wrap;
    gap: 18px;
  }

  .featured-product_wrapper{
    border: 1px solid var(--section-border-color);
  }

  .contact-form_col-info {
    flex-grow: 1;
    flex-basis: 0;
  }

  .contact-form .form-wrapper_heading {
    --mt-bottom: 10px;
  }

  .contact-form_col-form .heading-head{
    margin-bottom: 25px;
  }

  .form-wrapper_main-heading{
    --mt-bottom: 28px;
  }

  .locator-row--iframe,
  .product-pickup_icn{
    line-height: 0;
  }

  .locator-row--iframe{
    height: 100%;
  }

  .locator-row--iframe iframe,
  .locator-row--iframe svg{
    height: 300px;
  }

  .locator-row_col--iframe{
    margin-top: 37px;
  }

  .share-button-wrap,
  .collapsible-row_opener-icn{
    margin-left: auto;
  }

  .field__label,
  .share-button__copy,
  .share-button__close,
  .dropdown-component--share .field__label,
  .dropdown-component--share .share-button__message,
  .error-email,
  .featured-product_tags-list{
    position: absolute;
  }

  .featured-product_tags-list{
    top: 18px;
    left: 22px;
  }

  .dropdown-component_share-wrapper{
    width: 273px;
    right: -64px;
    left: auto;
    top: auto;
    bottom: 100%;
    transform: none;
    padding: 40px 60px 10px 10px;
  }

  .--share-native .dropdown-component_share-wrapper,
  [open] summary > .collapsible-row_opener--icn-open,
  .collapsible-row_opener--icn-close,
  .featured-product .--display-none,
  .featured-product .same-media{
    display: none;
  }

  .dropdown-component--share .field__label,
  .share-button__close{
    top: 5px;
  }

  .field__label{
    left: 23px;
  }

  .share-button__copy{
    right: 10px;
    bottom: 10px;
  }

  .share-button-wrap .form-group{
    width: calc(100% - 50px);
  }

  .share-button__close{
    right: 7px;
  }

  .dropdown-component--share .field__label,
  .share-button__message{
    top: -32px;
    left: 23px;
    z-index: 1;
  }

  .share-button__copy.button--icn{
    --button-padding-y: 1.4rem;
    --button-padding-x: 1.3rem;
  }

  .share-button__close.button--icn,
  .share-button__copy.button--icn{
    --btn-icn-bdr: transparent;
  }

  .share-button__close.button--icn{
    --button-padding-y: 0.5rem;
    --button-padding-x: 0.5rem;
  }

  .collapsible-row_opener{
    padding-top: 11px;
    padding-bottom: 11px;
    padding-right: 11px;
    border-bottom: 1px solid var(--border-color);
    cursor: pointer;
  }

  .product-common_details-btn{
    padding: 11px;
  }

  .variant-image-anchor:focus-visible img{
    padding: 2px;
  }

  .collapsible-row_slide-wrapper{
    padding-right: 11px;
  }

  [open] summary > .collapsible-row_opener--icn-close{
    display: inline;
  }

  .product-pickup_wrapper{
    padding-right: 11px;
    border-radius: calc(var(--section-radius) / 2);
  }

  .modal-component--pickup-drawer .product-pickup_wrapper{
    padding: 12px;
  }

  .product-pickup_text-wrap{
    gap: 20px;
    font-style: normal;
  }

  .product-pickup_icn{
    flex-shrink: 0;
    width: 30px;
  }

  .product-pickup_opener-link.button--link{
    --button-padding-y: 0.15rem;
    --button-padding-x: 0;
    --button-font-weight: 500;
    --button-text: var(--section-links-color);
    --button-hover-text: var(--section-active-hover-color);
    text-decoration: underline;
  }

  .product-pickup_text-wrap + .product-pickup_text-wrap,
  .product-pickup_wrapper + .product-pickup_wrapper,
  .product-pickup_cross-icn{
    margin-top: 4px;
  }

  .modal-component--pickup-drawer .modal-component_wrapper{
    max-width: 470px;
  }

  .modal-component--pickup-drawer .modal-component_body{
    min-height: 100%;
    padding: 24px;
  }

  .product-pickup_heading,
  .product-pickup_subheading,
  .variant-image-anchor,
  .product-common_details-btn,
  .success-message_icn,
  .featured-product_variant-image .product-column_image{
    display: block;
  }

  .product-pickup_options-list,
  .product-pickup_subheading{
    margin-top: 5px;
  }

  .product-common_slider-switcher .splide__arrows,
  .contact-form_wrapper {
    margin-top: 20px;
  }

  .featured_image--placeholder{
    height: 100%;
  }

  .featured-product_atc-btn:focus-visible{
    margin: 5px 0;
  }

  .product-common-selected-value{
    margin-left: 6px;
    color: var(--section-heading-color);
    text-transform: capitalize;
  }

  .image-top-scroll{
    position: sticky;
    top: 0;
    overflow: hidden;
  }

  @media (min-width: 576px){
    .featured-product_common-image + .featured-product_common-image{
      border-left: 1px solid var(--section-border-color);
    }

    .dropdown-component_share-wrapper{
      width: 350px;
      right: 0;
    }

    .featured-product_col--media{
      display: flex;
    }

    .featured-product_variant-image{
      width: 50%;
      flex-shrink: 0;
    }

    .featured-image{
      flex-grow: 1;
    }
  }

  @media (min-width: 768px){
    .featured-product{
      --q-align-value: var(--desktop-q-align);
    }

    .contact-form{
      --q-align-value: var(--desktop-q-align);
    }

    .contact-form{
      overflow: visible;
    }

    .contact-form_wrapper {
      gap: 20px;
      margin-top: 50px;
    }

    .contact-form_col-form {
      width: 53%;
    }

    .contact-form--form-center .contact-form_col-form {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      max-width: 703px;
    }

    .locator-row--iframe iframe,
    .locator-row--iframe svg{
      height: 400px;
    }

    .dropdown-component_share-wrapper{
      width: 430px;
    }

    .featured-product_variant-image{
      width: 50%;
      flex-shrink: 0;
    }
  }

  @media (min-width: 992px){
    .featured-product_wrapper{
      flex-direction: unset;
    }

    .featured--border-right{
      border-right: 1px solid var(--section-border-color);
    }

    .featured-product_col--media,
    .featured-product_wrapper{
      display: flex;
    }
    
    .featured-product_col--media{
      flex-grow: 1;
    }
    
    .featured-product_col--description{
      width: 38%;
    }

    .featured-product_variant-image{
      width: 50%;
      flex-shrink: 0;
    }
  }

  @media (min-width:1200px) {
    .contact-form_wrapper {
      gap: 54px;
      margin-top: 72px;
    }

    .locator-row--iframe iframe,
    .locator-row--iframe svg{
      height: 686px;
    }

    .featured-product_col--media{
      flex-grow: 1;
      display: flex;
    }
    
    .featured-product_col--description,
    .featured-product_col--description.--description-width{
      width: 40%;
    }
  }

  @media(max-width: 991px){
    .featured--border-right{
      border-top: 1px solid var(--section-border-color);
    }
  }
{%- endstyle -%}

          <div class="product-common_widget-wrap">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'title' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    <h2 class="mty {{ section_prefix_class }}_title product-common_title {{ block.settings.block_heading_size }} {{ block.settings.block_heading_weight }}">
                      <a {% unless product.title == blank %}href="{{- product_clean_url -}}"{% else %}aria-disabled="true"{% endunless %} class="">
                        {{- product_title -}}
                      </a>
                    </h2>
                  </div>
                {%- when 'price' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    <strong class="product-common_price-wrap {{ block.settings.block_text_size }} {{ block.settings.block_text_weight }}" {{ price_render_attr }}>
                      {%- render 'product-price', product: product, use_variant: true, show_unit_price: true -%}
                    </strong>
                    {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                      <strong class="product-common_taxes-text text-size--small --fw-light">
                        {%- liquid
                          if cart.taxes_included
                            echo 'product.include_taxes' | t
                          endif
                          if shop.shipping_policy.body != blank
                            echo 'product.shipping_policy_html' | t: link: shop.shipping_policy.url
                          endif
                        -%}
                      </strong>
                    {%- endif -%}
                  </div>
                {%- when 'statistics' -%}
                  {%- if block.settings.show_sku or block.settings.show_stock or block.settings.show_vendor -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <ul class="list-unstyled stats-list">
                        {%- if block.settings.show_sku -%}
                          <li class="stats-list_item parent-node">
                            <strong class="product-common_sku-wrap product-common_stat-wrap --v-align-middle text-size--small h {{ block.settings.block_text_weight }}" {{ sku_render_attr }}>
                              {%- render 'product-sku', product: product, show_label: true -%}
                            </strong>
                          </li>
                        {%- endif -%}
                        {%- if block.settings.show_stock -%}
                          <li class="stats-list_item parent-node">
                            <strong class="product-common_stock-wrap product-common_stat-wrap --v-align-middle text-size--small h {{ block.settings.block_text_weight }}" {{ stock_render_attr }}>
                              {%- render 'product-stock', product: product, show_label: true -%}
                            </strong>
                          </li>
                        {%- endif -%}
                        {%- if block.settings.show_vendor -%}
                          <li class="stats-list_item parent-node">
                            <strong class="product-common_vendor-wrap product-common_stat-wrap --v-align-middle text-size--small h {{ block.settings.block_text_weight }}">
                              {%- render 'product-vendor', product: product, show_label: false -%}
                            </strong>
                          </li>
                        {%- endif -%}
                      </ul>
                    </div>
                  {%- endif -%}
                {%- when 'variants_chart' -%}
                  {%- unless product.has_only_default_variant -%}

                                <span class="product-common-selected-value text-size--medium --fw-normal" {{ 'data-selected-parent' | append: forloop.index | append: '-' | append: section.id }}>
                                  {{- option.selected_value -}}
                                </span>
                                {%- if is_size_option == 'true' and block.settings.show_size_chart -%}

                                  <div>
                                    <button
                                      type="button"
                                      class="dropdown-component_opener dropdown-variant_opener --align-left --word-break"
                                      aria-expanded="false"
                                    >
                                      <span>
                                        {{- 'featured_product.gas' | t -}}
                                      </span>
                                      <i class="dropdown-componenet_icn-caret">
                                        {%- render 'icons-data', width: 9, height: 5, use_icon: true, icon_reference: 'chevron-down' -%}
                                      </i>
                                    </button>
                                    <div class="dropdown-component_wrapper dropdown-variant_wrapper">
                                      <ul class="list-unstyled dropdown-variant_items --align-left">
                                        <li>
                                          <button
                                            class="dropdown-component_btn-submit product-variant-option_btn-submit --align-left --v-align-middle --word-break active "
                                            disabled
                                            type="button"
                                            data-value="{{ 'featured_product.gas' | t }}"
                                            data-text="{{ 'featured_product.gas' | t }}"
                                          >
                                            {{- 'featured_product.gas' | t -}}
                                          </button>
                                        </li>
                                        <li>
                                          <button
                                            class="dropdown-component_btn-submit product-variant-option_btn-submit --align-left --v-align-middle --word-break" 
                                            disabled
                                            type="button"
                                            data-value="{{ 'featured_product.solid' | t }}"
                                            data-text="{{ 'featured_product.solid' | t }}"
                                          >
                                            {{- 'featured_product.solid' | t -}}
                                          </button>
                                        </li>
                                      </ul>
                                    </div>
                                  </div>
                                </dropdown-component>
                            {%- endunless -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endunless -%}
                {%- when 'quantity_input' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    <div class="product-common_qty-wrap {% unless block.settings.show_subtotal %}--hide-subtotal{% endunless %}" {{ qty_render_attr }}>
                      <label for="quantity-{{- form_id -}}" class="visually-hidden product-common_variant-title text-size--small --fw-normal">
                        {{- 'quantity.quantity' | t -}}
                      </label>
                      {%- liquid
                        assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
                        assign uses_comma_decimals = false
                        if currencies_using_comma_decimals contains cart.currency.iso_code
                          assign uses_comma_decimals = true
                        endif
                      -%}
                      <quantity-input
                        class="quantity-input product-common_quantity-input --v-align-middle"
                        data-init-value="{{- product.selected_or_first_available_variant.quantity_rule.min -}}"
                        {% unless uses_comma_decimals %}
                          data-variant-price="{{- product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '' | times: 100 -}}"
                          {% else %}
                            data-variant-price="{{- product.selected_or_first_available_variant.price | money_without_currency | replace: '.', '' | replace: ',', '.' | times: 100 -}}"
                        {% endunless %}
                      >
                        <strong class="quantity-input_subtotal-wrap --word-break --fw-normal">
                          <span class="quantit-input_subtotal-title">
                            {{- 'quantity.subtotal' | t -}}:
                          </span>
                          <span class="quantity-input_subtotal-price" data-qty-subtotal="">
                            {%- assign subtotal_price = product.selected_or_first_available_variant.price | default: 1999 -%}
                            {{- subtotal_price | money -}}
                          </span>
                        </strong>
                        <div class="quantity-input_fielder-wrap">
                          <button class="quantity-input_button button button--icn quantity-input_button-minus disabled" disabled name="minus" type="button">
                            <span class="button_icn-wrapper">
                              {%- render 'icons-data', width: 8, height: 8, use_icon: true, icon_reference: 'minus' -%}
                              <span class="visually-hidden">
                                {{- 'quantity.decrease' | t: product: product_title -}}
                              </span>
                            </span>
                          </button>
                          <input
                            type="number"
                            name="quantity"
                            placeholder="1"
                            data-min="{{ product.selected_or_first_available_variant.quantity_rule.min | default: 1 }}"
                            min="{{- product.selected_or_first_available_variant.quantity_rule.min | default: 1 -}}"
                            {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                              data-max="{{- product.selected_or_first_available_variant.quantity_rule.max -}}"
                              max="{{- product.selected_or_first_available_variant.quantity_rule.max -}}"
                            {% endif %}
                            step="{{- product.selected_or_first_available_variant.quantity_rule.increment | default: 1 -}}"
                            value="{{- product.selected_or_first_available_variant.quantity_rule.min | default: 1 -}}"
                            aria-label="{{- 'quantity.input_label' | t: product: product_title -}}"
                            {% if product.title != blank %}
                              form="{{- form_id -}}"
                            {% endif %}
                            id="quantity-{{- form_id -}}"
                            title="{{- 'quantity.input_label' | t: product: product_title -}}"
                          >
                          <button class="quantity-input_button button button--icn quantity-input_button-plus" name="plus" type="button">
                            <span class="button_icn-wrapper">
                              {%- render 'icons-data', width: 8, height: 8, use_icon: true, icon_reference: 'plus' -%}
                              <span class="visually-hidden" style="background-color: white; color: black;">
                                {{- 'quantity.increase' | t: product: product_title -}}
                              </span>
                            </span>
                          </button>
                        </div>
                      </quantity-input>
                    </div>
                    <strong class="product-common_error --v-align-middle --fw-normal --text-error text-size--small hidden" role="alert" tabindex="-1" {{ error_render_attr }}>
                      {%- render 'icons-data', width: 22, height: 22, use_icon: true, icon_reference: 'error' -%}
                      <span data-error=""></span>
                    </strong>
                  </div>
                {%- when 'stock_bar' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    <div class="{{ block.settings.block_text_size }} {{ block.settings.block_text_weight }}" {{ stockbar_render_attr }}>
                      {%- render 'product-stock-bar', product: product -%}
                    </div>
                  </div>
                {%- when 'buttons' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    {%- if product.title != blank -%}
                      {%- form 'product',
                        product,
                        data-productid: product.id,
                        id: product_form_installment_id,
                        class: 'product-atc-installment-form'
                      -%}
                        <input
                          type="hidden"
                          name="id"
                          data-productid="{{- product.id -}}"
                          value="{{- product.selected_or_first_available_variant.id -}}"
                        >
                        {{- form | payment_terms -}}
                      {%- endform -%}
                      {%- form 'product',
                        product,
                        id: form_id,
                        class: 'featured-product_submit-from',
                        novalidate: 'novalidate',
                        data-type: 'add-to-cart-form'
                      -%}
                        {%- liquid
                          assign gift_card_recipient_feature_active = false
                          if block.settings.show_gift_card_recipient and product.gift_card?
                            assign gift_card_recipient_feature_active = true
                          endif
    
                          assign show_dynamic_checkout = false
                          if block.settings.show_dynamic_checkouts and gift_card_recipient_feature_active == false
                            assign show_dynamic_checkout = true
                          endif
    
                          if gift_card_recipient_feature_active
                            render 'gift-card-recipient-form', product: product, form: form, section: section, error_render_attr: error_render_attr
                          endif
    
                          assign check_against_inventory = true
                          if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
                            assign check_against_inventory = false
                          endif
                          if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
                            assign quantity_rule_soldout = true
                          endif
    
                          capture atc_button_label
                            if product.selected_or_first_available_variant.available == false or quantity_rule_soldout
                              echo 'product.atc_buttons.soldout' | t
                              else
                                echo 'product.atc_buttons.add_to_cart' | t
                            endif
                          endcapture
                        -%}
                        <input
                          type="hidden"
                          name="id"
                          value="{{- product.selected_or_first_available_variant.id -}}"
                        >
                        {%- unless quantity_input_exist == 'true' -%}
                          <input
                            type="hidden"
                            name="quantity"
                            data-min="1"
                            value="1"
                          >
                        {%- endunless -%}
                        {%- render 'product-artwork-upload', form_id: form_id -%}
                        <div class="product-common_btns-wrap">
                          <div class="product-common_form-btns --v-align-start">
                            <atc-submit
                              class="product-common_atc-form"
                              data-error-selector="[{{ error_render_attr }}]"
                              data-form="#{{ form_id }}"
                              {% unless template.name == 'cart' %}
                                {% unless settings.cart_view == 'drawer' %}
                                  data-redirect="{{- routes.cart_url -}}"
                                {% endunless %}
                              {% endunless %}
                              {% unless template.name == 'cart' %}
                                data-modal="true"
                                data-modal-ref='[data-modal-ref="modal-cart-drawer"][data-expanded="false"]'
                              {% endunless %}
                              data-sections='[
                                {
                                  "id": "cart-head",
                                  "selectors": ["[data-render-cart-bubble]", "[data-render-cart-text]", "[data-render-cart-bubble-aside]", "[data-render-cart-text-aside]"]
                                },
                                {
                                  "id": "cart-showcase",
                                  "selectors": ["[data-line-items-drawer-container]"]
                                }
                                {% if template.name == 'cart' %}
                                  ,
                                  {
                                    "id": "main-cart",
                                    "selectors": ["[data-line-items-container]"]
                                  }
                                {% endif %}
                              ]'
                            >
                              <button
                                type="submit"
                                name="add"
                                class="button button--primary {{ section_prefix_class }}_atc-btn product-common_atc-btn button--animate"
                                {% if product.selected_or_first_available_variant.available == false or quantity_rule_soldout %}
                                  disabled
                                {% endif %}
                              >
                                <span data-atc-text="" data-text-avail="{{- 'product.atc_buttons.add_to_cart' | t -}}" data-text-sold="{{- 'product.atc_buttons.soldout' | t -}}" data-text-unavail="{{- 'product.atc_buttons.unavailable' | t -}}">
                                  {{- atc_button_label -}}
                                </span>
                              </button>
                            </atc-submit>
                            {%- if block.settings.show_whatsapp and block.settings.whatsapp_number != blank -%}
                              {% liquid
                                capture wasapp_message
                                  assign url_origin = product.selected_or_first_available_variant.url | prepend: request.origin
                                  if block.settings.custom_message != blank
                                    assign remove_spaces = block.settings.custom_message | replace: ' ', '&nbsp;'
                                    echo remove_spaces | replace: '||product_url||', url_origin
                                    else
                                      echo product.selected_or_first_available_variant.url
                                  endif
                                endcapture
                              %}
                              <a
                                href="https://wa.me/{{ block.settings.whatsapp_number }}?text={{ wasapp_message }}"
                                target="_blank"
                                class="button button--icn product-common_btn-whatsapp button--animate"
                                data-tooltip="{{- 'product.whatsapp_label' | t -}}"
                              >
                                <span class="button_icn-wrapper">
                                  {%- render 'icons-data', width: 30, height: 30, use_icon: true, icon_reference: 'whatsapp', section_id: section.id -%}
                                  <span class="whatsapp-text">
                                    {{- 'product.whatsapp_label' | t -}}
                                  </span>
                                </span>
                              </a>
                            {%- endif -%}
                          </div>
                          {%- if show_dynamic_checkout -%}
                            <div class="product-common_dynamic-btns">
                              {{- form | payment_button -}}
                            </div>
                          {%- endif -%}
                          <div class="product-common_full-details">
                            <a class="product-common_details-btn" href="{{ product.url }}">
                              {{ 'featured_product.view_details' | t }}
                            </a>
                          </div>
                        </div>
                      {%- endform -%}
                      {%- unless quantity_input_exist == true -%}
                        <strong
                          class="product-common_error --v-align-middle --fw-normal --text-error text-size--small hidden"
                          role="alert"
                          tabindex="-1"
                          {{ error_render_attr }}
                        >
                          {%- render 'icons-data', width: 22, height: 22, use_icon: true, icon_reference: 'error' -%}
                          <span data-error=""></span>
                        </strong>
                      {%- endunless -%}
                      {%- else -%}
                        <button
                          type="button"
                          class="button button--primary {{ section_prefix_class }}_atc-btn product-common_atc-btn button--animate"
                          disabled
                        >
                          <span data-atc-text="">
                            {{- 'product.atc_buttons.soldout' | t -}}
                          </span>
                        </button>
                    {%- endif -%}
                  </div>
                {%- when 'payment_icons' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }} --align-center"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    {%- if block.settings.heading != blank -%}
                      <strong class="product-common_pay-title h {{ block.settings.block_heading_size }} {{ block.settings.block_heading_weight }}">
                        {{- block.settings.heading -}}
                      </strong>
                    {%- endif -%}
                    {%- render 'payment-icons', prefix_class: 'product-common' -%}
                  </div>
                {%- when 'action_buttons' -%}
                  {%- if block.settings.enable_question or block.settings.enable_share -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }} --align-center"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <div class="product-common_action-btns">
                        {%- if block.settings.enable_question -%}
                          <div class="product-common_action-col product-common_action-col--ask">
                            {%- if product.title != blank -%}
                            <modal-component-toggler>
                              <button
                                type="button"
                                data-expanded="false"
                                data-modal-ref="{{ section.id }}-modal-question-ask"
                                aria-haspopup="dialog"
                                aria-controls="{{ section.id }}-modal-question-ask"
                                class="button button--primary procut-common_ask-btn button--animate --fw-normal"
                              >
                                {%- render 'icons-data', width: 20, height: 20, use_icon: true, icon_reference: 'question' -%}
                                {{- 'product.ask_question.label' | t -}}
                              </button>
                            </modal-component-toggler>
                            <modal-component
                              data-modal="{{ section.id }}-modal-question-ask"
                              data-container="body"
                            >
                              <div
                                class="modal modal-component modal-component--question-ask modal-component--centered scheme--{{ section.settings.section_color_scheme }}"
                                role="dialog"
                                aria-modal="true"
                                aria-labelledby="{{ section.id }}-modal-question-ask-heading"
                                aria-describedby="{{ section.id }}-modal-question-ask"
                                tabindex="-1"
                              >
                                <div class="modal-component_spacer">
                                  <div class="modal-component_wrapper" id="{{ section.id }}-modal-question-ask">
                                    <div class="modal-component_body">
                                      <div class="modal-component_head --align-center">
                                        <modal-component-toggler>
                                          <button type="button"
                                            data-expanded="true"
                                            data-toggle-attribute="false"
                                            data-modal-ref="{{ section.id }}-modal-question-ask"
                                            class="modal-component_btn-close button button--icn"
                                          >
                                            {%- render 'icons-data', width: 14, height: 14, use_icon: true, icon_reference: 'cross' -%}
                                            <span class="visually-hidden">{{- 'accessibility.close' | t -}}</span>
                                          </button>
                                        </modal-component-toggler>
                                        <strong id="{{ section.id }}-modal-question-ask-heading" class="modal-component_heading mty h6">
                                          {{- 'product.ask_question.heading' | t -}}
                                        </strong>
                                        <em class="question-popup_steric">
                                          {{- 'product.ask_question.required_fields' | t -}}
                                        </em>
                                      </div>
                                      <div class="modal-component_content">
                                        {%- assign form_ask_id = 'ContactForm' | append: section.id -%}
                                        {%- form 'contact', id: form_ask_id, class: 'isolate' -%}
                                          {%- if form.errors != blank -%}
                                            <strong class="form__message --fw-normal mty" role="alert" tabindex="-1">
                                              {%- render 'icons-data', width: 22, height: 22, use_icon: true, icon_reference: 'error' -%}
                                              {{- 'erorr.common_heading' | t -}}
                                            </strong>
                                            <ul class="errors-list list-unstyled">
                                              <li class="errors-list_item">
                                                <smooth-anchor data-offset=".sticky-header-wrapper">
                                                  <a class="errors-list_link text-size--small" href="#ContactForm-email-{{ form_ask_id }}">
                                                    *{{- form.errors.translated_fields.email | capitalize }}
                                                    {{ form.errors.messages.email -}}
                                                  </a>
                                                </smooth-anchor>
                                              </li>
                                            </ul>
                                          {%- endif -%}
                                          <div class="two-form-group">
                                            <div class="form-group form-group--name">
                                              <label class="text-size--small --fw-medium visually-hidden" for="contact-name-{{ form_ask_id }}">{{- 'contact_form.form_label.name.label' | t -}}</label>
                                              <input type="text" id="contact-name-{{ form_ask_id }}" name="contact[Name]" placeholder="{{- 'contact_form.form_placeholder.name.label' | t -}}">
                                            </div>
                                            <div class="form-group form-group--email">
                                              <label class="text-size--small --fw-medium visually-hidden" for="ContactForm-email-{{ form_ask_id }}">{{- 'contact_form.form_label.email.label' | t -}}</label>
                                              <input
                                                type="email"
                                                id="ContactForm-email-{{ form_ask_id }}"
                                                name="contact[email]"
                                                placeholder="{{- 'contact_form.form_placeholder.email.label' | t -}}"
                                              >
                                              <div class="newsletter-form_results-wrap results-wrap_message text-size--small">
                                                {%- if form.errors contains 'email' -%}
                                                  <div class="error-email">
                                                    {%- render 'icons-data', width: 22, height: 22, use_icon: true, icon_reference: 'error' -%}
                                                    <small class="contact__field-error" id="ContactForm-email-{{ form_ask_id }}-error">
                                                      {{- form.errors.translated_fields.email | capitalize }}
                                                      {{ form.errors.messages.email -}}
                                                    </small>
                                                  </div>
                                                {%- endif -%}
                                              </div>
                                            </div>
                                          </div>
                                          <div class="form-group form-group--textarea">
                                            <label class="text-size--small --fw-medium visually-hidden" for="contact-textarea-{{ form_ask_id }}">{{- 'contact_form.form_label.your_request.label' | t -}}</label>
                                            <textarea name="contact[textarea]" id="contact-textarea-{{ form_ask_id }}" placeholder="{{- 'contact_form.form_placeholder.your_request.label' | t -}}"></textarea>
                                          </div>
                                          <div class="form-wrapper_btn-wrap">
                                            <button class="button button--primary form-wrapper_button" type="submit">
                                              {{- 'contact_form.submit_label' | t -}}
                                            </button>
                                          </div>
                                          {%- if form.posted_successfully? -%}
                                            <div class="success-message" role="alert" tabindex="-1">
                                              <i class="success-message_icn">
                                                {%- render 'icons-data', width: 54, height: 54, use_icon: true, icon_reference: 'smile' -%}
                                              </i>
                                              <p>{{- 'contact_form.success.heading1' | t -}}</p>
                                              <p>{{- 'contact_form.success.heading2' | t -}}</p>
                                            </div>
                                          {%- endif -%}
                                        {%- endform -%}
                                      </div>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </modal-component>
                            {%- else -%}
                              <div>
                                <a
                                  aria-disabled
                                  class="button button--primary procut-common_ask-btn button--animate --fw-normal"
                                >
                                  {%- render 'icons-data', width: 20, height: 20, use_icon: true, icon_reference: 'question' -%}
                                  {{- 'product.ask_question.label' | t -}}
                                </a>
                              </div>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                        {%- if block.settings.enable_share -%}
                          <div class="product-common_action-col product-common_action-col--share" {{ share_render_attr }}>
                            {%- assign share_url = request.origin | append: product.url | append: '?variant=' | append: product.selected_or_first_available_variant.id -%}
                            {%- if product.title != blank -%}
                            {%- render 'share-button', share_link: share_url, share_title: product_title, product: product, view: 'full-button', section_id: section.id -%}
                            {%- else -%}
                              <div class="dropdown-component--share">
                                <a
                                  aria-disabled="true"
                                  class="dropdown-component_opener button button--primary share-button__button button--animate --fw-normal"
                                >
                                  {{- 'share_button.label' | t -}}
                                </a>
                              </div>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'collapsible_row' -%}
                <div
                  class="product-common_row product-common_row--{{ block.type }}"
                  style="--block-spacing: {{ block.settings.block_spacing }}px;"
                  {{ block.shopify_attributes }}
                >
                  {%- render 'collapsible-row', block: block, prefix_class: section_prefix_class, heading_size: block.settings.block_heading_size, heading_weight: block.settings.block_heading_weight, description_size: block.settings.block_description_size, description_weight: block.settings.block_description_weight, section_id: section.id -%}
                </div>
              {%- when 'pickup_availability' -%}
                <div
                  class="product-common_row product-common_row--{{ block.type }}"
                  style="--block-spacing: {{ block.settings.block_spacing }}px;"
                  {{ block.shopify_attributes }}
                  {{ pickup_render_attr }}
                >
                  {%- liquid
                    assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities | where: 'pick_up_enabled', true
                    assign closest_location = pick_up_availabilities.first
                  -%}
                  <div
                    class="product-pickup"
                    {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
                      available
                      {% else %}
                      hidden
                    {% endif %}
                  >
                    <div class="product-pickup_wrapper">
                      {%- if closest_location.available -%}
                        <strong class="product-pickup_text-wrap h --word-break --v-align-start {{ block.settings.block_text_weight }} {{ block.settings.block_text_size }}">
                          <span>
                            {{- 'product.pickup.available_at' | t: location: closest_location.location.name -}}
                          </span>
                        </strong>
                        <em class="product-pickup_text-wrap h product-pickup--link --v-align-start --word-break {{ block.settings.block_text_weight }} {{ block.settings.block_text_size }}">
                          <span>
                            {{- closest_location.pick_up_time -}}
                          </span>
                        </em>
                        {%- if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 -%}
                          <modal-component-toggler>
                            <button
                              type="button"
                              data-expanded="false"
                              data-modal-ref="modal-pickup-drawer-{{ section.id }}"
                              aria-haspopup="dialog"
                              aria-controls="modal-pickup-drawer-{{ section.id }}"
                              class="button button--link product-pickup_opener-link"
                            >
                              {%- liquid
                                if pick_up_availabilities.size == 1
                                  echo 'product.pickup.view_store' | t
                                  else
                                    echo 'product.pickup.other_store' | t
                                endif
                              -%}
                            </button>
                          </modal-component-toggler>
                        {%- endif -%}
                        {%- else -%}
                          <strong class="product-pickup_text-wrap h --v-align-start --word-break {{ block.settings.block_text_weight }} {{ block.settings.block_text_size }}">
                            <span>
                              {{- 'product.pickup.unavailable_at' | t: location: closest_location.location.name -}}
                            </span>
                          </strong>
                          <em class="product-pickup_text-wrap h product-pickup--link --v-align-start --word-break {{ block.settings.block_text_weight }} {{ block.settings.block_text_size }}">
                            <span>
                              {{- closest_location.pick_up_time -}}
                            </span>
                          </em>
                          {%- if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 -%}
                            <modal-component-toggler>
                              <button
                                type="button"
                                data-expanded="false"
                                data-modal-ref="modal-pickup-drawer-{{ section.id }}"
                                aria-haspopup="dialog"
                                aria-controls="modal-pickup-drawer-{{ section.id }}"
                                class="button button--link product-pickup_opener-link"
                              >
                                {%- liquid
                                  if pick_up_availabilities.size == 1
                                    echo 'product.pickup.view_store' | t
                                    else
                                      echo 'product.pickup.other_store' | t
                                  endif
                                -%}
                              </button>
                            </modal-component-toggler>
                          {%- endif -%}
                      {%- endif -%}
                    </div>
                    {%- if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 -%}
                      <modal-render-component
                        data-modal="modal-pickup-drawer-{{ section.id }}"
                        data-container="body"
                        data-url="{{ request.origin }}{{ product.url }}?variant={{ product.selected_or_first_available_variant.id }}&"
                        data-section="modal-pickup-drawer"
                        data-selector="#pickup-selector-{{ section.id }}"
                        data-render-selector="modal-pickup-drawer"
                      >
                        <div
                          class="modal modal-component --drawer modal-component--pickup-drawer"
                          role="dialog"
                          aria-modal="true"
                          aria-labelledby="modal-pickup-drawer-{{ section.id }}-heading"
                          aria-describedby="modal-pickup-drawer-{{ section.id }}"
                          tabindex="-1"
                        >
                          <div class="modal-component_wrapper scheme scheme--{{ section.settings.section_color_scheme }}" id="modal-pickup-drawer-{{ section.id }}">
                            <modal-component-toggler>
                              <button
                                type="button"
                                data-expanded="true"
                                data-toggle-attribute="false"
                                data-modal-ref="modal-pickup-drawer-{{ section.id }}"
                                class="modal-component_btn-close button button--icn"
                              >
                                <span class="button_icn-wrapper">
                                  {%- render 'icons-data', width: 14, height: 14, use_icon: true, icon_reference: 'cross' -%}
                                  <span class="visually-hidden">{{- 'accessibility.close' | t -}}</span>
                                </span>
                              </button>
                            </modal-component-toggler>
                            <strong id="modal-pickup-drawer-{{ section.id }}-heading" class="modal-component_heading mty h6 visually-hidden">
                              {{- 'product.pickup.label' | t -}}
                            </strong>
                            <div class="modal-component_body" id="pickup-selector-{{ section.id }}"></div>
                          </div>
                        </div>
                      </modal-render-component>
                    {%- endif -%}
                  </div>
                </div>
              {%- when 'content' -%}
                {%- if product.description != blank -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    <div class="{{ block.settings.block_text_weight }} {{ block.settings.block_text_size }}">
                      {{- product.description -}}
                    </div>
                  </div>
                {%- endif -%}
              {%- when 'custom_liquid' -%}
                <div
                  class="product-common_row product-common_row--{{ block.type }}"
                  style="--block-spacing: {{ block.settings.block_spacing }}px;"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.custom_liquid -}}
                </div>
              {%- when '@app' -%}
                <div
                  class="product-common_row product-common_row--{{ block.type }}"
                  style="--block-spacing: {{ block.settings.block_spacing }}px;"
                  {{ block.shopify_attributes }}
                >
                  {%- render block -%}
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
      {%- if product.title != blank -%}
        <div class="{{ section_prefix_class }}_col {{ section_prefix_class }}_col--media ">
          <div class="{{ section_prefix_class }}_variant-image {{ additional_class }} {% if variant_media.preview_image == null %}--display-none{% endif %} {% unless variant_media.preview_image == null or variant_media == featured_image %}{{ section_prefix_class }}_common-image{% endunless %}" {{ media_static_attr }}>
            <a {% if product.url != blank -%}href="{{ product.url }}"{% else %} aria-disabled="true" {% endif %} class="variant-image-anchor image-top-scroll anim--shine --media-size-{{ media_size }}" style="--media-ratio: {{ variant_media_size }};" data-media-id="{{- variant_media.id -}}">
              {%- if variant_media.preview_image != blank -%}
                <img
                  srcset="{%- if variant_media.preview_image.width >= 152 -%}{{ variant_media.preview_image | image_url: width: 152 }} 152w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 240 -%}{{ variant_media.preview_image | image_url: width: 240 }} 240w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 299 -%}{{ variant_media.preview_image | image_url: width: 299 }} 299w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 368 -%}{{ variant_media.preview_image | image_url: width: 368 }} 368w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 400 -%}{{ variant_media.preview_image | image_url: width: 400 }} 400w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 512 -%}{{ variant_media.preview_image | image_url: width: 512 }} 512w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 607 -%}{{ variant_media.preview_image | image_url: width: 607 }} 607w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 640 -%}{{ variant_media.preview_image | image_url: width: 640 }} 640w,{%- endif -%}
                          {%- if variant_media.preview_image.width >= 789 -%}{{ variant_media.preview_image | image_url: width: 789 }} 789w,{%- endif -%}
                          {{ variant_media.preview_image | image_url: width: variant_media.preview_image.width }} {{ variant_media.preview_image.width }}w"
                  sizes="{{- sizes_attr -}}"
                  src="{{- variant_media.preview_image | image_url: width: 240 -}}"
                  alt="{{- product.title | escape -}}"
                  loading="{{ loading_attr }}"
                  width= "240"
                  height="{{- 240 | divided_by: variant_media.preview_image.aspect_ratio | round -}}"
                  class="object-fit object-fit--absolute"
                >
                {%- endif -%}
                <span class="visually-hidden">{{- product.title -}}</span>
            </a>
          </div>
          <div class="featured-image {{ section_prefix_class }}_common-image">
            <div class="{{ section_prefix_class }}_featured_image image-top-scroll anim--shine --media-size-{{ media_size }}" style="--media-ratio: {{ featured_media_size }};">
              {%- if featured_image.preview_image != blank -%}
                <img
                  srcset="{%- if featured_image.preview_image.width >= 190 -%}{{ featured_image.preview_image | image_url: width: 190 }} 190w,{%- endif -%}
                          {%- if featured_image.preview_image.width >= 222 -%}{{ featured_image.preview_image | image_url: width: 222 }} 222w,{%- endif -%}
                          {%- if featured_image.preview_image.width >= 316 -%}{{ featured_image.preview_image | image_url: width: 316 }} 316w,{%- endif -%}
                          {%- if featured_image.preview_image.width >= 464 -%}{{ featured_image.preview_image | image_url: width: 464 }} 464w,{%- endif -%}
                          {%- if featured_image.preview_image.width >= 512 -%}{{ featured_image.preview_image | image_url: width: 512 }} 512w,{%- endif -%}
                          {%- if featured_image.preview_image.width >= 607 -%}{{ featured_image.preview_image | image_url: width: 607 }} 607w,{%- endif -%}
                          {%- if featured_image.preview_image.width >= 640 -%}{{ featured_image.preview_image | image_url: width: 640 }} 640w,{%- endif -%}
                          {%- if featured_image.preview_image.width >= 789 -%}{{ featured_image.preview_image | image_url: width: 789 }} 789w,{%- endif -%}
                          {{ featured_image.preview_image | image_url }} {{ featured_image.preview_image.width }}w"
                  sizes="(max-width: 414px) calc(100vw - 98px), (max-width: 991px) calc(100vw - 128px), (max-width: 1259px) calc((100vw * 60 / 100) - 15px), calc((var(--cp-width-px) * 60 / 100) - 15px)"
                  src="{{- featured_image.preview_image | image_url: width: 190 -}}"
                  alt="{{- product.title | escape -}}"
                  loading="{{ loading_attr }}"
                  width="190"
                  height="{{- 190 | divided_by: featured_image.preview_image.aspect_ratio | round -}}"
                  class="object-fit object-fit--absolute"
                >
              {%- endif -%}
            </div>
          </div>
          {% if section.settings.show_stock_tag %}
            <ul class="list-unstyled tags-list {{ section_prefix_class }}_tags-list --v-align-middle">
              <li class="tags-list_item parent-node">
                <strong class="tags-list_tag --fw-medium" {{ stock_badge_render_attr }}>
                  {%- render 'product-stock-tag', product: product -%}
                </strong>
              </li>
            </ul>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="{{ section_prefix_class }}_col {{ section_prefix_class }}_col--media">
          <div class="{{ section_prefix_class }}_variant-image">
            <div class="variant-image-anchor image-top-scroll anim--shine --media-size-{{ media_size }} featured_image--placeholder" style="--media-ratio: {{ variant_media_size }};">
              {%- render 'placeholder-svgs', type: 'product', class: 'object-fit object-fit--absolute', index: 3  -%}
            </div>
          </div>
          <div class="featured-image">
            <div class="{{ section_prefix_class }}_featured_image image-top-scroll anim--shine featured_image--placeholder --media-size-{{ media_size }}" style="--media-ratio: {{ featured_media_size }};">
              {%- render 'placeholder-svgs', type: 'product', class: 'object-fit object-fit--absolute', index: 4  -%}
            </div>
          </div>
          {% if section.settings.show_stock_tag %}
            <ul class="list-unstyled tags-list {{ section_prefix_class }}_tags-list --v-align-middle">
              <li class="tags-list_item parent-node">
                <strong class="tags-list_tag --fw-medium">
                  {%- render 'product-stock-tag', product: product -%}
                </strong>
              </li>
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
  <script id="{{- product_json_id -}}" type="application/json">
    {
      "handle": "{{ product.handle | escape }}",
      "available": {{ product.available | json }},
      "variants": [
        {%- for variant in product.variants -%}
          {
            "id": {{ variant.id | json }},
            "featured_image": {% unless variant.featured_media.id == blank %}{{ variant.featured_media.id }}{% else %}null{% endunless %},
            "available": {{ variant.available | json }},
            "options": {{ variant.options | json }},
            "option1": {{ variant.option1 | json }},
            "option2": {{ variant.option2 | json }},
            "option3": {{ variant.option3 | json }},
            "quantity_rule": {{ variant.quantity_rule | json }}
          }
          {% if forloop.last == false %},{% endif -%}
        {%- endfor -%}
      ]
    }
  </script>
  <script type="application/ld+json">
    {{ product | structured_data }}
  </script>
  {%- if request.design_mode == false -%}
    {%- if product.media.size > 0 -%}
      <link
        rel="stylesheet"
        href="{{ 'photoswipe.css' | asset_url }}"
        media="print"
        onload="this.media='all'"
      >
      <script type="module">
        import PhotoSwipeLightbox from '{{- 'photoswipe-lightbox.esm.js' | asset_url -}}';
        let options = {
          gallery: '#gallery-zoom-in-{{- section.id -}}{{- product.id -}}',
          children: '.--media-zoom-in',
          pswpModule: () => import('{{- 'photoswipe.esm.js' | asset_url -}}')
        };
        {%- if section.settings.product_gallery_view == 'thumbnails_only' -%}
          if(screen.width > 991) options.gallery = '#gallery-zoom-in-{{- section.id -}}{{- product.id -}}-stacked';
        {%- endif -%}
        const lightbox = new PhotoSwipeLightbox(options);
        lightbox.init();
      </script>
    {%- endif -%}
  {%- endif -%}
  <template {{ media_template_attr }}>
    {%- unless variant_media.preview_image != blank -%}
      <a {% if product.url != blank -%}href="{{ product.url }}"{% else %} aria-disabled="true" {% endif %} class="{{ section_prefix_class }}_variant-image image-top-scroll anim--shine --media-size-{{ media_size }}" style="--media-ratio: {{ variant_media_size }};">
        <img
          srcset="{%- if variant_media.preview_image.width >= 152 -%}{{ variant_media.preview_image | image_url: width: 152 }} 152w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 240 -%}{{ variant_media.preview_image | image_url: width: 240 }} 240w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 299 -%}{{ variant_media.preview_image | image_url: width: 299 }} 299w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 368 -%}{{ variant_media.preview_image | image_url: width: 368 }} 368w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 400 -%}{{ variant_media.preview_image | image_url: width: 400 }} 400w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 512 -%}{{ variant_media.preview_image | image_url: width: 512 }} 512w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 607 -%}{{ variant_media.preview_image | image_url: width: 607 }} 607w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 640 -%}{{ variant_media.preview_image | image_url: width: 640 }} 640w,{%- endif -%}
                  {%- if variant_media.preview_image.width >= 789 -%}{{ variant_media.preview_image | image_url: width: 789 }} 789w,{%- endif -%}
                  {{ variant_media.preview_image | image_url: width: variant_media.preview_image.width }} {{ variant_media.preview_image.width }}w"
          sizes="{{- sizes_attr -}}"
          src="{{- variant_media.preview_image | image_url: width: 240 -}}"
          alt="{{- product.title | escape -}}"
          loading="{{ loading_attr }}"
          width= "240"
          height="{{- 240 | divided_by: variant_media.preview_image.aspect_ratio | round -}}"
          class="object-fit object-fit--absolute"
        >
        <span class="visually-hidden">{{- product.title -}}</span>
      </a>
    {%- endunless -%}
    {%- for variant in product.variants -%}
      {%- liquid
        capture media_ratio
          if media_size == 'adapt'
            echo variant.featured_image.aspect_ratio | default: '1'
            else 
              echo '1'
          endif
        endcapture
      -%}
      <a href="{{- variant.url -}}" class="product-column_image image-top-scroll anim--shine --media-size-{{ media_size }}" style="--media-ratio: {{ media_ratio }};" data-media-id="{{ variant.featured_media.id }}">
        {%- unless variant.featured_image == blank -%}
          <img
            srcset="{%- if variant.featured_image.width >= 152 -%}{{ variant.featured_image | image_url: width: 152 }} 152w,{%- endif -%}
                    {%- if variant.featured_image.width >= 240 -%}{{ variant.featured_image | image_url: width: 240 }} 240w,{%- endif -%}
                    {%- if variant.featured_image.width >= 299 -%}{{ variant.featured_image | image_url: width: 299 }} 299w,{%- endif -%}
                    {%- if variant.featured_image.width >= 368 -%}{{ variant.featured_image | image_url: width: 368 }} 368w,{%- endif -%}
                    {%- if variant.featured_image.width >= 400 -%}{{ variant.featured_image | image_url: width: 400 }} 400w{%- endif -%}
                    {%- if variant.featured_image.width >= 512 -%}{{ variant.featured_image | image_url: width: 512 }} 512w,{%- endif -%}
                    {%- if variant.featured_image.width >= 607 -%}{{ variant.featured_image | image_url: width: 607 }} 607w,{%- endif -%}
                    {%- if variant.featured_image.width >= 640 -%}{{ variant.featured_image | image_url: width: 640 }} 640w,{%- endif -%}
                    {%- if variant.featured_image.width >= 789 -%}{{ variant.featured_image | image_url: width: 789 }} 789w,{%- endif -%}"
            sizes="{{- sizes_attr -}}"
            src="{{- variant.featured_image | image_url: width: 240 -}}"
            alt="{{- product.title | escape -}}"
            loading="{{- loading_attr -}}"
            width="{{- 240 -}}"
            height="{{- 240 | divided_by: variant.featured_image.aspect_ratio | round -}}"
            class="object-fit object-fit--absolute"
          >
          {%- else -%}
            {{- 'image' | placeholder_svg_tag: 'object-fit object-fit--absolute' -}}
            <span class="visually-hidden">
              {{- image_alt -}}
            </span>
        {%- endunless -%}
        <span class="visually-hidden">{{- product.title -}}</span>
      </a>
    {%- endfor -%}
  </template>
</div>
{% schema %}
{
  "name": "t:sections.featured_product.name",
  "tag": "section",
    "disabled_on": {
      "groups": [
        "header",
        "footer",
        "custom.overlay"
      ]
    },
  "blocks": [
    {
      "name": "t:product.blocks.title.name",
      "type": "title",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "block_heading_size",
          "label": "t:sizes.heading.label",
          "options": [
            {
              "value": "text-size--small",
              "label": "t:sizes.text.options.opt_1.label"
            },
            {
              "value": "text-size--medium",
              "label": "t:sizes.text.options.opt_2.label"
            },
            {
              "value": "text-size--large",
              "label": "t:sizes.text.options.opt_3.label"
            },
            {
              "value": "text-size--xlarge",
              "label": "t:sizes.text.options.opt_4.label"
            }
          ],
          "default": "text-size--large"
        },
        {
          "type": "select",
          "id": "block_heading_weight",
          "label": "t:weight.heading.label",
          "options": [
            {
              "value": "--fw-bold",
              "label": "t:weight.heading.options.opt_1.label"
            },
            {
              "value": "--fw-semi-bold",
              "label": "t:weight.heading.options.opt_5.label"
            },
            {
              "value": "--fw-medium",
              "label": "t:weight.heading.options.opt_2.label"
            },
            {
              "value": "--fw-normal",
              "label": "t:weight.heading.options.opt_3.label"
            },
            {
              "value": "--fw-light",
              "label": "t:weight.heading.options.opt_4.label"
            }
          ],
          "default": "--fw-bold"
        },
        {
          "type": "range",
          "id": "block_spacing",
          "label": "t:bottom_margin.label",
          "min": 0,
          "max": 50,
          "step": 1,
          "default": 10,
          "unit": "px"
        }
      ]
    },
    {
      "name": "t:product.blocks.price.name",
      "type": "price",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "block_text_size",
          "label": "t:sizes.text.label",
          "options": [
            {
              "value": "text-size--small",
              "label": "t:sizes.text.options.opt_1.label"
            },
            {
              "value": "text-size--medium",
              "label": "t:sizes.text.options.opt_2.label"
            },
            {
              "value": "text-size--large",
              "label": "t:sizes.text.options.opt_3.label"
            }
          ],
          "default": "text-size--small"
        },
        {
          "type": "select",
          "id": "block_text_weight",
          "label": "t:weight.text.label",
          "options": [
            {
              "value": "--fw-bold",
              "label": "t:weight.heading.options.opt_1.label"
            },
            {
              "value": "--fw-semi-bold",
              "label": "t:weight.heading.options.opt_5.label"
            },
            {
              "value": "--fw-medium",
              "label": "t:weight.heading.options.opt_2.label"
            },
            {
              "value": "--fw-normal",
              "label": "t:weight.heading.options.opt_3.label"
            },
            {
              "value": "--fw-light",
              "label": "t:weight.heading.options.opt_4.label"
            }
          ],
          "default": "--fw-semi-bold"
        },
        {
          "type": "range",
          "id": "block_spacing",
          "label": "t:bottom_margin.label",
          "min": 0,
          "max": 50,
          "step": 1,
          "default": 4,
          "unit": "px"
        }
      ]
    },
    {
      "name": "t:product.blocks.statistics.name",
      "type": "statistics",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_sku",
          "default": false,
          "label": "t:product.sku.label"
        },
        {
          "type": "checkbox",
          "id": "show_stock",
          "default": false,
          "label": "t:product.stock.label"
        },
        {
          "type": "checkbox",
          "id": "show_vendor",
          "default": true,
          "label": "t:product.vendor.label"
        },
        {
          "type": "select",
          "id": "block_text_weight",
          "label": "t:weight.text.label",
          "options": [
            {
              "value": "--fw-bold",
              "label": "t:weight.heading.options.opt_1.label"
            },
            {
              "value": "--fw-semi-bold",
              "label": "t:weight.heading.options.opt_5.label"
            },
            {
              "value": "--fw-medium",
              "label": "t:weight.heading.options.opt_2.label"
            },
            {
              "value": "--fw-normal",
              "label": "t:weight.heading.options.opt_3.label"
            },
            {
              "value": "--fw-light",
              "label": "t:weight.heading.options.opt_4.label"
            }
          ],
          "default": "--fw-medium"
        },
        {
          "type": "range",
          "id": "block_spacing",
          "label": "t:bottom_margin.label",
          "min": 0,
          "max": 50,
          "step": 1,
          "default": 4,
          "unit": "px"
        }
      ]
    },
    {
      "name": "t:product.blocks.variants_chart.name",
      "type": "variants_chart",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "variant_style",
          "label": "t:product.blocks.variants_chart.settings.style.label",
          "options": [
            {
              "value": "dropdown",
              "label": "t:product.blocks.variants_chart.settings.style.options.opt_1.label"
            },
            {
              "value": "pills",
              "label": "t:product.blocks.variants_chart.settings.style.options.opt_2.label"
            }
          ],
          "default": "pills"
        },
        {
          "type": "checkbox",
          "id": "show_size_chart",

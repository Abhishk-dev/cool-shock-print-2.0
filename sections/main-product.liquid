    --button-padding-y: 0.15rem;
    --button-padding-x: 0;
    --button-font-weight: 500;
    --button-text: var(--section-links-color);
    --button-hover-text: var(--section-active-hover-color);
  }

  .product-variant_row + .product-variant_row,
  .main-product_col--description,
  .main-product .product-common_slider-switcher {
    margin-top: 12px;
  }

  .product-pickup_text-wrap + .product-pickup_text-wrap,
  .product-pickup_wrapper + .product-pickup_wrapper,
  .product-pickup_cross-icn {
    margin-top: 4px;
  }

  .modal-component--pickup-drawer .modal-component_wrapper {
    max-width: 470px;
  }

  .modal-component--pickup-drawer .modal-component_body {
    min-height: 100%;
    padding: 24px;
  }

  .product-pickup_options-list,
  .product-pickup_subheading {
    margin-top: 5px;
  }

  .product-row_image {
    width: 110px;
  }

  .product-row_heading,
  .product-row_price {
    line-height: 1.2;
  }

  .product-row_btn.button--link {
    --button-padding-y: 0.05rem;
    --button-padding-x: 0;
    --button-text: var(--section-widget-links-color);
    --button-hover-text: var(--section-widget-active-hover-color);
  }

  .product-row_descr-wrap {
    padding: 18px;
  }

  .main-product .discount-amount {
    line-height: 1.8rem;
    background: var(--section-primary-bg);
    color: var(--section-primary-text-color);
    padding: 3px 9px;
  }

  .main-product .sale-price {
    line-height: 2.3rem;
  }

  .abc_row .collapsible-row_opener--icn-close svg {
    transform: rotate(180deg);
  }

  .main-product .product-common_widget-wrap {
    margin-bottom: 0;
  }

  .main-product .product-common_slider {
    border: 1px solid var(--section-border-color);
  }

  .main-product .product-common_widget-wrap {
    border: 1px solid var(--section-widget-border-color);
  }

  .main-product .product-common_widget-wrap + .product-common_widget-wrap {
    margin-top: -2px;
  }

  .main-product .--border-bottom {
    margin-bottom: -1px;
  }

  .product-common_widget-wrap.product-common_widget-wrap--two {
    padding: 0;
  }

  .main-product .product-common_unit-wrap,
  .main-product .product-common_sku-wrap,
  .main-product .product-common_stock-wrap {
    padding: 14px;
  }

  .quantity-input_label-subtotal {
    margin-bottom: 8px;
  }

  .--collapse-row[open] .collapsible-row_opener,
  .product-pickup_showcase-item.product-pickup_wrapper {
    border-bottom: none;
  }

  .--collapse-row .collapsible-row_slide-wrapper {
    padding: 11px 0px;
  }

  .--collapse-row .collapsible-row_opener,
  .abc_row .collapsible-row_opener {
    padding-bottom: 6px;
  }

  .--collapse-row .collapsible-row_opener {
    padding-top: 11px;
  }

  .icn-box_image svg {
    width: 48px;
    height: 48px;
  }

  .icn-box {
    gap: 22px;
  }

  .featured_list {
    column-gap: 37px;
    row-gap: 10px;
    padding-bottom: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--section-border-color);
  }

  .product-common_splide-list {
    width: 58%;
  }

  .product-common_splide-slide.is-active {
    pointer-events: auto;
  }

  .product-common_splide-slide {
    pointer-events: none;
  }

  .product-common_splide-slide + .product-common_splide-slide {
    border-left: 1px solid var(--section-border-color);
  }

  .main-product .product-common_slider {
    margin-right: -1px;
    margin-left: 1px;
  }

  .product-common_splide-slide + .product-common_splide-slide {
    margin-left: -1px;
  }

  .main-product .product-common_image--slider {
    border: none;
    margin-top: auto;
    margin-bottom: auto;
  }

  .main-product .product-common_image--switcher,
  .main-product .discount-amount {
    border-radius: 5px;
  }

  .main-product .product-common_image--switcher img,
  .main-product .product-common_image--switcher svg {
    border-radius: inherit;
  }

  .main-product .product-common_slider-switcher .splide__arrows {
    margin-top: 14px;
    justify-content: left;
  }

  .product-common_image--slider {
    --focus-outline-offset: -3px;
  }

  .product-common_image--slider:focus-visible svg,
  .product-common_image--slider:focus-visible img {
    padding: 5px;
  }

  .main-product .product-price_pricing {
    gap: 6px;
  }

  .main-product .recipient-fields {
    padding-top: 12px;
  }

  .stats-list_item--unit {
    margin-top: -1px;
  }

  .main-product .product-common-selected-value {
    margin-left: 6px;
    color: var(--section-widget-heading-color);
    text-transform: none;
  }

  .product-common_complementry-slider .splide__arrow--next,
  .product-common_complementry-slider .splide__arrow--prev {
    --button-padding-y: 0.6rem;
    --button-padding-x: 0.6rem;
    --button-corner-radius: 9px;
  }

  .main-product_booking-form .form-group--request-type,
  .main-product_booking-form .form-group--name {
    margin-bottom: 16px;
  }

  .main-product_booking-form .form-group--request-type {
    position: relative;
  }

  .main-product_booking-form .two-form-group {
    display: flex;
    gap: 16px;
    margin-bottom: 35px;
    flex-direction: column;
  }

  .main-product_booking-form.booking_sidebar .two-form-group {
    flex-direction: column;
    gap: 16px;
    margin-bottom: 16px;
  }

  .main-product_booking-form .form-group--phone,
  .main-product_booking-form .form-group--email {
    width: 100%;
  }

  .main-product_booking-form .form-group select {
    padding-right: 40px;
    appearance: none;
  }

  .main-product_booking-form .main-product_select-icon {
    line-height: 0;
    pointer-events: none;
    position: absolute;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1rem;
    height: 1rem;
    color: var(--section-foreground-color);
  }

  .--side-bar .main-product_booking-form .two-form-group {
    flex-direction: column;
  }

  .--side-bar .main-product_booking-form .form-group--phone {
    margin-bottom: 16px;
  }

  .product-common_services .form-control--textarea {
    height: 110px;
  }

  .main-product_full-slider .product-common_splide-list {
    width: 100%;
  }

  @media (min-width: 414px) {
    .quantity-input_label-subtotal {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 15px;
    }

    .quantity-input_subtotal-wrap {
      margin-left: auto;
    }
  }

  @media (min-width: 576px) {
    .dropdown-component_share-wrapper {
      width: 350px;
      right: 0;
    }
  }

  @media (min-width: 768px) {
    .contact-form {
      --q-align-value: var(--desktop-q-align);
    }

    .contact-form {
      overflow: visible;
    }

    .contact-form_wrapper {
      gap: 20px;
      margin-top: 50px;
    }

    .contact-form_col-form {
      width: 53%;
    }

    .contact-form--form-center .contact-form_col-form {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      max-width: 703px;
    }

    .locator-row--iframe iframe,
    .locator-row--iframe svg {
      height: 400px;
    }

    .dropdown-component_share-wrapper {
      width: 430px;
    }

    .main-product .product-common_unit-wrap,
    .main-product .product-common_sku-wrap,
    .main-product .product-common_stock-wrap {
      padding: 12px 22px;
    }

    .main-product .product-common_slider-switcher {
      max-width: 280px;
    }

    .main-product .deferred-media__poster-icn {
      width: 60px;
      height: 60px;
    }

    .main-product_booking-form .two-form-group {
      gap: 8px;
      flex-direction: row;
    }
  }

  @media (min-width: 992px) {
    .main-product_wrapper,
    .other-blocks_two-col {
      display: flex;
    }

    .other-blocks_two-col {
      gap: 31px;
    }

    .other-blocks_one--half {
      width: 60%;
    }

    .other-blocks_two-col .reviews-aside {
      flex-grow: 1;
      padding-top: 0;
      padding-bottom: 0;
      margin-top: -1px;
    }

    .main-product_col--media {
      width: calc(60%);
    }

    .main-product_col--description {
      width: calc(40%);
      margin-top: 0;
    }

    .main-product .product-price_pricing {
      gap: 12px;
    }
  }

  @media (min-width: 1200px) {
    .contact-form_wrapper {
      gap: 54px;
      margin-top: 72px;
    }

    .locator-row--iframe iframe,
    .locator-row--iframe svg {
      height: 686px;
    }

    .main-product_col--media {
      width: calc(70%);
    }

    .main-product_col--description {
      width: calc(30%);
    }
  }
{%- endstyle -%}

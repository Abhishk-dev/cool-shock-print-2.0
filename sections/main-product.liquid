<div class="container">
  {%- liquid
    if section.settings.show_breadcrumb
      render 'breadcrumb', color_scheme: section.settings.breadcrumb_color_scheme
    endif
  -%}
</div>
<div
  class="global-block product-common {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }} {{ section_scheme_class }}"
  style="--section-padding-top: {{ section.settings.section_top_padding }}px; --section-padding-bottom: {{ section.settings.section_bottom_padding }}px;"
>
  <div class="container" id="{{- section.id -}}-description">
    <div class="{{ section_prefix_class }}_wrapper">
      {%- if enable_row_reviews == 'true' or product.media.size > 0 -%}
        <div class="{{ section_prefix_class }}_col {{ section_prefix_class }}_col--media">
          <div class="product-common_sticky-wrap">
            <div class="product-common_media-slider {% if section.settings.product_gallery_view %}{{ section_prefix_class }}_full-slider{% endif %}">
              {%- liquid
                render 'product-gallery-thumbnails', product: product, show_navigation: section.settings.section_show_navigation, variant_media_attr: media_slider_attr, media_size: section.settings.product_media_size, fetchpriority: true, autoplay: section.settings.section_auto_play
              -%}
            </div>
          </div>
        </div>
      {%- endif -%}
      <div class="{{ section_prefix_class }}_col {{ section_prefix_class }}_col--description">
        <div class="product-common_sticky-wrap">
          <div class="widget--styles product-common_widget-wrap product-common_widget-wrap--one">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'title' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    <h1 class="mty {{ section_prefix_class }}_title product-common_title {{ block.settings.block_heading_size }} {{ block.settings.block_heading_weight }}">
                      {{- product.title -}}
                    </h1>
                  </div>
                {%- when 'price' -%}
                  <div
                    class="product-common_row product-common_row--{{ block.type }}"
                    style="--block-spacing: {{ block.settings.block_spacing }}px;"
                    {{ block.shopify_attributes }}
                  >
                    <strong
                      class="product-common_price-wrap {{ block.settings.block_text_size }} {{ block.settings.block_text_weight }}"
                      {{ price_render_attr }}
                    >
                      {%- render 'product-price',
                        product: product,
                        use_variant: true,
                        show_unit_price: false,
                        show_discount: true
                      -%}
                    </strong>
                    {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
                      <strong class="product-common_taxes-text text-size--small --fw-normal">
                        {%- liquid
                          if cart.taxes_included
                            echo 'product.include_taxes' | t
                          endif
                          if shop.shipping_policy.body != blank
                            echo 'product.shipping_policy_html' | t: link: shop.shipping_policy.url
                          endif
                        -%}
                      </strong>
                    {%- endif -%}
                  </div>
                {%- when 'text' -%}
                  {%- if block.settings.show_on_sidebar -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <div class="product-common_description-wrap h {{ block.settings.block_text_size }} {{ block.settings.block_text_weight }} mty">
                        <div class="description-text">
                          {{- block.settings.block_description -}}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
                  {%- when 'pdp_downloads' -%}
                  {%- if block.settings.show_on_sidebar -%}
                    {%- capture pdp_downloads_capture_top -%}
                      {%- render 'product-pdp-downloads', product: product, block: block -%}
                    {%- endcapture -%}
                    {%- if pdp_downloads_capture_top != blank -%}
                      <div
                        class="product-common_row product-common_row--{{ block.type }}"
                        style="--block-spacing: {{ block.settings.block_spacing }}px;"
                        {{ block.shopify_attributes }}
                      >
                        {{- pdp_downloads_capture_top -}}
                      </div>
                    {%- endif -%}
                  {%- endif -%}
                {%- when 'additional_information' -%}
                  {%- if block.settings.show_on_sidebar -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      {%- render 'product-additional-information',
                        block: block,
                        form_id: form_id,
                        buttons_exist: buttons_exist,
                        section: section
                      -%}
                    </div>
                  {%- endif -%}
                {%- when 'services' -%}
                  {%- if block.settings.show_on_sidebar -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <div class="product-common_services">
                        <div class="{{ section_prefix_class }}_booking-form {% if block.settings.show_on_sidebar %}booking_sidebar{% endif %}">
                          {%- if block.settings.form_heading != blank -%}
                            <h3 class="{{ section_prefix_class }}_booking-form-heading {{ block.settings.form_heading_size }} {{ block.settings.form_heading_weight }}">
                              {{ block.settings.form_heading }}
                            </h3>
                          {%- endif -%}
                          {%- if block.settings.form_description != blank -%}
                            <div class="{{ section_prefix_class }}_booking-form-description {{ block.settings.form_description_size }} {{ block.settings.form_description_weight }}">
                              {{ block.settings.form_description }}
                            </div>
                          {%- endif -%}
                          {%- assign form_id = 'ContactForm' | append: block.id -%}
                          {%- form 'contact', id: form_id, class: 'isolate' -%}
                            {%- if form.errors != blank -%}
                              <strong class="form__message --fw-normal mty" role="alert" tabindex="-1" autofocus>
                                {%- render 'icons-data',
                                  width: 22,
                                  height: 22,
                                  use_icon: true,
                                  icon_reference: 'error'
                                -%}
                                {{- 'erorr.common_heading' | t -}}
                              </strong>
                              <ul class="errors-list list-unstyled">
                                <li class="errors-list_item">
                                  <smooth-anchor data-offset=".sticky-header-wrapper">
                                    <a
                                      class="errors-list_link text-size--small"
                                      href="#ContactForm-email-{{ form_id }}"
                                    >
                                      *
                                      {{- form.errors.translated_fields.email | capitalize }}
                                      {{ form.errors.messages.email -}}
                                    </a>
                                  </smooth-anchor>
                                </li>
                              </ul>
                            {%- endif -%}
                            <div class="form-group form-group--name">
                              <label
                                class="text-size--small --fw-medium visually-hidden"
                                for="contact-name-{{ form_id }}"
                              >
                                {{- 'contact_form.form_label.name.label' | t -}}
                              </label>
                              <input
                                type="text"
                                id="contact-name-{{ form_id }}"
                                name="contact[Name]"
                                placeholder="{{- 'contact_form.form_placeholder.name.label' | t -}}"
                              >
                            </div>
                            {%- if block.settings.form_request_type_label != blank -%}
                              {%- if block.settings.option_1 != blank
                                or block.settings.option_2 != blank
                                or block.settings.option_3 != blank
                                or block.settings.option_4 != blank
                              -%}
                                <div class="form-group form-group--request-type">
                                  <label
                                    class="text-size--small --fw-medium visually-hidden"
                                    for="contact-request-type-{{ form_id }}"
                                  >
                                    {{- block.settings.form_request_type_label -}}
                                  </label>
                                  <div class="form-group_select-wrap">
                                    <select id="contact-request-type-{{ form_id }}" name="contact[request_type]">
                                      <option value="" disabled selected hidden>
                                        {{- block.settings.form_request_type_label -}}
                                      </option>
                                      {%- if block.settings.option_1 != blank -%}
                                        <option value="{{ block.settings.option_1 }}">
                                          {{- block.settings.option_1 -}}
                                        </option>
                                      {%- endif -%}
                                      {%- if block.settings.option_2 != blank -%}
                                        <option value="{{ block.settings.option_2 }}">
                                          {{- block.settings.option_2 -}}
                                        </option>
                                      {%- endif -%}
                                      {%- if block.settings.option_3 != blank -%}
                                        <option value="{{ block.settings.option_3 }}">
                                          {{- block.settings.option_3 -}}
                                        </option>
                                      {%- endif -%}
                                      {%- if block.settings.option_4 != blank -%}
                                        <option value="{{ block.settings.option_4 }}">
                                          {{- block.settings.option_4 -}}
                                        </option>
                                      {%- endif -%}
                                    </select>
                                    <div class="{{ section_prefix_class }}_select-icon">
                                      {%- render 'icons-data',
                                        width: 10,
                                        height: 10,
                                        use_icon: true,
                                        icon_reference: 'chevron-down'
                                      -%}
                                    </div>
                                  </div>
                                </div>
                              {%- endif -%}
                            {%- endif -%}
                            <div class="two-form-group">
                              <div class="form-group form-group--phone">
                                <label
                                  class="text-size--small --fw-medium visually-hidden"
                                  for="contact-phone-{{ form_id }}"
                                >
                                  {{- 'contact_form.form_label.phone.label' | t -}}
                                </label>
                                <input
                                  type="tel"
                                  id="contact-phone-{{ form_id }}"
                                  name="contact[phone]"
                                  placeholder="{{- 'contact_form.form_placeholder.phone.label' | t -}}"
                                  onkeydown="validation()"
                                >
                              </div>
                              <div class="form-group form-group--email">
                                <label
                                  class="text-size--small --fw-medium visually-hidden"
                                  for="ContactForm-email-{{ form_id }}"
                                >
                                  {{- 'contact_form.form_label.email.label' | t -}}
                                </label>
                                <input
                                  type="email"
                                  id="ContactForm-email-{{ form_id }}"
                                  name="contact[email]"
                                  placeholder="{{ 'contact_form.form_placeholder.email.label' | t }}"
                                  onkeydown="validation()"
                                >
                                <div class="newsletter-form_results-wrap results-wrap_message text-size--small">
                                  {%- if form.errors contains 'email' -%}
                                    <div class="error-email">
                                      {%- render 'icons-data',
                                        width: 22,
                                        height: 22,
                                        use_icon: true,
                                        icon_reference: 'error'
                                      -%}
                                      <small class="contact__field-error" id="ContactForm-email-{{ form_id }}-error">
                                        {{- form.errors.translated_fields.email | capitalize }}
                                        {{ form.errors.messages.email -}}
                                      </small>
                                    </div>
                                  {%- endif -%}
                                </div>
                              </div>
                            </div>
                            <div class="form-group form-group--message">
                              {%- liquid
                                assign max_chars_message = 200
                                assign max_chars_message_rendered = 'recipient.form.max_characters' | t: max_chars: max_chars_message
                                assign message_label_rendered = 'recipient.form.message_label' | t
                              -%}
                              <label
                                for="ContactForm-message-{{ form_id }}"
                                class="form-label visually-hidden"
                              >
                                {{ 'recipient.form.message' | t }}
                              </label>
                              <textarea
                                rows="10"
                                id="ContactForm-message-{{ form_id }}"
                                class="form-control form-control--textarea"
                                name="properties[Message]"
                                maxlength="{{ max_chars_message }}"
                                placeholder="{{ 'recipient.form.message' | t }}"
                                aria-label="{{ message_label_rendered }} {{ max_chars_message_rendered }}"
                                title="{{ message_label_rendered }}"
                                {% if form.errors contains 'message' %}
                                  aria-invalid="true"
                                  aria-describedby="ContactForm-message-error-{{ form_id }}"
                                {% endif %}
                              >{{ form.message }}</textarea>
                            </div>
                            <span class="service-form-field-label text-size--small">
                              <span>{{ max_chars_message_rendered }}</span>
                            </span>
                            <div
                              id="ContactForm-message-error-{{ form_id }}"
                              class="form__message text-size--small {% unless form.errors contains 'message' %}hidden{% endunless %}"
                            >
                              {%- render 'icons-data',
                                width: 20,
                                height: 20,
                                use_icon: true,
                                icon_reference: 'error'
                              -%}
                              <span class="error-message">
                                {%- if form.errors contains 'message' -%}
                                  {{ form.errors.messages.message }}.
                                {%- endif -%}
                              </span>
                            </div>
                            <div class="form-wrapper_btn-wrap">
                              <div class="form-wrapper_btn-wrap-btn {% unless section.settings.form_label != blank %}btn--no-label{% endunless %}">
                                <button class="button button--secondary form-wrapper_button" type="submit">
                                  {{- 'contact_form.submit_label' | t -}}
                                </button>
                              </div>
                            </div>
                            {%- if form.posted_successfully? -%}
                              <div class="success-message" role="alert" tabindex="-1" autofocus>
                                <i class="success-message_icn">
                                  {%- render 'icons-data',
                                    width: 54,
                                    height: 54,
                                    use_icon: true,
                                    icon_reference: 'smile'
                                  -%}
                                </i>
                                <p>{{- 'contact_form.success.heading1' | t -}}</p>
                                <p>{{- 'contact_form.success.heading2' | t -}}</p>
                              </div>
                            {%- endif -%}
                          {%- endform -%}
                        </div>
                      </div>
                    </div>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
          <div class="widget--styles product-common_widget-wrap product-common_widget-wrap--two">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'statistics' -%}
                  {%- if block.settings.show_sku or block.settings.show_stock or block.settings.show_unitprice -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <ul class="list-unstyled stats-list">
                        {%- if block.settings.show_unitprice -%}
                          <li class="stats-list_item parent-node stats-list_item--unit">
                            <span {{ price_unit_render_attr }}>
                              {%- unless product.selected_or_first_available_variant.unit_price_measurement == null -%}
                                <span class="product-price_unit-pricing product-common_unit-wrap product-common_stat-wrap --v-align-middle text-size--small">
                                  <span class="product-stock_label product-common_stat-label h {{ block.settings.block_text_weight }}">
                                    {{ 'product.unitPrice' | t }}:
                                  </span>
                                  <span class="unit-price">
                                    <span>
                                      {{- product.selected_or_first_available_variant.unit_price | money -}}
                                    </span>
                                    <span aria-hidden="true">/</span>
                                    <span class="visually-hidden"
                                      >&nbsp;
                                      {{- 'product.unit_price_separator' | t -}}
                                      &nbsp;</span
                                    >
                                    <span>
                                      {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value
                                          != 1
                                      -%}
                                        {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
                                      {%- endif -%}
                                      {{- product.selected_or_first_available_variant.unit_price_measurement.reference_unit -}}
                                    </span>
                                  </span>
                                </span>
                              {%- endunless -%}
                            </span>
                          </li>
                        {%- endif -%}
                        {%- if block.settings.show_sku -%}
                          <li class="stats-list_item parent-node">
                            <strong
                              class="product-common_sku-wrap product-common_stat-wrap --v-align-middle text-size--small"
                              {{ sku_render_attr }}
                            >
                              {%- render 'product-sku',
                                product: product,
                                show_label: true,
                                text_weight: block.settings.block_text_weight
                              -%}
                            </strong>
                          </li>
                        {%- endif -%}
                        {%- if block.settings.show_stock -%}
                          <li class="stats-list_item parent-node">
                            <strong
                              class="product-common_stock-wrap product-common_stat-wrap --v-align-middle text-size--small"
                              {{ stock_render_attr }}
                            >
                              {%- render 'product-stock',
                                product: product,
                                show_label: true,
                                text_weight: block.settings.block_text_weight
                              -%}
                            </strong>
                          </li>
                        {%- endif -%}
                      </ul>
                    </div>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
          {%- if collapse_exist == 'true' -%}
            <div class="widget--styles product-common_widget-wrap product-common_widget-wrap--three">
              {%- for block in section.blocks -%}
                {%- if block.settings.show_on_sidebar -%}
                  {%- case block.type -%}
                    {%- when 'collapsible_row' -%}
                      <div
                        class="product-common_row product-common_row--{{ block.type }}"
                        style="--block-spacing: {{ block.settings.block_spacing }}px;"
                        {{ block.shopify_attributes }}
                      >
                        {%- render 'abc-row',
                          block: block,
                          prefix_class: section_prefix_class,
                          heading_size: block.settings.block_heading_size,
                          heading_weight: block.settings.block_heading_weight,
                          description_size: block.settings.block_description_size,
                          description_weight: block.settings.block_description_weight,
                          section_id: section.id
                        -%}
                      </div>
                  {%- endcase -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
          {%- if variants_chart_exist == 'true'
            or quantity_input_exist == 'true'
            or stock_bar_exist == 'true'
            or buttons_exist == 'true'
            or additional_information_exist == 'true'
            or payment_icons_exist == 'true'
            or action_buttons_exist == 'true'
            or app_exist == 'true'
          -%}
            <div class="widget--styles product-common_widget-wrap product-common_widget-wrap--four">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'variants_chart' -%}
                    {%- unless product.has_only_default_variant -%}
                      {%- liquid
                        assign product_option_count = product.options_with_values | size
                        assign use_custom_cascade = false
                        if product_option_count == 2
                          unless block.settings.force_standard_variant_picker
                            assign use_custom_cascade = true
                          endunless
                        endif
                      -%}
                      {%- if use_custom_cascade -%}
                        <div
                          class="product-common_row product-common_row--{{ block.type }}"
                          style="--block-spacing: {{ block.settings.block_spacing }}px;"
                          {{ block.shopify_attributes }}
                        >
                          {%- render 'product-custom-cascade-variants',
                            product: product,
                            section: section,
                            product_json_id: product_json_id,
                            form_id: form_id,
                            product_form_installment_id: product_form_installment_id,
                            stock_render_attr: stock_render_attr,
                            price_render_attr: price_render_attr,
                            sku_render_attr: sku_render_attr,
                            price_unit_render_attr: price_unit_render_attr,
                            share_render_attr: share_render_attr,
                            qty_render_attr: qty_render_attr,
                            pickup_render_attr: pickup_render_attr,
                            stockbar_render_attr: stockbar_render_attr,
                            media_slider_attr: media_slider_attr,
                            media_static_attr: media_static_attr,
                            error_render_attr: error_render_attr
                          -%}
                        </div>
                        <div
                          class="product-common_row product-common_row--dimension-fields"
                          style="--block-spacing: {{ block.settings.block_spacing }}px;"
                        >
                          {%- render 'product-dimension-fields',
                            section: section,
                            form_id: form_id,
                            price_render_attr: price_render_attr,
                            qty_render_attr: qty_render_attr
                          -%}
                        </div>
                      {%- else -%}
                      <div
                        class="product-common_row product-common_row--{{ block.type }}"
                        style="--block-spacing: {{ block.settings.block_spacing }}px;"
                        {{ block.shopify_attributes }}
                      >
                        <div id="{{ section.id }}-variants-container">
                          {%- for option in product.options_with_values -%}
                            {%- liquid
                              unless settings.variant_swatches == 'none'
                                capture has_color_variant
                                  for value in option.values
                                    if settings.variant_swatches == 'swatches'
                                      if value.swatch.image
                                        echo 'true'
                                        break
                                      elsif value.swatch.color
                                        echo 'true'
                                        break
                                      endif
                                    else
                                      if option.name == 'color' or option.name == 'Color' or option.name == 'colour' or option.name == 'Colour' or option.name == 'Couleur'
                                        echo 'true'
                                        break
                                      endif
                                    endif
                                  endfor
                                endcapture
                              endunless

                              capture is_size_option
                                if option.name == 'Size' or option.name == 'size' or option.name == 'Taille' or option.name == 'Tamaño'
                                  echo 'true'
                                else
                                  echo 'false'
                                endif
                              endcapture
                            -%}
                            <fieldset class="product-variant_row {% unless block.settings.variant_style == 'dropdown' %}{% if has_color_variant == 'true' %}product-variant_fieldset{% endif %}{% endunless %}">
                              <div class="product-variant_title-wrap --v-align-middle">
                                <strong class="product-common_variant-title text-size--medium --fw-bold h">
                                  {{- option.name | append: ':' -}}
                                </strong>
                                <span
                                  class="product-common-selected-value text-size--medium --fw-normal"
                                  {{
                                    'data-selected-parent'
                                    | append: forloop.index
                                    | append: '-'
                                    | append: section.id
                                  }}
                                >
                                  {{- option.selected_value -}}
                                </span>
                                {%- if is_size_option == 'true' and block.settings.show_size_chart -%}
                                  <modal-component-toggler class="product-variant_title-elem">
                                    <button
                                      type="button"
                                      data-expanded="false"
                                      data-modal-ref="modal-size-chart-{{ section.id }}"
                                      aria-haspopup="dialog"
                                      aria-controls="modal-size-chart-{{ section.id }}"
                                      class="button button--link product-common_chart-link"
                                    >
                                      {{- 'product.size_chart.toggler_label' | t -}}
                                    </button>
                                  </modal-component-toggler>
                                  <modal-component
                                    data-modal="modal-size-chart-{{ section.id }}"
                                    data-container="body"
                                  >
                                    <div
                                      class="modal modal-component modal-component--size-chart modal-component--centered scheme--{{ section.settings.section_color_scheme }}"
                                      role="dialog"
                                      aria-modal="true"
                                      aria-labelledby="modal-size-chart-{{ section.id }}-heading"
                                      aria-describedby="modal-size-chart-{{ section.id }}"
                                      tabindex="-1"
                                    >
                                      <div class="modal-component_spacer">
                                        <div class="modal-component_wrapper" id="modal-size-chart-{{ section.id }}">
                                          <div class="modal-component_body">
                                            <div class="modal-component_head --align-left product-common_size-heading">
                                              <modal-component-toggler>
                                                <button
                                                  type="button"
                                                  data-expanded="true"
                                                  data-toggle-attribute="false"
                                                  data-modal-ref="modal-size-chart-{{ section.id }}"
                                                  class="modal-component_btn-close button button--icn"
                                                >
                                                  <span class="button_icn-wrapper">
                                                    {%- render 'icons-data',
                                                      width: 14,
                                                      height: 14,
                                                      use_icon: true,
                                                      icon_reference: 'cross'
                                                    -%}
                                                    <span class="visually-hidden">
                                                      {{- 'accessibility.close' | t -}}
                                                    </span>
                                                  </span>
                                                </button>
                                              </modal-component-toggler>
                                              <strong
                                                id="modal-size-chart-{{ section.id }}-heading"
                                                class="modal-component_heading h4 mty"
                                              >
                                                {{- 'product.size_chart.heading' | t -}}
                                              </strong>
                                            </div>
                                            <div class="modal-component_content">
                                              <div
                                                class="main-product_chart-wrap --media-size-adapt"
                                                style="--media-ratio: {{ block.settings.size_chart_image.aspect_ratio | default: '1' }};"
                                              >
                                                {%- if block.settings.size_chart_image != blank -%}
                                                  {%- liquid
                                                    capture image_alt
                                                      echo 'product.size_chart.alt_label' | t: product_title: product.title
                                                    endcapture

                                                    assign image_height = block.settings.size_chart_image.width | divided_by: block.settings.size_chart_image.aspect_ratio | round
                                                  -%}
                                                  {{-
                                                    block.settings.size_chart_image
                                                    | image_url: width: 568
                                                    | image_tag:
                                                      width: block.settings.size_chart_image.width,
                                                      height: image_height,
                                                      class: 'object-fit object-fit--absolute',
                                                      loading: 'lazy',
                                                      alt: image_alt,
                                                      widths: '300, 568',
                                                      sizes: '(max-width: 767px) calc(100vw - 82px), 33vw'
                                                  -}}
                                                {%- else -%}
                                                  {%- render 'placeholder-svgs',
                                                    type: 'hero',
                                                    index: 1,
                                                    class: 'object-fit object-fit--absolute'
                                                  -%}
                                                {%- endif -%}
                                              </div>
                                            </div>
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                  </modal-component>
                                {%- endif -%}
                              </div>
                              {%- unless block.settings.variant_style == 'dropdown' -%}
                                <variant-pill
                                  class="product-variant_options-wrap product-common_product-variant_options-wrap --v-align-middle"
                                  data-json-selector="#{{- product_json_id -}}"
                                  data-forms='["#{{ product_form_installment_id }}", "#{{ form_id }}"]'
                                  data-error-selector="[{{ error_render_attr }}]"
                                  data-renders='["[{{ stock_render_attr }}]", "[{{ price_render_attr }}]", "[{{ price_unit_render_attr }}]", "[{{ sku_render_attr }}]", "[{{ share_render_attr }}]", "[{{ qty_render_attr }}]", "[{{ pickup_render_attr }}]", "[{{ stockbar_render_attr }}]"]'
                                  data-section-id="{{- section.id -}}"
                                  data-product-url="{{- product.url -}}"
                                  data-update-url="true"
                                  data-current-set='{{- current_values | json | escape -}}'
                                  data-option-index="{{- forloop.index | minus: 1 -}}"
                                  data-parent="#{{- section.id -}}-variants-container"
                                  data-main-parent="#{{- section.id -}}-description"
                                  data-galleries='["[{{ media_slider_attr }}]", "[{{ media_static_attr }}]"]'
                                  data-selected-parent="[{{ 'data-selected-parent' | append: forloop.index | append: '-' | append: section.id }}]"
                                >
                                  {%- render 'product-variant-options',
                                    product: product,
                                    option: option,
                                    product_form_id: form_id,
                                    swatches: settings.variant_swatches,
                                    is_color_option: has_color_variant
                                  -%}
                                </variant-pill>
                              {%- else -%}
                                <div class="dropdown-component dropdown-component--variant">
                                  <strong
                                    id="{{ option.position }}-variant-heading"
                                    class="visually-hidden"
                                    role="heading"
                                    aria-level="2"
                                  >
                                    {{- option.name -}}
                                  </strong>
                                  <variant-dropdown
                                    data-json-selector="#{{- product_json_id -}}"
                                    data-forms='["#{{ product_form_installment_id }}", "#{{ form_id }}"]'
                                    data-error-selector="[{{ error_render_attr }}]"
                                    data-renders='["[{{ stock_render_attr }}]", "[{{ price_render_attr }}]", "[{{ sku_render_attr }}]", "[{{ price_unit_render_attr }}]", "[{{ share_render_attr }}]", "[{{ qty_render_attr }}]", "[{{ pickup_render_attr }}]", "[{{ stockbar_render_attr }}]"]'
                                    data-section-id="{{- section.id -}}"
                                    data-product-url="{{- product.url -}}"
                                    data-update-url="true"
                                    data-current-set='{{- current_values | json | escape -}}'
                                    data-option-index="{{- forloop.index | minus: 1 -}}"
                                    data-parent="#{{- section.id -}}-variants-container"
                                    data-main-parent="#{{- section.id -}}-description"
                                    data-galleries='["[{{ media_slider_attr }}]", "[{{ media_static_attr }}]"]'
                                  >
                                    <button
                                      type="button"
                                      class="dropdown-component_opener dropdown-variant_opener --align-left --word-break"
                                      aria-expanded="false"
                                      aria-controls="{{ option.position }}-variant-dropdown"
                                      aria-describedby="{{ option.position }}-variant-heading"
                                    >
                                      {%- liquid
                                        capture value
                                          for value in option.values
                                            if option.selected_value == value
                                              echo value
                                              break
                                            endif
                                          endfor
                                        endcapture
                                      -%}
                                      <span data-current-value="">
                                        {{- value -}}
                                      </span>
                                      <i class="dropdown-componenet_icn-caret">
                                        {%- render 'icons-data',
                                          width: 9,
                                          height: 5,
                                          use_icon: true,
                                          icon_reference: 'chevron-down',
                                          section_id: section.id
                                        -%}
                                      </i>
                                    </button>
                                    <div class="dropdown-component_wrapper dropdown-variant_wrapper">
                                      <ul
                                        id="{{ option.position }}-variant-dropdown"
                                        class="list-unstyled dropdown-variant_items --align-left"
                                      >
                                        {%- render 'product-variant-selects',
                                          product: product,
                                          option: option,
                                          product_form_id: form_id,
                                          swatches: settings.variant_swatches,
                                          is_color_option: has_color_variant
                                        -%}
                                      </ul>
                                    </div>
                                  </variant-dropdown>
                                </div>
                              {%- endunless -%}
                            </fieldset>
                          {%- endfor -%}
                        </div>
                      </div>
                      {%- endif -%}
                    {%- endunless -%}
                  {%- when 'quantity_input' -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <div
                        class="product-common_qty-wrap {% unless block.settings.show_subtotal %}--hide-subtotal{% endunless %}"
                        {{ qty_render_attr }}
                      >
                        {%- liquid
                          assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
                          assign uses_comma_decimals = false
                          if currencies_using_comma_decimals contains cart.currency.iso_code
                            assign uses_comma_decimals = true
                          endif
                        -%}
                        <quantity-input
                          class="quantity-input product-common_quantity-input --v-align-middle"
                          data-init-value="{{- product.selected_or_first_available_variant.quantity_rule.min -}}"
                          {% unless uses_comma_decimals %}
                            data-variant-price="{{- product.selected_or_first_available_variant.price | money_without_currency | replace: ',', '' | times: 100 -}}"
                          {% else %}
                            data-variant-price="{{- product.selected_or_first_available_variant.price | money_without_currency | replace: '.', '' | replace: ',', '.' | times: 100 -}}"
                          {% endunless %}
                        >
                          <div class="quantity-input_label-subtotal">
                            <label
                              for="quantity-{{- form_id -}}"
                              class="product-common_variant-title text-size--medium --fw-bold h"
                            >
                              {{- 'quantity.quantity' | t -}}
                            </label>
                            <strong class="quantity-input_subtotal-wrap --word-break --fw-normal">
                              <span class="quantit-input_subtotal-title">
                                {{- 'quantity.subtotal' | t -}}
                                :
                              </span>
                              <span class="quantity-input_subtotal-price" data-qty-subtotal="">
                                {{- product.selected_or_first_available_variant.price | money -}}
                              </span>
                            </strong>
                          </div>
                          <div class="quantity-input_fielder-wrap">
                            <button
                              class="quantity-input_button button button--icn quantity-input_button-minus disabled"
                              disabled
                              name="minus"
                              type="button"
                            >
                              <span class="button_icn-wrapper">
                                {%- render 'icons-data',
                                  width: 8,
                                  height: 8,
                                  use_icon: true,
                                  icon_reference: 'minus',
                                  section_id: section.id
                                -%}
                                <span class="visually-hidden">
                                  {{- 'quantity.decrease' | t: product: product_title -}}
                                </span>
                              </span>
                            </button>
                            <input
                              type="number"
                              name="quantity"
                              placeholder="1"
                              data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                              min="{{- product.selected_or_first_available_variant.quantity_rule.min -}}"
                              {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                                data-max="{{- product.selected_or_first_available_variant.quantity_rule.max -}}"
                                max="{{- product.selected_or_first_available_variant.quantity_rule.max -}}"
                              {% endif %}
                              step="{{- product.selected_or_first_available_variant.quantity_rule.increment -}}"
                              value="{{- product.selected_or_first_available_variant.quantity_rule.min -}}"
                              aria-label="{{- 'quantity.input_label' | t: product: product_title -}}"
                              form="{{- form_id -}}"
                              id="quantity-{{- form_id -}}"
                              title="{{- 'quantity.input_label' | t: product: product_title -}}"
                            >
                            <button
                              class="quantity-input_button button button--icn quantity-input_button-plus"
                              name="plus"
                              type="button"
                            >
                              <span class="button_icn-wrapper">
                                {%- render 'icons-data',
                                  width: 8,
                                  height: 8,
                                  use_icon: true,
                                  icon_reference: 'plus',
                                  section_id: section.id
                                -%}
                                <span class="visually-hidden" style="background-color: white; color: black;">
                                  {{- 'quantity.increase' | t: product: product_title -}}
                                </span>
                              </span>
                            </button>
                          </div>
                        </quantity-input>
                      </div>
                      <strong
                        class="product-common_error --v-align-middle --fw-normal --text-error text-size--small hidden"
                        role="alert"
                        tabindex="-1"
                        {{ error_render_attr }}
                      >
                        {%- render 'icons-data', width: 22, height: 22, use_icon: true, icon_reference: 'error' -%}
                        <span data-error=""></span>
                      </strong>
                    </div>
                  {%- when 'additional_information' -%}
                    {%- unless block.settings.show_on_sidebar -%}
                      <div
                        class="product-common_row product-common_row--{{ block.type }}"
                        style="--block-spacing: {{ block.settings.block_spacing }}px;"
                        {{ block.shopify_attributes }}
                      >
                        {%- render 'product-additional-information',
                          block: block,
                          form_id: form_id,
                          buttons_exist: buttons_exist,
                          section: section
                        -%}
                      </div>
                    {%- endunless -%}
                  {%- when 'stock_bar' -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <div
                        class="{{ block.settings.block_text_size }} {{ block.settings.block_text_weight }}"
                        {{ stockbar_render_attr }}
                      >
                        {%- render 'product-stock-bar', product: product -%}
                      </div>
                    </div>
                  {%- when 'buttons' -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      {%- form 'product',
                        product,
                        data-productid: product.id,
                        id: product_form_installment_id,
                        class: 'product-atc-installment-form'
                      -%}
                        <input
                          type="hidden"
                          name="id"
                          data-productid="{{- product.id -}}"
                          value="{{- product.selected_or_first_available_variant.id -}}"
                        >
                        {{- form | payment_terms -}}
                      {%- endform -%}
                      {%- form 'product',
                        product,
                        id: form_id,
                        class: 'main-product_submit-from',
                        novalidate: 'novalidate',
                        data-type: 'add-to-cart-form'
                      -%}
                        {%- liquid
                          assign gift_card_recipient_feature_active = false
                          if block.settings.show_gift_card_recipient and product.gift_card?
                            assign gift_card_recipient_feature_active = true
                          endif

                          assign show_dynamic_checkout = false
                          if block.settings.show_dynamic_checkouts and gift_card_recipient_feature_active == false
                            assign show_dynamic_checkout = true
                          endif

                          if gift_card_recipient_feature_active
                            render 'gift-card-recipient-form', product: product, form: form, section: section, error_render_attr: error_render_attr
                          endif

                          assign check_against_inventory = true
                          if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
                            assign check_against_inventory = false
                          endif
                          if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
                            assign quantity_rule_soldout = true
                          endif

                          capture atc_button_label
                            if product.selected_or_first_available_variant.available == false or quantity_rule_soldout
                              echo 'product.atc_buttons.soldout' | t
                            else
                              echo 'product.atc_buttons.add_to_cart' | t
                            endif
                          endcapture
                        -%}
                        <input
                          type="hidden"
                          name="id"
                          value="{{- product.selected_or_first_available_variant.id -}}"
                        >
                        {%- unless quantity_input_exist == 'true' -%}
                          <input
                            type="hidden"
                            name="quantity"
                            data-min="1"
                            value="1"
                          >
                        {%- endunless -%}
                        {%- render 'product-artwork-upload', form_id: form_id -%}
                        <div class="product-common_btns-wrap">
                          <div class="product-common_form-btns --v-align-start">
                            <atc-submit
                              class="product-common_atc-form"
                              data-error-selector="[{{ error_render_attr }}]"
                              data-form="#{{ form_id }}"
                              {% unless template.name == 'cart' %}
                                {% unless settings.cart_view == 'drawer' %}
                                  data-redirect="{{- routes.cart_url -}}"
                                {% endunless %}
                              {% endunless %}
                              {% unless template.name == 'cart' %}
                                data-modal="true"
                                data-modal-ref='[data-modal-ref="modal-cart-drawer"][data-expanded="false"]'
                              {% endunless %}
                              data-sections='
                                [
                                  {
                                    "id": "cart-head",
                                    "selectors": ["[data-render-cart-bubble]", "[data-render-cart-text]", "[data-render-cart-bubble-aside]", "[data-render-cart-text-aside]"]
                                  },
                                  {
                                    "id": "cart-showcase",
                                    "selectors": ["[data-line-items-drawer-container]"]
                                  }
                                ]
                              '
                            >
                              <button
                                type="submit"
                                name="add"
                                class="button button--primary {{ section_prefix_class }}_atc-btn product-common_atc-btn button--animate"
                                {% if product.selected_or_first_available_variant.available == false
                                  or quantity_rule_soldout
                                %}
                                  disabled
                                {% endif %}
                              >
                                <span
                                  data-atc-text=""
                                  data-text-avail="{{- 'product.atc_buttons.add_to_cart' | t -}}"
                                  data-text-sold="{{- 'product.atc_buttons.soldout' | t -}}"
                                  data-text-unavail="{{- 'product.atc_buttons.unavailable' | t -}}"
                                >
                                  {{- atc_button_label -}}
                                </span>
                              </button>
                            </atc-submit>
                            {%- if block.settings.show_whatsapp and block.settings.whatsapp_number != blank -%}
                              {% liquid
                                capture wasapp_message
                                  assign url_origin = product.selected_or_first_available_variant.url | prepend: request.origin
                                  if block.settings.custom_message != blank
                                    assign remove_spaces = block.settings.custom_message | replace: ' ', '&nbsp;'
                                    echo remove_spaces | replace: '||product_url||', url_origin
                                  else
                                    echo product.selected_or_first_available_variant.url
                                  endif
                                endcapture
                              %}
                              <a
                                href="https://wa.me/{{ block.settings.whatsapp_number }}?text={{ wasapp_message }}"
                                target="_blank"
                                class="button button--icn product-common_btn-whatsapp button--animate"
                                data-tooltip="{{- 'product.whatsapp_label' | t -}}"
                              >
                                <span class="button_icn-wrapper">
                                  {%- render 'icons-data',
                                    width: 30,
                                    height: 30,
                                    use_icon: true,
                                    icon_reference: 'whatsapp',
                                    section_id: section.id
                                  -%}
                                  <span class="whatsapp-text">
                                    {{- 'product.whatsapp_label' | t -}}
                                  </span>
                                </span>
                              </a>
                            {%- endif -%}
                          </div>
                          {%- if show_dynamic_checkout -%}
                            <div class="product-common_dynamic-btns">
                              {{- form | payment_button -}}
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endform -%}
                      {%- unless quantity_input_exist == true -%}
                        <strong
                          class="product-common_error --v-align-middle --fw-normal --text-error text-size--small hidden"
                          role="alert"
                          tabindex="-1"
                          {{ error_render_attr }}
                        >
                          {%- render 'icons-data', width: 22, height: 22, use_icon: true, icon_reference: 'error' -%}
                          <span data-error=""></span>
                        </strong>
                      {%- endunless -%}
                    </div>
                  {%- when 'payment_icons' -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }} --align-center"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      {%- if block.settings.heading != blank -%}
                        <strong class="product-common_pay-title h text-size--small --fw-semi-bold">
                          {{- block.settings.heading -}}
                        </strong>
                      {%- endif -%}
                      {%- render 'payment-icons', prefix_class: 'product-common' -%}
                    </div>
                  {%- when 'action_buttons' -%}
                    {%- if block.settings.enable_question or block.settings.enable_share -%}
                      <div
                        class="product-common_row product-common_row--{{ block.type }} --align-center"
                        style="--block-spacing: {{ block.settings.block_spacing }}px;"
                        {{ block.shopify_attributes }}
                      >
                        <div class="product-common_action-btns">
                          {%- if block.settings.enable_question -%}
                            <div class="product-common_action-col product-common_action-col--ask">
                              <modal-component-toggler>
                                <button
                                  type="button"
                                  data-expanded="false"
                                  data-modal-ref="{{ section.id }}-modal-question-ask"
                                  aria-haspopup="dialog"
                                  aria-controls="{{ section.id }}-modal-question-ask"
                                  class="button button--primary procut-common_ask-btn button--animate --fw-normal"
                                >
                                  {%- render 'icons-data',
                                    width: 20,
                                    height: 20,
                                    use_icon: true,
                                    icon_reference: 'question'
                                  -%}
                                  {{- 'product.ask_question.label' | t -}}
                                </button>
                              </modal-component-toggler>
                              <modal-component
                                data-modal="{{ section.id }}-modal-question-ask"
                                data-container="body"
                              >
                                <div
                                  class="modal modal-component modal-component--question-ask modal-component--centered scheme--{{ section.settings.section_color_scheme }}"
                                  role="dialog"
                                  aria-modal="true"
                                  aria-labelledby="{{ section.id }}-modal-question-ask-heading"
                                  aria-describedby="{{ section.id }}-modal-question-ask"
                                  tabindex="-1"
                                >
                                  <div class="modal-component_spacer">
                                    <div class="modal-component_wrapper" id="{{ section.id }}-modal-question-ask">
                                      <div class="modal-component_body">
                                        <div class="modal-component_head --align-center">
                                          <modal-component-toggler>
                                            <button
                                              type="button"
                                              data-expanded="true"
                                              data-toggle-attribute="false"
                                              data-modal-ref="{{ section.id }}-modal-question-ask"
                                              class="modal-component_btn-close button button--icn"
                                            >
                                              {%- render 'icons-data',
                                                width: 14,
                                                height: 14,
                                                use_icon: true,
                                                icon_reference: 'cross'
                                              -%}
                                              <span class="visually-hidden">{{- 'accessibility.close' | t -}}</span>
                                            </button>
                                          </modal-component-toggler>
                                          <strong
                                            id="{{ section.id }}-modal-question-ask-heading"
                                            class="modal-component_heading mty h6"
                                          >
                                            {{- 'product.ask_question.heading' | t -}}
                                          </strong>
                                          <em class="question-popup_steric">
                                            {{- 'product.ask_question.required_fields' | t -}}
                                          </em>
                                        </div>
                                        <div class="modal-component_content">
                                          {%- assign form_ask_id = 'ContactForm' | append: section.id -%}
                                          {%- form 'contact', id: form_id, class: 'isolate' -%}
                                            {%- if form.errors != blank -%}
                                              <strong class="form__message --fw-normal mty" role="alert" tabindex="-1">
                                                {%- render 'icons-data',
                                                  width: 22,
                                                  height: 22,
                                                  use_icon: true,
                                                  icon_reference: 'error'
                                                -%}
                                                {{- 'erorr.common_heading' | t -}}
                                              </strong>
                                              <ul class="errors-list list-unstyled">
                                                <li class="errors-list_item">
                                                  <smooth-anchor data-offset=".sticky-header-wrapper">
                                                    <a
                                                      class="errors-list_link text-size--small"
                                                      href="#ContactForm-email-{{ form_ask_id }}"
                                                    >
                                                      *
                                                      {{- form.errors.translated_fields.email | capitalize }}
                                                      {{ form.errors.messages.email -}}
                                                    </a>
                                                  </smooth-anchor>
                                                </li>
                                              </ul>
                                            {%- endif -%}
                                            <div class="two-form-group">
                                              <div class="form-group form-group--name">
                                                <label
                                                  class="text-size--small --fw-medium visually-hidden"
                                                  for="contact-name-{{ form_ask_id }}"
                                                >
                                                  {{- 'contact_form.form_label.name.label' | t -}}
                                                </label>
                                                <input
                                                  type="text"
                                                  id="contact-name-{{ form_ask_id }}"
                                                  name="contact[Name]"
                                                  placeholder="{{- 'contact_form.form_placeholder.name.label' | t -}}"
                                                >
                                              </div>
                                              <div class="form-group form-group--email">
                                                <label
                                                  class="text-size--small --fw-medium visually-hidden"
                                                  for="ContactForm-email-{{ form_ask_id }}"
                                                >
                                                  {{- 'contact_form.form_label.email.label' | t -}}
                                                </label>
                                                <input
                                                  type="email"
                                                  id="ContactForm-email-{{ form_ask_id }}"
                                                  name="contact[email]"
                                                  placeholder="{{- 'contact_form.form_placeholder.email.label' | t -}}"
                                                >
                                                <div class="newsletter-form_results-wrap results-wrap_message text-size--small">
                                                  {%- if form.errors contains 'email' -%}
                                                    <div class="error-email">
                                                      {%- render 'icons-data',
                                                        width: 22,
                                                        height: 22,
                                                        use_icon: true,
                                                        icon_reference: 'error'
                                                      -%}
                                                      <small
                                                        class="contact__field-error"
                                                        id="ContactForm-email-{{ form_ask_id }}-error"
                                                      >
                                                        {{- form.errors.translated_fields.email | capitalize }}
                                                        {{ form.errors.messages.email -}}
                                                      </small>
                                                    </div>
                                                  {%- endif -%}
                                                </div>
                                              </div>
                                            </div>
                                            <div class="form-group">
                                              <label
                                                class="text-size--small --fw-medium visually-hidden"
                                                for="contact-textarea-{{ form_ask_id }}"
                                              >
                                                {{- 'contact_form.form_label.your_request.label' | t -}}
                                              </label>
                                              <textarea
                                                name="contact[textarea]"
                                                id="contact-textarea-{{ form_ask_id }}"
                                                placeholder="{{- 'contact_form.form_placeholder.your_request.label' | t -}}"
                                              ></textarea>
                                            </div>
                                            <div class="form-wrapper_btn-wrap">
                                              <button class="button button--primary form-wrapper_button" type="submit">
                                                {{- 'contact_form.submit_label' | t -}}
                                              </button>
                                            </div>
                                            {%- if form.posted_successfully? -%}
                                              <div class="success-message" role="alert" tabindex="-1">
                                                <i class="success-message_icn">
                                                  {%- render 'icons-data',
                                                    width: 54,
                                                    height: 54,
                                                    use_icon: true,
                                                    icon_reference: 'smile'
                                                  -%}
                                                </i>
                                                <p>{{- 'contact_form.success.heading1' | t -}}</p>
                                                <p>{{- 'contact_form.success.heading2' | t -}}</p>
                                              </div>
                                            {%- endif -%}
                                          {%- endform -%}
                                        </div>
                                      </div>
                                    </div>
                                  </div>
                                </div>
                              </modal-component>
                            </div>
                          {%- endif -%}
                          {%- if block.settings.enable_share -%}
                            <div
                              class="product-common_action-col product-common_action-col--share"
                              {{ share_render_attr }}
                            >
                              {%- assign share_url = request.origin
                                | append: product.url
                                | append: '?variant='
                                | append: product.selected_or_first_available_variant.id
                              -%}
                              {%- render 'share-button',
                                share_link: share_url,
                                share_title: product_title,
                                product: product,
                                view: 'full-button',
                                section_id: section.id
                              -%}
                            </div>
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endif -%}
                  {%- when '@app' -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      {%- render block -%}
                    </div>
                {%- endcase -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
          {%- if pickup_exist == 'true'
            or featured_list_exist == 'true'
            or icon_description_exist == 'true'
            or enable_complementary == 'true'
          -%}
            <div class="--side-bar">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'complementary' -%}
                    <div
                      class="product-common_row product-common_row--{{ block.type }}"
                      style="--block-spacing: {{ block.settings.block_spacing }}px;"
                      {{ block.shopify_attributes }}
                    >
                      <product-recommendations data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit=10&intent=complementary">
                        <div class="product-recommendations product-common_complementary-products">
                          {%- if recommendations.performed and recommendations.products_count > 0 -%}
                            {%- if block.settings.heading != blank -%}
                              <strong class="product-common_text-heading {{ block.settings.block_heading_size }} {{ block.settings.block_heading_weight }} --word-break">
                                {{- block.settings.heading -}}
                              </strong>
                            {%- endif -%}
                            <div class="product-common_complementry-wrap">
                              <splide-slider
                                data-slider-type="default"
                                data-drag="true"
                                data-autoplay="false"
                                data-gap="15px"
                                data-per-move="1"
                                data-type="slide"
                                data-arrows="{{- block.settings.show_navigation -}}"
                                data-pagination="false"
                                data-per-page="1"
                              >
                                <div
                                  class="splide product-common_complementry-slider"
                                  data-splide='
                                    {
                                      "type": "slide",
                                      "live": true,
                                      "drag": true,
                                      "autoplay": false,
                                      "rewind": false,
                                      "perMove": 1,
                                      "perPage": 1,
                                      "arrows": {{ block.settings.show_navigation }},
                                      "pagination": false,
                                      "mediaQuery": "min",
                                      "gap": "15px"
                                    }
                                  '
                                >
                                  <div class="splide__track">
                                    <div class="splide__list">
                                      {%- for recommendation in recommendations.products -%}
                                        <div class="splide__slide">
                                          {%- render 'product-row',
                                            product: recommendation,
                                            loading_attr: 'lazy',
                                            heading_weight: '--fw-medium',
                                            heading_size: 'small',
                                            section_id: section.id
                                          -%}
                                        </div>
                                      {%- endfor -%}
                                    </div>
                                    {%- if block.settings.show_navigation -%}
                                      <div class="splide-controls splide__arrows --justify-center">
                                        <button class="splide__arrow splide__arrow--prev button button--primary button--icn button--animate">
                                          <span class="visually-hidden">
                                            {{- 'accessibility.slider.previous' | t -}}
                                          </span>
                                          {%- render 'icons-data',
                                            width: 10,
                                            height: 10,
                                            use_icon: true,
                                            icon_reference: 'left-arrow'
                                          -%}
                                        </button>
                                        <button class="splide__arrow splide__arrow--next button button--primary button--icn button--animate">
                                          <span class="visually-hidden">{{- 'accessibility.slider.next' | t -}}</span>
                                          {%- render 'icons-data',
                                            width: 10,
                                            height: 10,
                                            use_icon: true,
                                            icon_reference: 'right-arrow'
                                          -%}
                                        </button>
                                      </div>
                                    {%- endif -%}
                                  </div>
                                </div>

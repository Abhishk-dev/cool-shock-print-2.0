{%- liquid
  assign section_prefix_class = 'main-product'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign selected_variant = product.selected_or_first_available_variant
  assign current_values = selected_variant.options
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
  if product.selected_or_first_available_variant.featured_media
    assign seo_media = product.selected_or_first_available_variant.featured_media
  else
    assign seo_media = product.featured_media
  endif

  assign product_json_id = 'ProductCardJson-' | append: product.id | append: '-' | append: section.id
  assign form_id = 'main-product-atc-form' | append: product.id | append: '-' | append: section.id
  assign product_form_installment_id = 'main-form-installment' | append: product.id | append: '-' | append: section.id
  assign price_render_attr = 'data-render-price'
  assign price_unit_render_attr = 'data-render-price-unit'
  assign sku_render_attr = 'data-render-sku'
  assign stock_render_attr = 'data-render-stock'
  assign qty_render_attr = 'data-render-qty'
  assign stockbar_render_attr = 'data-render-stockbar'
  assign pickup_render_attr = 'data-render-pickup'
  assign share_render_attr = 'data-render-share'
  assign media_slider_attr = 'data-change-slide-' | append: section.id
  assign media_static_attr = 'data-change-media' | append: section.id
  assign error_render_attr = 'data-render-main-error' | append: section.id

  capture variants_chart_exist
    for block in section.blocks
      case block.type
        when 'variants_chart'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture quantity_input_exist
    for block in section.blocks
      case block.type
        when 'quantity_input'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture stock_bar_exist
    for block in section.blocks
      case block.type
        when 'stock_bar'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture buttons_exist
    for block in section.blocks
      case block.type
        when 'buttons'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture additional_information_exist
    for block in section.blocks
      case block.type
        when 'additional_information'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture payment_icons_exist
    for block in section.blocks
      case block.type
        when 'payment_icons'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture action_buttons_exist
    for block in section.blocks
      case block.type
        when 'action_buttons'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture app_exist
    for block in section.blocks
      case block.type
        when '@app'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture collapse_exist
    for block in section.blocks
      case block.type
        when 'collapsible_row'
          if block.settings.show_on_sidebar
            echo 'true'
            break
          endif
      endcase
    endfor
  endcapture

  capture review_exist
    for block in section.blocks
      case block.type
        when 'review'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture featured_list_exist
    for block in section.blocks
      case block.type
        when 'featured_list'
          if block.settings.show_on_sidebar
            echo 'true'
            break
          endif
      endcase
    endfor
  endcapture

  capture pickup_exist
    for block in section.blocks
      case block.type
        when 'pickup_availability'
          if block.settings.show_on_sidebar
            echo 'true'
            break
          endif
      endcase
    endfor
  endcapture

  capture services_exist
    for block in section.blocks
      case block.type
        when 'services'
          if block.settings.show_on_sidebar
            echo 'true'
            break
          endif
      endcase
    endfor
  endcapture

  capture icon_description_exist
    for block in section.blocks
      case block.type
        when 'icon_description'
          if block.settings.show_on_sidebar
            echo 'true'
            break
          endif
      endcase
    endfor
  endcapture

  capture enable_complementary
    for block in section.blocks
      case block.type
        when 'complementary'
          echo 'true'
          break
      endcase
    endfor
  endcapture

  capture product_title
    echo product.title | escape
  endcapture

  capture enable_row_reviews
    if enable_reviews == 'true' and section.settings.reviews_position == 'vertical'
      echo 'true'
    endif
  endcapture

  capture product_clean_url
    if product.url contains '?'
      assign parts = product.url | split: '?'
      echo parts[0]
    else
      echo product.url
    endif
  endcapture
-%}

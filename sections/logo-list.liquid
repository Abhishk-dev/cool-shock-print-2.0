{%- liquid
  assign section_prefix_class = 'logo-list'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign max_logos_to_show = section.settings.number_of_columns_on_desktop | times: section.settings.number_of_rows_on_desktop

  capture loading_attr
    unless section.index != 1
      echo 'eager'
      else
        echo 'lazy'
    endunless
  endcapture

  capture container_class
    if section.settings.section_full_width
      echo 'container-fluid'
      else
        echo 'container'
    endif
  endcapture

  capture marquee_direction
    if section.settings.marquee_direction == 'marquee_forward'
      echo 'forward'
      else
        echo 'backward'
    endif
  endcapture

  capture is_marquee_on
    if section.settings.enable_marquee
      echo 'true'
    endif
  endcapture

  capture max_header_size
    echo settings.page_width | times: section.settings.max_header_size | divided_by: 100
  endcapture
-%}
{%- style -%}
  .logo-list{
    --q-align-value: var(--mobile-q-align);
  }

  .logo-list--no-gutter .container-fluid{
    --cp-spacer-left: 0;
    --cp-spacer-right: 0;
  }

  .logo-list .heading-head{
    margin-bottom: 31px;
  }

  .logo-list marquee-component,
  .logo-list_list{
    margin-top: auto;
    margin-bottom: auto;
  }

  .logo-list_list li,
  .logo-list .marquee-component_col{
    display: flex;
    height: 84px;
  }

  .logo-list .marquee-component_col{
    width: calc(var(--cp-width) * 1px / 3.76 - (var(--cp-spacer-left, 15px) + var(--cp-spacer-right, 15px)));
    padding-left: 0;
    padding-right: 0;
  }

  .logo-list .img-placeholder{
    width: 100%;
    height: 84px;
  }

  .logo-list .logo-placeholder path{
    fill: currentColor;
  }

  .logo-list_list-logo{
    width: 100%;
    display: flex;
    padding-left: 10px;
    padding-right: 10px;
  }

  .logo-list_list-logo img{
    margin: auto;
  }

  .logo-list .logo-placeholder{
    margin-left: auto;
    margin-right: auto;
  }

  .logo-list_list-logo img{
    width: auto;
    max-height: 100%;
  }

  .logo-list_col{
    border: 1px solid var(--section-border-color);
    margin-top: -1px;
    margin-left: -1px;
  }

  .logo-list_col,
  .logo-list_marquee-col{
    filter: grayscale(100%);
    transition: filter 0.3s ease;
  }

  .logo-list_col:hover,
  .logo-list_marquee-col:hover{
    filter: grayscale(0);
    pointer-events: auto;
  }

  .grid-logo.logo-list_col{
    padding-top: 12px;
    padding-bottom: 12px;
  }

  .logo-list_list-logo svg{
      width: 110px;
  }

  .logo-list {
    --desktop-columns-count: 1;
  }

  .logo-list_list.grid{
    row-gap: 0;
    margin-left: 0;
    margin-right: 0;
  }

  @media (min-width: 414px){
    .logo-list_list-logo svg{
      width: unset;
    }
  }

  @media(min-width: 576px){
    .logo-list {
      --desktop-columns-count: 2;
    }
  }

  @media (min-width: 768px){
    .logo-list {
      --desktop-columns-count: 3;
    }

    .logo-list_list-logo{
      padding-left: 35px;
      padding-right: 35px;
    }

    .logo-list{
      --q-align-value: var(--desktop-q-align);
    }
  }

  @media (min-width: 992px){
    .logo-list {
      --desktop-columns-count: 4;
    }

    .logo-list_list-logo{
      padding-left: 42px;
      padding-right: 42px;
    }
  }

  @media (min-width: 1200px){
    .logo-list {
      --desktop-columns-count: var(--columns-count);
    }
  }

  {%- assign query = '414px' -%}
  @media (min-width: {{ query }}) and (max-width: 575px){
    #{{ section.id }}{
      --desktop-columns-count: {{ section.settings.number_of_columns_on_mobile }};
    }
  }
{%- endstyle -%}
<div class="global-block {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }} {{ section_scheme_class }} {% if is_marquee_on == 'true' %}{{ section_prefix_class }}--no-gutter{% endif %}" style="--section-padding-top: {{ section.settings.section_top_padding }}px; --section-padding-bottom: {{ section.settings.section_bottom_padding }}px; --mobile-q-align: {{ section.settings.section_mobile_text_alignment }}; --desktop-q-align: {{ section.settings.section_text_alignment }}; --columns-count: {{ section.settings.number_of_columns_on_desktop }}; --mobile-columns-count: {{ section.settings.number_of_columns_on_mobile }};" id="{{- section.id -}}">
  <div class="{{ container_class }}">
    {%- if section.settings.section_heading != blank or section.settings.section_caption  != blank or section.settings.section_description != blank -%}
      <header class="heading-head inner-container --word-break --q-align" style="--max-content: {{ max_header_size }}px;">
        {%- if section.settings.section_caption != blank -%}
          <div class="{{ section_prefix_class }}_caption h --word-break {{ section.settings.section_caption_size }} {{ section.settings.section_caption_weight }} mty">
            {{- section.settings.section_caption -}}
          </div>
        {%- endif -%}
        {%- if section.settings.section_heading != blank -%}
          <h2 class="{{ section_prefix_class }}_heading --h-anchor-none {{ section.settings.section_heading_size }} {{ section.settings.section_heading_weight }} mty">
            {{- section.settings.section_heading -}}
          </h2>
        {%- endif -%}
        {%- if section.settings.section_description != blank -%}
          <div class="{{ section_prefix_class }}_description --h-anchor-none {{ section.settings.description_text_size }} {{ section.settings.section_description_weight }} mty">
            {{- section.settings.section_description -}}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}
    <div class="{{ section_prefix_class }}_wrapper">
      {%- if section.settings.enable_marquee -%}
        <marquee-component data-direction="{{- marquee_direction -}}" data-pause-on-hover="{{- section.settings.marquee_on_hover -}}" data-speed="{{- section.settings.marquee_speed | plus: 15 -}}">
          <div class="marquee-component marquee-component--h-scroll">
            {%- for block in section.blocks -%}
              <div class="marquee-component_col {{ section_prefix_class }}_marquee-col">
                {% if block.settings.url != blank %}
                  <a href="{{- block.settings.url -}}" class="{{ section_prefix_class }}_list-logo" {% if block.settings.open_new_window %}target="_blank"{% endif %}>
                {% else %}
                  <span class="{{ section_prefix_class }}_list-logo">
                {% endif %}
                  {%- if block.settings.image != blank -%}
                    {%- liquid
                      assign logo_width = block.settings.image.width | round
                      capture image_alt
                        unless block.settings.image.alt == blank
                          echo block.settings.image.alt
                          else
                            echo 'logo_list.image_alt' | t: index: forloop.index
                        endunless
                      endcapture
    
                      capture logo_widths
                        echo logo_width
                      endcapture
                    -%}
                    {%- capture logo_sizes -%}
                      {{- logo_width | prepend: '(min-width: 50px) ' | append: 'px' -}}
                    {%- endcapture -%}
                    {{- block.settings.image | image_url: width: logo_width | image_tag: sizes: logo_sizes, alt: image_alt, widths: logo_widths, loading: loading_attr -}}
                    {%- else -%}
                      {{- 'lifestyle-1' | placeholder_svg_tag: 'img-placeholder' -}}
                  {%- endif -%}
                {% if block.settings.url != blank %}
                  </a>
                {% else %}
                  </span>
                {% endif %}
              </div>
            {%- endfor -%}
          </div>
        </marquee-component>
        {%- else -%}
          <ul class="list-unstyled {{ section_prefix_class }}_list grid">
            {%- for block in section.blocks limit: max_logos_to_show -%}
              <li {{ block.shopify_attributes }} class="grid-logo grid_col {{ section_prefix_class }}_col">
                {% if block.settings.url != blank %}
                  <a href="{{- block.settings.url -}}" class="{{ section_prefix_class }}_list-logo" {% if block.settings.open_new_window %}target="_blank"{% endif %}>
                {% else %}
                  <span class="{{ section_prefix_class }}_list-logo">
                {% endif %}
                  {%- if block.settings.image != blank -%}
                    {%- liquid
                      assign logo_width = block.settings.image.width | round
                      capture image_alt
                        unless block.settings.image.alt == blank
                          echo block.settings.image.alt
                          else
                            echo 'logo_list.image_alt' | t: index: forloop.index
                        endunless
                      endcapture

                      capture logo_widths
                        echo logo_width
                      endcapture
                    -%}
                    {%- capture logo_sizes -%}
                      {{- logo_width | prepend: '(min-width: 50px) ' | append: 'px' -}}
                    {%- endcapture -%}
                    {{- block.settings.image | image_url: width: logo_width | image_tag: sizes: logo_sizes, alt: image_alt, widths: logo_widths, loading: loading_attr -}}
                    {%- else -%}
                      {{- 'lifestyle-1' | placeholder_svg_tag: 'logo-placeholder' -}}
                  {%- endif -%}
                {% if block.settings.url != blank %}
                  </a>
                {% else %}
                  </span>
                {% endif %}
              </li>
            {%- endfor -%}
          </ul>
      {%- endif -%}
    </div>
  </div>
</div>
{% schema %}

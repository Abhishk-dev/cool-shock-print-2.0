<div class="global-block main-page {{ section_prefix_class }}-{{ section.id }} {{ banner_color_scheme }} {{ section_parallax_class }}" style="--desktop-text-alignment: {{ section.settings.section_text_alignment }}; --mobile-text-alignment: {{ section.settings.section_mobile_text_alignment }};">
  <div class="main-page_wrapper --padding">
    <div class="container">
      <div class="main-page_content {{ section_height_class }}">
        {%- liquid
          if section.settings.show_breadcrumb
            render 'breadcrumb', border_top: section.settings.show_top_bdr, border_bottom: section.settings.show_bottom_bdr, color_scheme: section.settings.breadcrumb_color_scheme
          endif
        -%}
        <header class="heading-head inner-container --word-break --q-align">
          {%- if section.settings.page_caption != blank -%}
            <div class="main-page_caption h --word-break {{ section.settings.page_caption_size }} {{ section.settings.page_caption_weight }} mty">
              {{- section.settings.page_caption -}}
            </div>
          {%- endif -%}
          {%- if blog.title != blank -%}
            <h1 class="main-page_heading {{ section.settings.page_heading_size }} {{ section.settings.page_heading_weight }} mty">
              {{- blog.title -}}
            </h1>
          {%- endif -%}
          {%- if section.settings.page_description != blank -%}
            <div class="main-page_description --h-anchor-none {{ section.settings.page_text_size }} {{ section.settings.page_description_weight }} mty">
              {{- section.settings.page_description -}}
            </div>
          {%- endif -%}
        </header>
      </div>
    </div>
    <div class="main-page_bg-wrapper">
      {%- if section.settings.page_image -%}
        {%- if section.settings.parallax_effect -%}
          <span class="main-page_image" style="background-image: url({{- section.settings.page_image | image_url: width: 1920 -}});"></span>
          {%- else -%}
            {%- liquid
              capture image_alt
                unless section.settings.page_image.alt == blank
                  echo section.settings.page_image.alt
                  else
                    echo 'sections.featured_banner.image_alt' | t: index: ''
                endunless
              endcapture
              assign image_height = 320 | divided_by: section.settings.page_image.aspect_ratio | round
            -%}
            <div class="main-page_image">
              {{- section.settings.page_image | image_url: width: 1920 | image_tag:
                class: 'object-fit object-fit--absolute',
                loading: 'lazy',
                width: 320,
                height: image_height,
                widths: '320, 412, 768, 992, 1260, 1350, 1440, 1640, 1920',
                sizes: '100vw',
                alt: image_alt
              -}}
            </div>
        {%- endif -%}
        {% else %}
          {%- render 'placeholder-svgs', type: 'hero', index: 1, class: 'object-fit object-fit--absolute' -%}
      {%- endif -%}
    </div>
  </div>
</div>
<div class="global-block {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }} {{ section_scheme_class }} {% if section.settings.show_borders %}{{ section_prefix_class }}_border{% endif %} {% if section.settings.show_tags_overlay %}{{ section_prefix_class }}_tags-overlay{% endif %}" id="{{- section.id -}}" style="--section-padding-top: {{ section.settings.section_top_padding }}px; --section-padding-bottom: {{ section.settings.section_bottom_padding }}px; --columns-count: {{ section.settings.number_of_columns_on_desktop }};">
  <div class="container">
    <div class="{{ section_prefix_class }}_wrapper">
      <header class="heading-head --v-align-{{ section.settings.content_alignment }}">
        <div class="{{ section_prefix_class }}_title-img">
          {%- if section.settings.image != blank -%}
            {%- liquid
              capture image_alt
                if blog.title != blank
                  echo blog.title
                  else
                    echo 'blogs.placeholder.title' | t
                endif
              endcapture
            -%}
              {{- section.settings.image | image_url: width: 200 | image_tag: class: 'object-fit object-fit--absolute', loading: 'lazy', alt: image_alt, widths: '100, 200', sizes: '(max-width: 767px) 100vw, 200vw' -}}
            {%- else -%}
              {%- render 'placeholder-svgs', type: 'hero', index: 1, class: 'object-fit object-fit--absolute' -%}
          {%- endif -%}
        </div>
        <div class="{{ section_prefix_class }}_head-title">
          <h1 class="{{ section_prefix_class }}_heading h {{ section.settings.section_heading_size }} {{ section.settings.section_heading_weight }} mty">{{- blog.title -}}</h1>
          {%- if section.settings.section_description -%}
            <div class="{{ section_prefix_class }}_description --word-break {{ section.settings.section_text_size }} {{ section.settings.section_description_weight }} mty">
              <p>{{- section.settings.section_description -}}</p>
            </div>
          {%- endif -%}
        </div>
      </header>
      {%- if blog.articles_count == 0 -%}
        <div class="grid_col grid_col--empty">
          <div class="{{ section_prefix_class }}_empty-content --align-center">
            <i class="{{ section_prefix_class }}_icn">
              {%- render 'icons-data', width: 38, height: 38, use_icon: true, icon_reference: 'empty-box' -%}
            </i>
            <strong class="h6 {{ section_prefix_class }}_empty-heading mty">
              {{- 'main_blog.empty_heading' | t -}}
            </strong>
          </div>
        </div>
      {%- else -%}
        {%- paginate blog.articles by max_blogs_to_show -%}
          <div class="grid {{ section_prefix_class }}_grid">
            {%- for article in blog.articles -%}
              <div class="grid_col">
                {%- render 'blog-card',
                  article: article,
                  show_image: section.settings.show_featured_image,
                  show_date: section.settings.show_date,
                  show_author: section.settings.show_author,
                  show_excerpt: section.settings.show_excerpt,
                  show_tags: section.settings.show_tags,
                  show_comments_count: section.settings.show_comments_count,
                  prefix_class: section_scheme_class,
                  index: forloop.index,
                  loading_attr: loading_attr,
                  section_id: section.id
                -%}
              </div>
            {%- endfor -%}
          </div>
          {%- liquid
            if paginate.pages > 1
              render 'pagination', paginate: paginate, prefix_class: section_prefix_class, section_id: section.id
            endif
          -%}
        {%- endpaginate -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main_blog.name",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main_blog.settings.blog_card.banner_header.label"
    },
    {
      "type": "image_picker",
      "id": "page_image",
      "label": "t:image.label",
      "info": "t:sections.main_page.settings.image.info"
    },
    {
      "type": "checkbox",
      "label": "t:sections.image_banner.settings.animations.parallax.label",
      "id": "parallax_effect",
      "default": false
    },
    {
      "type": "text",
      "id": "page_caption",
      "label": "t:caption.label",
      "default": "Caption"
    },
    {

{%- liquid
  assign section_prefix_class = 'main-blog'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign banner_color_scheme = section.settings.banner_color_scheme | prepend: 'scheme scheme--'

  capture max_blogs_to_show
    echo section.settings.number_of_columns_on_desktop | times: section.settings.number_of_rows_on_desktop
  endcapture

  capture loading_attr
    unless section.index != 1
      echo 'eager'
      else
        echo 'lazy'
    endunless
  endcapture

  capture section_parallax_class
    if section.settings.parallax_effect
      echo '--parallax-effect'
    endif
  endcapture

  capture section_height_class
    case section.settings.section_height
      when 'small'
        echo '--small-height'
      when 'medium'
        echo '--medium-height'
      when 'window_height'
        echo '--vh-height'
    endcase
  endcapture
-%}
{%- style -%}
  .main-page_bg-wrapper,
  .main-page.--parallax-effect .main-page_image{
    position: absolute;
  }

  .breadcrumb-nav{
    padding-top: 0;
    padding-bottom: 0;
  }

  .breadcrumb-list,
  .breadcrumb-list_item,
  .breadcrumb-nav,
  .main-page_wrapper,
  .main-page_content{
    display: flex;
  }

  .breadcrumb-list{
    flex-wrap: wrap;
    font-size: 1.4rem;
    line-height: 2rem;
    padding: 10px 22px;
  }

  .breadcrumb-list_item + .breadcrumb-list_item::before{
    content: '';
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    display: inline-block;
    margin-left: 11px;
    margin-right: 11px;
    background: var(--section-links-color);
    border-radius: 100%;
  }

  .breadcrumb-list [aria-current="page"],
  .breadcrumb-list_link{
    font-weight: 700;
  }


  .breadcrumb-list [aria-current="page"]{
    color: var(--heading-color);
  }

  .breadcrumb-list_link{
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 1.2rem;
  }

  .main-page_wrapper{
    margin: auto;
    min-height: inherit;
    z-index: 1;
  }

  .main-page_wrapper.--padding{
    --section-padding-top: 0;
    --section-padding-bottom: 0;
  }

  .main-page_content{
    position: relative;
    z-index: 1;
    flex-direction: column;
  }

  .main-page_content .heading-head {
    margin-top: auto;
    margin-bottom: auto;
    padding: 32px 22px;
  }

  .main-page{
    --height-factor: 0.94;
    z-index: 1;
    --q-align-value: var(--mobile-text-alignment);
    overflow: hidden;
    padding-top: 0;
    padding-bottom: 0;
  }

  .main-page_bg-wrapper,
  .main-page.--parallax-effect .main-page_image,
  .main-page_wrapper{
    width: 100%;
    height: 100%;
  }

  .main-page_bg-wrapper{
    top: 0;
    left: 0;
    z-index: -1;
  }

  .main-page.--parallax-effect .main-page_image {
    background-attachment: fixed;
    background-position: 50% 50%;
    left: 0;
    top: 0;
    z-index: -1;
    background-size: cover;
  }

  .main-page_wrapper{
    --sec-pt-top: calc(var(--section-padding-top) * 0.45);
    --sec-pt-bottom: calc(var(--section-padding-bottom) * 0.45);
    padding-top: var(--sec-pt-top, 35px);
    padding-bottom: var(--sec-pt-bottom, 35px);
  }

  .main-page_description {
    --mt-top: 18px;
  }

  .pagination-wrapper,
  .pagination,
  .pagination_list,
  .load-more_button,
  .main-blog .heading-head,
  .main-blog_empty-content,
  .main-blog_grid .grid_col,
  .blog-card_tags-list,
  .blog-card_stats-wrap,
  .blog-card_subtitle,
  .blog-card{
    display: flex;
  }

  .pagination_link,
  .blog-card_heading a{
    text-decoration: none;
  }

  .pagination_link,
  .blog-card_tag-link,
  .blog-card_subtitle{
    font-weight: 400;
  }

  .pagination-wrapper{
    padding-left: var(--cp-spacer-left, 15px);
    padding-right: var(--cp-spacer-right, 15px);
    margin-top: 18px;
  }

  .pagination_list {
    gap: 2px;
  }

  .pagination_next-pg{
    margin-right: 9.6px;
  }

  .pagination_back-pg{
    margin-left: 9.6px;
  }

  .pagination_link {
    font-size: 1.8rem;
    line-height: 2.8rem;
    transition: color 0.35s ease;
    padding: 0.5rem 1rem;
  }

  .pagination_link,
  .blog-card_image,
  .blog-card_tag-link{
    display: block;
  }

  .pagination-wrapper,
  .pagination,
  .pagination_list{
    justify-content: center;
  }

  .load-more_button,
  .blog-card_subtitle{
    align-items: center;
  }

  .load-more_button{
    gap: 8px;
  }

  .load-more_loader{
    line-height: 1rem;
  }

  .main-blog {
    --desktop-columns-count: 1;
  }

  .main-blog .heading-head {
    margin-bottom: 24px;
    gap: 20px;
    text-align: center;
  }

  .main-blog_empty-content,
  .main-blog .heading-head,
  .blog-card{
    flex-direction: column;
  }

  .main-blog_border .main-blog_grid > .grid_col{
    margin-left: -1px;
    margin-top: -1px;
  }

  .main-blog_grid {
    --cp-spacer-left: 7px;
    --cp-spacer-right: 7px;
  }

  .blog-card_image{
    border-radius: calc(var(--section-radius) / 2);
    overflow: hidden;
  }

  .blog-card_image-date,
  .blog-card_image,
  .main-blog_title-img{
    position: relative;
  }

  .blog-card_date{
    position: absolute;
    bottom: 0;
    z-index: 1;
    background: var(--section-background-color);
    padding: 3px 10px;
    max-width: 249px;
  }

  .blog-card_date-static,
  .blog-card_date{
    color: var(--section-alternative-color);
  }

  a.blog-card_image:focus-visible{
    --focus-outline-offset: -2px;
  }

  a.blog-card_image:focus-visible img,
  a.blog-card_image:focus-visible svg {
    padding: 5px;
  }

  .blog-card_image svg,
  .blog-card_image img{
    border-radius: inherit;
  }

  .blog-card_heading a{
    transition: color 0.3s ease;
    color: var(--section-heading-color);
  }

  .blog-card_icn{
    color: var(--section-links-color);
  }

  .blog-card_icn,
  .blog-card_subtitle + .blog-card_subtitle::before{
    line-height: 0;
  }

  .blog-card_subtitle,
  .blog-card_stats-wrap,
  .pagination_list{
    flex-wrap: wrap;
  }

  .--tag-full{
    margin-top: 21px;
  }

  .--normal-tag{
    margin: 5px 0;
  }

  .blog-card_tags-list{
    overflow-x: auto;
    overflow-y: hidden;
  }

  .blog-card_tag-item,
  .main-blog_title-img,
  .blog-card_subtitle + .blog-card_subtitle::before{
    flex-shrink: 0;
  }

  .blog-card_tags-list,
  .blog-card_subtitle{
    gap: 10px;
  }

  .blog-card_stats-wrap{
    column-gap: 10px;
  }

  .--normal-gap{
    margin-top: 5px;
  }

  .blog-card_subtitle--comments-count{
    margin-top: 13px;
  }

  .--margin-date{
    --mt-bottom: 7px;
  }

  .--excerpt{
    --mt-top: 19px;
  }

  .blog-card_tag-link{
    padding: 7px 13px;
    border-radius: calc(var(--section-radius) + 100px);
    background-color: var(--section-widget-background-color);
    color: var(--section-widget-foreground-color);
    transition: color 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
  }

  .blog-card_stats-wrap,
  .blog-card_tag-link{
    font-size: 1.2rem;
  }

  .blog-card_stats-wrap,
  .blog-card_tag-link {
    line-height: 2.3rem;
  }

  .blog-card_subtitle + .blog-card_subtitle::before{
    content: "-";
    background: var(--section-foreground-color);
    pointer-events: none;
    margin-left: 3px;
    margin-right: 3px;
  }

  .blog-card_subtitle:last-child:not(:nth-child(2))::before{
    display: none;
  }

  .main-blog_title-img{
    border: 1px solid var(--section-border-color);
  }

  .blog-card_top-wrap{
    flex-grow: 1;
  }

  .blog-card,
  .blog-card_subtitle--comments-count,
  .main-blog_empty-content,
  .main-blog .heading-head,
  .pagination-wrapper,
  .pagination,
  .pagination_list{
    width: 100%;
  }

  .pagination_link--active{
    color: var(--section-active-hover-color);
  }

  .blog-card_read-more{
    margin-left: 3px;
    padding: 3px;
  }

  .blog-card_content-head{
    padding: 15px 22px;
  }

  .main-blog_title-img{
    width: 60px;
    height: 60px;
  }

  .main-blog_title-img,
  .main-blog_title-img img,
  .main-blog_title-img svg{
    border-radius: 5px;
  }

  .main-blog_border .blog-card{
    border: 1px solid var(--section-border-color);
  }

  .main-blog_tags-overlay .blog-card{
    position: relative;
  }

  .main-blog_tags-overlay .blog-card_tags-list{
    position: absolute;
    top: 0;
    z-index: 1;
    left: 0;
    right: 0;
    padding: 17px 16px;
    margin: 0;
  }

  .main-blog_tags-overlay .blog-card_tag-link{
    font-size: 1rem;
    line-height: 1.6rem;
  }

  .main-blog_border .main-blog_grid{
    --cp-spacer-left: 0;
    --cp-spacer-right: 0;
  }

  @media (min-width: 414px){
    .blog-card_date{
      max-width: 140px
    }
  }

  @media (min-width: 576px){
    .blog-card_date{
      max-width: 249px
    }

    .main-blog .heading-head{
      flex-direction: row;
      text-align: left;
    }
  }

  @media (min-width: 768px) {
    .main-blog {
      --desktop-columns-count: 3;
    }

    .main-page{
      --q-align-value: var(--desktop-text-alignment);
    }
  }

  @media (min-width: 1200px) {
    .main-blog {
      --desktop-columns-count: var(--columns-count);
    }
  }
  {%- assign query = '414px' -%}
  @media (min-width: {{ query }}) and (max-width: 767px){
    #{{ section.id }}{
      --desktop-columns-count: {{ section.settings.number_of_columns_on_mobile }};
    }
  }
{%- endstyle -%}

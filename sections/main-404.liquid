{%- liquid
  assign section_prefix_class = 'main-404'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'

	capture loading_attr
		if section.index > 1
			echo 'lazy'
			else
				echo 'eager'
		endif
	endcapture

	capture heading_alt
		echo 'main_404.label' | t
	endcapture

	capture img_blank
		if section.settings.image == blank
			echo '--image-none'
		endif
	endcapture

	capture btn_url
		echo section.settings.section_link | default: routes.root_url
	endcapture

	capture btn_label
		if section.settings.section_link_label != blank
			echo section.settings.section_link_label | escape
			else
				echo 'main_404.button_label' | t
		endif
	endcapture
-%}
{%- style -%}

  .main-404_heading{
    margin: 0;
    text-transform: uppercase; 
    font-size: 12rem;
    font-weight: 700;
    line-height: 12rem;
    font-family: var(--body-font-family);
    color: var(--section-heading-color);
    text-shadow: 6px 6px var(--section-success-color);
  }
  
  .main-404_heading,
  .main-404_caption{
    margin-bottom: 22px;
  }

  .--uppercase {
    text-transform: uppercase;
  }

  .main-404_description p{
    text-transform: uppercase;
    color: var(--section-heading-color);
  }

  .main-404,
  .main-404_img,
  .main-404_form-align{
    position: relative;
  }

  .main-404 .container-fluid{
    --cp-spacer-left: 0;
    --cp-spacer-right: 0;
  }

  .main-404_btn-label{
    display: block;
  }

  .main-404_description{
    margin-top: 16px;
    margin-bottom: 14px;
  }

  .main-404_wrapper{
    display: flex;
  }

  .main-404_btn{
    display: inline-block;
    gap: 20px;
    --button-text-alignment: left;
  }

  .main-404_foot{
    z-index: 1;
  }

  .main-404_wrapper{
    justify-content: center;
    padding-left: 15px;
    padding-right: 15px;
  }

  .main-404_column{
    min-width: 100%;
  }

  .main-404_column--image{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .main-404_img{
    height: 100%;
    width: 100%;
  }

  .main-404_img img{
    mix-blend-mode: darken;
  }

  .--image-none .main-404_form-align{
    max-width: 100%;
  }

  .main-404_column.align-holder{
    flex-direction: column;
  }

  .main-404_foot:focus-within {
    padding: 4px;
  }

  .align-holder--mcenter .main-404_form-align.align-holder_wrapper{
    margin: 0;
  }

  .main-404_description{
    margin-top: 22px;
  }

  .main-404_form-align{
    padding-top: 120px;
    padding-bottom: 120px;
  }

  @media(min-width: 768px){
    .main-404_form-align{
      padding-top: 170px;
      padding-bottom: 170px;
      padding-left: 30px;
      padding-right: 30px;
    }

    .main-404_description {
      margin-top: 50px;
    }
  }

  @media (min-width: 992px){
    .main-404_heading{
      font-size: 22rem;
      line-height: 17rem;
    }
  }
{%- endstyle -%}
<div class="global-block {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }} {{ section_scheme_class }}" style="--section-padding-top: {{ section.settings.section_top_padding }}px; --section-padding-bottom: {{ section.settings.section_bottom_padding }}px;">
  <div class="container">
    <div class="{{ section_prefix_class }}_wrapper">
      <div class="{{ section_prefix_class }}_column align-holder {{ img_blank }} align-holder--mcenter" style="--desktop-q-align: {{ section.settings.section_text_alignment }}; --q-align-value: var(--desktop-q-align);">
        <div class="{{ section_prefix_class }}_form-align align-holder_wrapper --q-align">
          {%- if section.settings.page_caption != blank -%}
            <div class="{{ section_prefix_class }}_caption h --word-break {{ section.settings.page_caption_size }} {{ section.settings.page_caption_weight }} --uppercase mty">
              {{- section.settings.page_caption -}}
            </div>
          {%- endif -%}
					{%- if section.settings.heading != blank -%}
						<h1 class="{{ section_prefix_class }}_heading {{ section.settings.section_heading_size }} {{ section.settings.section_heading_weight }} --word-break mty">
							{{ section.settings.heading }}
						</h1>
					{%- endif -%}
          {%- if section.settings.subheading != blank -%}
						<h3 class="{{ section_prefix_class }}_subheading {{ section.settings.section_subheading_size }} {{ section.settings.section_subheading_weight }} --word-break --uppercase mty">
							{{ section.settings.subheading }}
						</h3>
					{%- endif -%}
					{%- if section.settings.section_description != blank -%}
						<div class="{{ section_prefix_class }}_description {{ section.settings.section_description_size }} {{ section.settings.section_description_weight }} --word-break mty">
							{{ section.settings.section_description }}
						</div>
					{%- endif -%}
          <a
						href="{{- btn_url -}}" 
						class="{{ section_prefix_class }}_btn button button--{{ section.settings.section_link_type }} button--animate"
						{% if section.settings.section_link_target %}target="_blank"{% endif %}
					>
						<span class="{{ section_prefix_class }}_btn-label --word-break">
							{{- btn_label -}}
						</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>


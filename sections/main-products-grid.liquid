{%- liquid
  assign section_prefix_class = 'main-grid'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign banner_color_scheme = section.settings.banner_color_scheme | prepend: 'scheme scheme--'
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign results_url = collection.url
  assign base_url = request.path

  if section.settings.enable_sort
    capture sort_value
      for option in collection.sort_options
        if option.value == sort_by
          echo option.value
        endif
      endfor
    endcapture
    assign base_url = base_url | append: '?' | append: 'sort_by' | append: '=' | append: sort_by
  endif

  capture max_products_to_show
    assign columns_count = section.settings.number_of_columns_on_desktop | times: 1
    echo columns_count | times: section.settings.number_of_rows_on_desktop
  endcapture

  capture enable_description
    unless collection.description == blank
      if section.settings.show_description
        echo 'true'
      endif
    endunless
  endcapture

  capture section_parallax_class
    if section.settings.parallax_effect
      echo '--parallax-effect'
    endif
  endcapture

  capture section_height_class
    case section.settings.section_height
      when 'small'
        echo '--small-height'
      when 'medium'
        echo '--medium-height'
      when 'window_height'
        echo '--vh-height'
    endcase
  endcapture
-%}

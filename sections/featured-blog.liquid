<div class="global-block {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }} {{ section_scheme_class }} --q-align {% if section.settings.show_borders %}{{ section_prefix_class }}_border{% endif %} {% if section.settings.show_tags_overlay %}{{ section_prefix_class }}_tags-overlay{% endif %}" id="{{- section.id -}}" style="--section-padding-top: {{ section.settings.section_top_padding }}px; --section-padding-bottom: {{ section.settings.section_bottom_padding }}px; --columns-count: {{ section.settings.number_of_columns_on_desktop }}; --mobile-columns-count: {{ section.settings.number_of_columns_on_mobile }}; --mobile-q-align: {{ section.settings.section_mobile_text_alignment }}; --desktop-q-align: {{ section.settings.section_text_alignment }};">
  <div class="container">
    <div class="{{ section_prefix_class }}_wrapper">
      {%- if section.settings.heading != blank or section.settings.section_description != blank or section.settings.section_caption != blank -%}
        <header class="heading-head">
          {%- if section.settings.section_caption != blank -%}
            <h2 class="{{ section_prefix_class }}_caption {{ section.settings.section_caption_size }} {{ section.settings.section_caption_weight }} mty">
              {{- section.settings.section_caption -}}
            </h2>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="{{ section_prefix_class }}_heading {{ section.settings.section_heading_size }} {{ section.settings.section_heading_weight }} mty">
              {{- section.settings.heading -}}
            </h2>
          {%- endif -%}
          {%- if section.settings.section_description != blank -%}
            <div class="{{ section_prefix_class }}_description --word-break {{ section.settings.section_text_size }} {{ section.settings.section_description_weight }} mty">
              <p>{{- section.settings.section_description -}}</p>
            </div>
          {%- endif -%}
        </header>
      {%- endif -%}
      {%- if section.settings.section_blog.articles_count > 0 -%}
        {%- if section.settings.enable_slideshow -%}
          <splide-slider
            data-slider-type="default"
          >
            <div class="splide {{ section_prefix_class }}_slider"
              data-splide='{
                "drag": true,
                "autoplay": {{- section.settings.auto_play -}},
                "rewind": true,
                "gap": "14px",
                "perMove": 1,
                "perPage": 1,
                "padding": "3px",
                "arrows": {{- section.settings.show_navigation -}},
                "pagination": {{- section.settings.show_pagination -}},
                "mediaQuery": "min",
                  "breakpoints": {
                    "414": {
                      "perPage": {{ section.settings.number_of_columns_on_mobile }}
                    },
                    "576": {
                      "perPage": 2
                    },
                    "768": {
                      "perPage": 3
                    },
                    "1200": {
                      "perPage": {{ section.settings.number_of_columns_on_desktop }}
                    }
                  },
                "type": "loop"
              }'
            >
              <div class="splide__track">
                <div class="splide__list" style="--init-divider: {{ section.settings.number_of_columns_on_desktop }}; --init-mob-divider: {{ section.settings.number_of_columns_on_mobile }};">
                  {%- for article in section.settings.section_blog.articles limit: max_blogs_to_show -%}
                    <div class="splide__slide {{ section_prefix_class }}_card-border">
                      {%- render 'blog-card',
                        article: article,
                        show_image: section.settings.show_featured_image,
                        show_date: section.settings.show_date,
                        show_author: section.settings.show_author,
                        show_excerpt: section.settings.show_excerpt,
                        show_tags: section.settings.show_tags,
                        show_comments_count: section.settings.show_comments_count,
                        prefix_class: section_scheme_class,
                        loading_attr: loading_attr,
                        section_id: section.id
                      -%}
                    </div>
                  {%- endfor -%}
                </div>
              </div>
              {%- if section.settings.show_navigation or section.settings.show_pagination -%}
                <div class="splide-controls splide__arrows --justify-center">
                  {%- if section.settings.show_navigation -%}
                    <button class="splide__arrow splide__arrow--prev button button--primary button--icn button--animate">
                      <span class="visually-hidden">{{- 'accessibility.slider.previous' | t -}}</span>
                      {%- render 'icons-data', width: 10, height: 10, use_icon: true, icon_reference: 'left-arrow' -%}
                    </button>
                  {%- endif -%}
                  <ul
                    class="splide__pagination"
                    role="tablist"
                    aria-label="{{- 'accessibility.slider.pagination_label' | t -}}"
                  ></ul>
                  {%- if section.settings.show_navigation -%}
                    <button class="splide__arrow splide__arrow--next button button--primary button--icn button--animate">
                      <span class="visually-hidden">{{- 'accessibility.slider.next' | t -}}</span>
                      {%- render 'icons-data', width: 10, height: 10, use_icon: true, icon_reference: 'right-arrow' -%}
                    </button>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </splide-slider>
        {%- else -%}
          <div class="grid {{ section_prefix_class }}_grid">
            {%- for article in section.settings.section_blog.articles limit: max_blogs_to_show -%}
              <div class="grid_col {{ section_prefix_class }}_card-border">
                {%- render 'blog-card',
                  article: article,
                  show_image: section.settings.show_featured_image,
                  show_date: section.settings.show_date,
                  show_author: section.settings.show_author,
                  show_excerpt: section.settings.show_excerpt,
                  show_tags: section.settings.show_tags,
                  show_comments_count: section.settings.show_comments_count,
                  prefix_class: section_scheme_class,
                  loading_attr: loading_attr,
                  section_id: section.id
                -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        {%- if section.settings.enable_slideshow -%}
          <splide-slider
            data-slider-type="default"
          >
            <div class="splide {{ section_prefix_class }}_slider"
              data-splide='{
                "drag": true,
                "autoplay": {{- section.settings.auto_play -}},
                "rewind": true,
                "gap": "14px",
                "perMove": 1,
                "perPage": 1,
                "padding": "3px",
                "arrows": {{- section.settings.show_navigation -}},
                "pagination": {{- section.settings.show_pagination -}},
                "mediaQuery": "min",
                  "breakpoints": {
                    "414": {
                      "perPage": {{ section.settings.number_of_columns_on_mobile }}
                    },
                    "576": {
                      "perPage": 2
                    },
                    "768": {
                      "perPage": 3
                    },
                    "1200": {
                      "perPage": {{ section.settings.number_of_columns_on_desktop }}
                    }
                  },
                "type": "loop"
              }'
            >
              <div class="splide__track">
                <div class="splide__list splide-slider--h-scroll" style="--init-divider: {{ section.settings.number_of_columns_on_desktop }}; --init-mob-divider: {{ section.settings.number_of_columns_on_mobile }};">
                  {%- for article in (1..max_blogs_to_show) -%}
                    <div class="splide__slide {{ section_prefix_class }}_card-border">
                      {%- render 'blog-card-placeholder',
                        index: forloop.index,
                        show_image: section.settings.show_featured_image,
                        show_date: section.settings.show_date,
                        show_author: section.settings.show_author,
                        show_excerpt: section.settings.show_excerpt,
                        show_tags: section.settings.show_tags,
                        show_comments_count: section.settings.show_comments_count,
                        prefix_class: section_scheme_class,
                        loading_attr: loading_attr,
                        section_id: section.id
                      -%}
                    </div>
                  {%- endfor -%}
                </div>
              </div>
              {%- if section.settings.show_navigation or section.settings.show_pagination -%}
                <div class="splide-controls splide__arrows --justify-center">
                  {%- if section.settings.show_navigation -%}
                    <button class="splide__arrow splide__arrow--prev button button--primary button--icn button--animate">
                      <span class="visually-hidden">{{- 'accessibility.slider.previous' | t -}}</span>
                      {%- render 'icons-data', width: 10, height: 10, use_icon: true, icon_reference: 'left-arrow' -%}
                    </button>
                  {%- endif -%}
                  <ul
                    class="splide__pagination"
                    role="tablist"
                    aria-label="{{- 'accessibility.slider.pagination_label' | t -}}"
                  ></ul>
                  {%- if section.settings.show_navigation -%}
                    <button class="splide__arrow splide__arrow--next button button--primary button--icn button--animate">
                      <span class="visually-hidden">{{- 'accessibility.slider.next' | t -}}</span>
                      {%- render 'icons-data', width: 10, height: 10, use_icon: true, icon_reference: 'right-arrow' -%}
                    </button>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </splide-slider>
        {%- else -%}
          <div class="grid {{ section_prefix_class }}_grid">
            {%- for article in (1..max_blogs_to_show) -%}
              <div class="grid_col {{ section_prefix_class }}_card-border">
                {%- render 'blog-card-placeholder',
                  index: forloop.index,
                  show_image: section.settings.show_featured_image,
                  show_date: section.settings.show_date,
                  show_author: section.settings.show_author,
                  show_excerpt: section.settings.show_excerpt,
                  show_tags: section.settings.show_tags,
                  show_comments_count: section.settings.show_comments_count,
                  prefix_class: section_scheme_class,
                  loading_attr: loading_attr,
                  section_id: section.id
                -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.enable_show_more_button and show_more_button == 'true' -%}
        <footer class="{{ section_prefix_class }}_foot --align-center">
          <a
            href="{{- section.settings.section_blog.url -}}"
            class="button button--{{ section.settings.view_more_type }} {{ section_prefix_class }}_btn-more button--animate"
          >
            {%- if section.settings.view_more_label != blank -%}
              {{- section.settings.view_more_label | escape -}}
            {%- else -%}
              {{- 'blogs.view_all_button_label' | t -}}
            {%- endif -%}
          </a>
        </footer>
      {%- endif -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:sections.featured_blog.name",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header", 
      "footer",
      "custom.overlay"
    ]
  },
  "settings": [
    {
      "type": "blog",
      "label": "t:sections.featured_blog.settings.blog.label",
      "id": "section_blog"
    },
    {
      "type": "text",
      "id": "section_caption",
      "label": "t:caption.label",
      "default": "Caption"
    },
    {
      "type": "select",
      "id": "section_caption_size",
      "label": "t:sizes.caption.label",
      "options": [
        {
          "value": "text-size--small",
          "label": "t:sizes.text.options.opt_1.label"
        },
        {
          "value": "text-size--medium",
          "label": "t:sizes.text.options.opt_2.label"
        },
        {
          "value": "text-size--large",
          "label": "t:sizes.text.options.opt_3.label"
        },
        {
          "value": "text-size--xlarge",
          "label": "t:sizes.text.options.opt_4.label"
        }
      ],
      "default": "text-size--medium"
    },
    {
      "type": "select",
      "id": "section_caption_weight",
      "label": "t:weight.caption.label",
      "options": [
        {
          "value": "--fw-bold",
          "label": "t:weight.heading.options.opt_1.label"
        },

{%- liquid
  assign section_prefix_class = 'featured-blog'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign max_blogs_to_show = section.settings.number_of_columns_on_desktop | times: section.settings.number_of_rows_on_desktop

  capture show_more_button
    if section.settings.section_blog.articles_count > max_blogs_to_show
      echo 'true'
      else
        echo 'false'
    endif
  endcapture

  capture loading_attr
    unless section.index != 1
      echo 'eager'
      else
        echo 'lazy'
    endunless
  endcapture
-%}
{%- style -%}
  .pagination-wrapper{
    padding-left: var(--cp-spacer-left, 15px);
    padding-right: var(--cp-spacer-right, 15px);
  }

  .pagination_list {
    flex-wrap: wrap;
    gap: 6px;
  }

  .pagination_next-pg{
    margin-right: 9.6px;
  }

  .pagination_back-pg{
    margin-left: 9.6px;
  }

  .pagination_item{
    border: 1px solid var(--section-border-color);
    border-radius: 4px;
  }

  .pagination_link {
    text-decoration: none;
    font-size: 1.4rem;
    font-weight: 400;
    line-height: 2rem;
    transition: color 0.35s ease;
    padding: 0.5rem 1rem;
    display: block;
  }

  a.pagination_link--active{
    background-color: var(--section-active-hover-color);
    color: var(--section-background-color);
  }

  .pagination-wrapper{
    margin-top: 47px;
  }

  .pagination-wrapper,
  .pagination,
  .pagination_list{
    display: flex;
    width: 100%;
    justify-content: center;
  }

  .load-more_button{
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .load-more_loader{
    line-height: 1rem;
  }

  .blog-card_image{
    border-radius: calc(var(--section-radius) / 2);
    overflow: hidden;
    display: block;
  }

  .blog-card_image-date,
  .blog-card_image{
    position: relative;
  }

  .blog-card_date{
    position: absolute;
    bottom: 0;
    z-index: 1;
    background: var(--section-background-color);
    color: var(--section-alternative-color);
    padding: 3px 10px;
    max-width: 249px;
  }

  .blog-card_date-static{
    color: var(--section-alternative-color);
  }

  a.blog-card_image:focus-visible{
    --focus-outline-offset: 1px;
  }

  .blog-card_image svg,
  .blog-card_image img{
    border-radius: inherit;
  }

  .blog-card_heading a{
    text-decoration: none;
    transition: color 0.3s ease;
    color: var(--section-heading-color);
  }

  .blog-card_icn{
    color: var(--section-links-color);
  }

  .blog-card_icn,
  .blog-card_subtitle + .blog-card_subtitle::before{
    line-height: 0;
  }

  .blog-card_tags-list,
  .blog-card_stats-wrap,
  .blog-card_subtitle,
  .blog-card{
    display: flex;
  }

  .blog-card_subtitle,
  .blog-card_stats-wrap{
    flex-wrap: wrap;
  }

  .--tag-full{
    margin-top: 21px;
  }

  .--normal-tag{
    margin: 5px 0;
  }

  .blog-card_tags-list{
    overflow-x: auto;
    overflow-y: hidden;
  }

  .blog-card_tag-item{
    flex-shrink: 0;
  }

  .blog-card_stats-wrap{
    column-gap: 10px;
  }

  .blog-card_tags-list,
  .blog-card_subtitle{
    gap: 10px;
  }

  .--normal-gap{
    margin-top: 5px;
  }

  .blog-card_subtitle--comments-count{
    margin-top: 13px;
  }

  .--margin-date{
    --mt-bottom: 7px;
  }

  .--excerpt{
    --mt-top: 19px;
  }

  .blog-card_tag-link{
    padding: 7px 13px;
    border-radius: calc(var(--section-radius) + 100px);
    background-color: var(--section-widget-background-color);
    color: var(--section-widget-foreground-color);
    transition: color 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
    display: block;
    font-weight: 400;
  }

  .blog-card_stats-wrap,
  .blog-card_tag-link {
    font-size: 1.2rem;
    line-height: 2.3rem;
  }

  .blog-card_subtitle{
    align-items: center;
  }

  .blog-card_subtitle{
    font-weight: 400;
  }

  .blog-card_subtitle + .blog-card_subtitle::before{
    content: "-";
    background: var(--section-foreground-color);
    flex-shrink: 0;
    pointer-events: none;
    margin-left: 3px;
    margin-right: 3px;
  }

  .blog-card_subtitle:last-child:not(:nth-child(2))::before{
    display: none;
  }

  .blog-card{
    flex-direction: column;
  }

  .featured-blog_border .blog-card{
    border: 1px solid var(--section-border-color);
  }

  .featured-blog_tags-overlay .blog-card{
    position: relative;
  }

  .featured-blog_tags-overlay .blog-card_tags-list{
    position: absolute;
    top: 0;
    z-index: 1;
    left: 0;
    right: 0;
    padding: 17px 16px;
    margin: 0;
  }

  .featured-blog_tags-overlay .blog-card_tag-link{
    font-size: 1rem;
    line-height: 1.6rem;
  }

  .blog-card_top-wrap{
    flex-grow: 1;
  }

  .blog-card,
  .blog-card_subtitle--comments-count{
    width: 100%;
  }

  .blog-card_read-more{
    margin-left: 3px;
    padding: 3px;
  }

  .blog-card_content-head{
    padding: 15px 22px;
  }

  .featured-blog {
    --desktop-columns-count: 1;
    --q-align-value: var(--mobile-q-align);
    --q-justify-value: var(--mobile-justify-align);
  }

  .featured-blog .heading-head {
    width: 100%;
    margin-bottom: 33px;
  }

  .featured-blog_grid .grid_col {
    display: flex;
  }

  .featured-blog_description {
    --mt-top: 4px;
  }

  .featured-blog_caption{
    --mt-bottom: 4px;
  }

  .featured-blog_foot,
  .featured-blog .splide-controls {
    margin-top: 32px;
  }

  .featured-blog .splide__slide {
    display: flex;
  }

  .featured-blog_slider .blog-card .button {
    --focus-outline-offset: -3px;
  }

  .featured-blog_slider .blog-card {
    margin-top: 2px;
  }

  .featured-blog .splide__arrow--next, 
  .featured-blog .splide__arrow--prev{
    --button-padding-y: 0.6rem;
    --button-padding-x: 0.6rem;
    --button-corner-radius: 9px;
  }

  .featured-blog .splide__track{
    overflow: visible;
  }

  @media (min-width: 414px){
    .blog-card_date{
      max-width: 140px
    }
  }

  @media (min-width: 576px){
    .pagination_link {
      padding: 0.8rem 1.2rem;
    }

    .featured-blog {
      --desktop-columns-count: 2;
    }

    .blog-card_date{
      max-width: 249px
    }
  }

  @media (min-width: 768px){
    .featured-blog {
      --desktop-columns-count: 3;
      --q-align-value: var(--desktop-q-align);
      --q-justify-value: var(--desktop-justify-align);
    }
  }

  @media (min-width: 992px){
    .pagination-wrapper{
      margin-top: 78px;
    }
  }

  @media (min-width: 1200px){
    .featured-blog {
      --desktop-columns-count: var(--columns-count);
    }

    .featured-blog_grid {
      --cp-spacer-left: 7px;
      --cp-spacer-right: 7px;
    }
  }
  {%- assign query = '414px' -%}
  @media (min-width: {{ query }}) and (max-width: 575px){
    #{{ section.id }}{
      --desktop-columns-count: {{ section.settings.number_of_columns_on_mobile }};
    }
  }
{%- endstyle -%}

{%- liquid
  assign section_prefix_class = 'main-search'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign banner_color_scheme = section.settings.banner_color_scheme | prepend: 'scheme scheme--'
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign base_url = request.path
  
  if search.url
    assign results_url = search.url
    else
      assign terms = search.terms | escape
      assign results_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
  endif

  if section.settings.enable_sort
    capture sort_value
      for option in search.sort_options
        if option.value == sort_by
          echo option.value
        endif
      endfor
    endcapture
    assign base_url = base_url | append: results_url
  endif

  capture max_products_to_show
    assign columns_count = section.settings.number_of_columns_on_desktop | times: 1
    echo columns_count | times: section.settings.number_of_rows_on_desktop
  endcapture

  capture loading_attr
    unless section.index != 1
      echo 'eager'
      else
        echo 'lazy'
    endunless
  endcapture

  capture results_text
    if search.performed
      echo 'search.results_with_count_and_term' | t: count: search.results_count, terms: search.terms
      else
        echo 'search.s_for' | t
    endif
  endcapture

  capture section_parallax_class
    if section.settings.parallax_effect
      echo '--parallax-effect'
    endif
  endcapture

  capture section_height_class
    case section.settings.section_height
      when 'small'
        echo '--small-height'
      when 'medium'
        echo '--medium-height'
      when 'window_height'
        echo '--vh-height'
    endcase
  endcapture
-%}

<div class="global-block main-page {{ section_prefix_class }}-{{ section.id }} {{ banner_color_scheme }} {{ section_parallax_class }}" style="--desktop-text-alignment: {{ section.settings.section_text_alignment }}; --mobile-text-alignment: {{ section.settings.section_mobile_text_alignment }};">
  <div class="main-page_wrapper --padding">
    <div class="container">
      <div class="main-page_content {{ section_height_class }}">
        {%- liquid
          if section.settings.show_breadcrumb
            render 'breadcrumb', border_top: section.settings.show_top_bdr, border_bottom: section.settings.show_bottom_bdr, color_scheme: section.settings.breadcrumb_color_scheme
          endif
        -%}
        <header class="heading-head inner-container --word-break --q-align">
          {%- if section.settings.page_caption != blank -%}
            <div class="main-page_caption h --word-break {{ section.settings.page_caption_size }} {{ section.settings.page_caption_weight }} mty">
              {{- section.settings.page_caption -}}
            </div>
          {%- endif -%}
          {%- if section.settings.page_heading != blank -%}
            <h1 class="main-page_heading {{ section.settings.page_heading_size }} {{ section.settings.page_heading_weight }} mty">
              {{- section.settings.page_heading -}}
            </h1>
          {%- endif -%}
          {%- if section.settings.page_description != blank -%}
            <div class="main-page_description --h-anchor-none {{ section.settings.page_text_size }} {{ section.settings.page_description_weight }} mty">
              {{- section.settings.page_description -}}
            </div>
          {%- endif -%}
        </header>
      </div>
    </div>
    <div class="main-page_bg-wrapper">
      {%- if section.settings.page_image -%}
        {%- if section.settings.parallax_effect -%}
          <span class="main-page_image" style="background-image: url({{- section.settings.page_image | image_url: width: 1920 -}});"></span>
          {%- else -%}
            {%- liquid
              capture image_alt
                unless section.settings.page_image.alt == blank
                  echo section.settings.page_image.alt
                  else
                    echo 'sections.featured_banner.image_alt' | t: index: ''
                endunless
              endcapture
              assign image_height = 320 | divided_by: section.settings.page_image.aspect_ratio | round
            -%}
            <div class="main-page_image">
              {{- section.settings.page_image | image_url: width: 1920 | image_tag:
                class: 'object-fit object-fit--absolute',
                loading: 'lazy',
                width: 320,
                height: image_height,
                widths: '320, 412, 768, 992, 1260, 1350, 1440, 1640, 1920',
                sizes: '100vw',
                alt: image_alt
              -}}
            </div>
        {%- endif -%}
        {% else %}
          {%- render 'placeholder-svgs', type: 'hero', index: 1, class: 'object-fit object-fit--absolute' -%}
      {%- endif -%}
    </div>
  </div>
</div>
<div class="global-block {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }} {{ section_scheme_class }} grid-common {% if section.settings.card_view == 'view_2' %}card_view-2{% endif %} {% if section.settings.card_view == 'view_3' %}card_view-3{% endif %}" id="{{ section.id }}" style="--section-padding-top: {{ section.settings.section_top_padding }}px; --section-padding-bottom: {{ section.settings.section_bottom_padding }}px; --columns-count: {{ section.settings.number_of_columns_on_desktop }}; --mobile-columns-count: {{ section.settings.number_of_columns_on_mobile }};">
  <div class="container">
    <div class="{{ section_prefix_class }}_wrapper grid-common_wrapper">
      <nav class="{{ section_prefix_class }}_tabs {% if section.settings.show_top_bdr %}--nav-brdr-top{% endif %}">
        <ul class="list-unstyled {{ section_prefix_class }}_collection-list">
          {%- for in_collection in collections limit: 5 -%}
            {%- unless in_collection.url == collection.url -%}
              <li>
                <a class="tab-item --text-decoration" {% if in_collection.url != blank -%}href="{{ in_collection.url }}"{% else %}aria-disabled="true"{% endif %}>
                  {{- in_collection.title -}}
                </a>
              </li>
            {%- endunless -%}
          {%- endfor -%}
        </ul>
        <ul class="list-unstyled {{ section_prefix_class }}_filter-search">
          {%- if section.settings.enable_filters -%}
            <li class="btn-list_item {{ section_prefix_class }}_filters">
              {%- liquid
                if section.settings.enable_filters
                  for filter in search.filters
                    case filter.type
                      when 'price_range'
                        if filter.min_value.value != null or filter.max_value.value != null
                          assign price_min_filter = filter.min_value.param_name
                          assign price_max_filter = filter.max_value.param_name

                          assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
                          assign uses_comma_decimals = false
                          if currencies_using_comma_decimals contains cart.currency.iso_code
                            assign uses_comma_decimals = true
                          endif

                          assign filter_min_value = filter.min_value.value | money_without_currency | replace: ',', ''
                          if uses_comma_decimals
                            assign filter_min_value = filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.'
                          endif

                          if filter.max_value.value
                            assign filter_max_value = filter.max_value.value | money_without_currency | replace: ',', ''
                            if uses_comma_decimals
                              assign filter_max_value = filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.'
                            endif
                            else
                              assign filter_max_value = filter.range_max | money_without_currency | replace: ',', ''
                              if uses_comma_decimals
                                assign filter_max_value = filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.'
                              endif
                          endif

                          assign price_min_filter = price_min_filter | append: '=' | append: filter_min_value
                          assign price_max_filter = price_max_filter | append: '=' | append: filter_max_value
                          unless base_url contains '?'
                            assign base_url = base_url | append: '?' | append: price_min_filter | append: '&' | append: price_max_filter
                            else
                              assign base_url = base_url | append: '&' | append: price_min_filter | append: '&' | append: price_max_filter
                          endunless
                        endif
                      when 'boolean', 'list'
                        for value in filter.active_values
                          assign active_filter_param = value.param_name | append: '=' | append: value.value

                          if base_url contains '?'
                            assign base_url = base_url | append: '&' | append: active_filter_param
                            else
                              assign base_url = base_url | append: '?' | append: active_filter_param
                          endif
                        endfor
                    endcase
                  endfor
                endif

                capture filter_url
                  unless base_url contains '?'
                    echo base_url | append: '?'
                    else
                      echo base_url | append: '&'
                  endunless
                endcapture
              -%}
              <facets-filter
                hidden
                data-sections='[
                  {
                    "id": "{{ section.id }}",
                    "selectors": ["[data-render-counts]", "[data-render-params]", "modal-filter-component:not(.modal--active)", "[data-render-actives]", "[data-render-grid]"]
                  },
                  {
                    "id": "modal-facets",
                    "selectors": ["[data-render-facets]"]
                  }
                ]'
              >
                <input type="hidden" value="{% unless filter_url contains '?' %}?section_id=modal-facets{% else %}section_id=modal-facets{% endunless %}" id="modal-section">
                <input type="hidden" value="{% unless filter_url contains '?' %}?sections[]=modal-facets&sections[]={{ section.id }}{% else %}&sections[]=modal-facets&sections[]={{ section.id }}{% endunless %}" id="filters-sections">
                <span data-render-params="">
                  <input type="hidden" value="{{- filter_url -}}" id="filters-params">
                </span>
                <input type="hidden" value="{{- results_url -}}" id="base-url">
              </facets-filter>
              {%- if section.settings.enable_filters -%}
                <div class="grid-common_facets-wrap grid-common_facets-bar_col grid-common_facets-bar_col--filter">
                  <modal-component-toggler>
                    <button
                      type="button"
                      data-expanded="false"
                      data-modal-ref="modal-facets"
                      aria-haspopup="dialog"
                      aria-controls="modal-facets"
                      class="button button--icn grid-common_facet-opener grid-common--btn --align-center --justify-center --v-align-middle --word-break"
                    >
                      <i class="button_icn-wrapper">
                        {%- render 'icons-data', width: 20, height: 20, use_icon: true, icon_reference: 'filters' -%}
                      </i>
                      <span class="grid-common_facet-opener--text visually-hidden">
                        {{- 'filters.drawer_label_heading' | t -}}
                      </span>
                    </button>
                  </modal-component-toggler>
                  <modal-filter-component
                    data-modal="modal-facets"
                    data-container="body"
                    data-render-selector="modal-facets"
                    data-url="{{- filter_url -}}"
                    data-selector="#facets-wrapper"
                  >
                    <div
                      class="modal modal-component --drawer modal-component--facets-drawer scheme--{{ section.settings.section_color_scheme }}"
                      role="dialog"
                      aria-modal="true"
                      aria-labelledby="modal-facets-heading"
                      aria-describedby="modal-facets"
                      tabindex="-1"
                    >
                      <div class="modal-component_wrapper scheme" id="modal-facets">
                        <div class="modal-component_body">
                          <div class="modal-component_head --align-left product-common_size-heading">
                            <modal-component-toggler>
                              <button
                                type="button"
                                data-expanded="true"
                                data-toggle-attribute="false"
                                data-modal-ref="modal-facets"
                                class="modal-component_btn-close button button--icn">
                                <span class="button_icn-wrapper">
                                  {%- render 'icons-data', width: 14, height: 14, use_icon: true, icon_reference: 'cross' -%}
                                  <span class="visually-hidden">{{- 'accessibility.close' | t -}}</span>
                                </span>
                              </button>
                            </modal-component-toggler>
                            <strong id="modal-facets-heading" class="modal-component_heading h3 --fw-bold mty">
                              {{- 'filters.drawer_label_heading' | t -}}
                            </strong>
                          </div>
                          <div class="modal-component_content" id="facets-wrapper"></div>
                        </div>
                      </div>
                    </div>
                  </modal-filter-component>
                </div>
              {%- else -%}
                <div class="grid-common_facets-wrap grid-common_facets-bar_col grid-common_facets-bar_col--filter">&nbsp;</div>
              {%- endif -%}
            </li>
          {%- endif -%}
          {%- if section.settings.enable_search -%}
            <li class="btn-list_item {{ section_prefix_class }}_search">
              <strong id="search-bar-heading-grid" class="visually-hidden">{{- 'search.label' | t -}}</strong>
              <dropdown-component>
                <button
                  type="button"
                  class="dropdown-component_opener button button--icn {{ section_prefix_class }}_search-opener grid-common--btn"
                  aria-expanded="false"
                  aria-controls="search-bar"
                  aria-describedby="search-bar-heading"
                >
                  <i class="button_icn-wrapper">
                    {%- render 'icons-data', width: 22, height: 22, use_icon: true, icon_reference: 'search', section_id: section.id -%}
                    <span class="visually-hidden">
                      {{- 'search.toggler_label' | t -}}
                    </span>
                  </i>
                </button>
                <div class="dropdown-component_wrapper {{ section_prefix_class }}_dropdown-wrapper widget--styles" id="search-bar-grid">
                  <form action="{{- routes.search_url -}}" method="get" role="search" class="{{ section_prefix_class }}_form">
                    <label for="search-bar-input-{{ section.id }}" class="visually-hidden">
                      {{- 'search.label' | t -}}
                    </label>
                    <input
                      type="search"
                      name="q"
                      title="{{- 'search.label' | t -}}"
                      autocomplete="off"
                      id="search-bar-input-{{ section.id }}"
                      value="{%- if search.terms != blank -%}{{- search.terms  -}}{%- endif -%}"
                      placeholder="{{- 'search.placeholder' | t -}}"
                    >
                    <button type="submit" class="button button--icn {{ section_prefix_class }}_search-bar_label">
                      <i class="button_icn-wrapper">
                        {%- render 'icons-data', width: 16, height: 16, use_icon: true, icon_reference: 'search', section_id: section.id -%}
                        <span class="visually-hidden">
                          {{- 'search.label' | t -}}
                        </span>
                      </i>
                    </button>
                    <button type="button" class="button button--icn {{ section_prefix_class }}_search-bar_reset-btn" data-dropdown-close-btn="">
                      <i class="button_icn-wrapper">
                        {%- render 'icons-data', width: 13, height: 13, use_icon: true, icon_reference: 'cross' -%}
                        <span class="visually-hidden">
                          {{- 'search.reset' | t -}}
                        </span>
                      </i>
                    </button>
                  </form>
                </div>
              </dropdown-component>
            </li>
          {%- endif -%}
          {%- if section.settings.enable_sort -%}
            <li class="btn-list_item {{ section_prefix_class }}_sorting">
              {%- if section.settings.enable_sort -%}
                <div class="grid-common_sort-wrap dropdown-component grid-common_facets-bar_col grid-common_facets-bar_col--sort">
                  <strong id="facets-sort-select-heading" class="visually-hidden" role="heading" aria-level="2">
                    {{- 'filters.sort.label_heading' | t -}}
                  </strong>
                  <div class="dropdown-sort_wrap">
                    <sort-dropdown
                      class="dropdown-sort"
                    >
                      <button
                        type="button"
                        class="dropdown-component_opener grid-common_opener dropdown-sort_opener --align-left --word-break"
                        aria-expanded="false"
                        aria-controls="facets-sort-select"
                        aria-describedby="facets-sort-select-heading"
                      >
                        <span data-current-value="" class="dropdown-sort_title">
                          {%- liquid
                            for option in search.sort_options
                              if option.value == sort_by
                                echo option.name | escape
                              endif
                            endfor
                          -%}
                        </span>
                        <i class="dropdown-componenet_icn-caret">
                          {%- render 'icons-data', width: 9, height: 5, use_icon: true, icon_reference: 'chevron-down', section_id: section.id -%}
                        </i>
                      </button>
                      <div class="dropdown-component_wrapper dropdown-sort_wrapper">
                        <ul id="facets-sort-select" class="list-unstyled dropdown-sort_items">
                          {%- for option in search.sort_options -%}
                            <li>
                              <button
                                data-btn-sort=""
                                type="button"
                                class="dropdown-component_btn-submit --word-break --align-left facet-sort_btn-submit {% if option.value == sort_by %}active{% endif %}"
                                data-value="{{- option.value | escape -}}"
                                data-text="{{- option.name | escape -}}"
                              >
                                {{- option.name | escape -}}
                                {%- if option.value == sort_by -%}
                                  <span class="visually-hidden">{{- 'filters.sort.option_selected' | t -}}</span>
                                {%- endif -%}
                              </button>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                      <input type="hidden" name="sort_by" value="{{- sort_value -}}">
                    </sort-dropdown>
                  </div>
                </div>
              {%- else -%}
                <div class="grid-common_sort-wrap dropdown-component grid-common_facets-bar_col grid-common_facets-bar_col--sort">&nbsp;</div>
              {%- endif -%}
            </li>
          {%- endif -%}
        </ul>
      </nav>
      <header class="heading-head inner-container --align-left">
        {%- if section.settings.show_featured_image -%}
          {%- if section.settings.featured_image != blank -%}
            {%- liquid
              capture image_alt
                if section.settings.featured_image.alt != blank
                  echo section.settings.featured_image.alt
                  else
                    echo section.settings.section_heading | escape
                endif
              endcapture
            -%}
            <div class="{{ section_prefix_class }}_featured-img">
              {{- section.settings.featured_image | image_url: width: 1944 | image_tag: class: 'object-fit object-fit--absolute', loading: 'lazy', alt: image_alt, widths: '100, 200', sizes: '(max-width: 767px) 100px, 200px' -}}
            </div>
          {%- else -%}
            <div class="{{ section_prefix_class }}_featured-img">
              {%- render 'placeholder-svgs', type: 'hero', index: 1, class: 'object-fit object-fit--absolute' -%}
            </div>
          {%- endif -%}
        {%- endif -%}
        <div class="grid-common_header-content">
          <div class="grid-comment_title-counts">
            <h1 class="mty grid-common_heading h {{ section.settings.section_heading_size }} {{ section.settings.section_heading_weight }}">
              {{- section.settings.section_heading -}}
            </h1>
            {%- if search.performed -%}
              <div class="grid-common_text-count mty text-size--small --fw-medium" data-render-counts="">
                {%- liquid
                  if search.results_count != null
                    if search.results_count > 0
                      echo 'search.show_results' | t: count: search.results_count
                      else
                        echo 'search.no_res' | t
                    endif
                  endif
                -%}
              </div>
            {%- endif -%}
          </div>
          <div class="grid-common_text {{ section.settings.section_description_size }} {{ section.settings.section_description_weight }}">
            {{- results_text -}}
          </div>
        </div>
      </header>
      {%- if search.performed and search.results.size != 0 -%}
        <div class="grid-common_area-wrap">
          {%- unless search.results.size == 0 -%}
            <div class="grid-common_cols-wrap grid grid--no-gutters {{ section_prefix_class }}_cols-wrap" data-render-grid="">
              {%- paginate search.results by max_products_to_show -%}
                {%- for product in search.results -%}
                  {%- case product.object_type -%}
                    {%- when 'product' -%}
                      <div class="grid_col" data-render-columns="">
                        {%- liquid
                          if forloop.index == 1
                            render 'product-column', product: product, heading_tag: 'h2', columns_count: section.settings.number_of_columns_on_desktop, media_size: section.settings.product_media_size, enable_atc: section.settings.enable_atc, show_swatches: section.settings.show_swatches, show_price: section.settings.show_price, show_vendor: section.settings.show_vendor, show_stock_tag: section.settings.show_stock_tag, heading_size: section.settings.product_heading_size, heading_weight: section.settings.product_heading_weight, btns_position: section.settings.btns_position, show_quick_view: section.settings.enable_quick_view, fetchpriority: 'high', section_id: section.id
                            else
                              render 'product-column', product: product, heading_tag: 'h2', columns_count: section.settings.number_of_columns_on_desktop, media_size: section.settings.product_media_size, enable_atc: section.settings.enable_atc, show_swatches: section.settings.show_swatches, show_price: section.settings.show_price, show_vendor: section.settings.show_vendor, show_stock_tag: section.settings.show_stock_tag, heading_size: section.settings.product_heading_size, heading_weight: section.settings.product_heading_weight, btns_position: section.settings.btns_position, show_quick_view: section.settings.enable_quick_view, loading_attr: 'lazy', section_id: section.id
                          endif
                        -%}
                      </div>
                    {%- when 'article' -%}
                      <div class="grid_col" data-render-columns="">
                        {%- render 'blog-card',
                          article: product,
                          show_image: section.settings.show_featured_image,
                          show_date: section.settings.show_date,
                          show_author: section.settings.show_author,
                          show_excerpt: section.settings.show_excerpt,
                          show_tags: section.settings.show_tags,
                          show_comments_count: section.settings.show_comments_count,
                          prefix_class: section_scheme_class,
                          index: forloop.index,
                          loading_attr: loading_attr,
                          section_id: section.id
                        -%}
                      </div>
                    {%- when 'page' -%}
                      <div class="grid_col" data-render-columns="">
                        {%- render 'page-card', page: product, section_id: section.id -%}
                      </div>
                  {%- endcase -%}
                {%- endfor -%}
                {%- liquid
                  case section.settings.paging_type
                    when 'click_load'
                      render 'load-more', paginate: paginate, infinite: false, section_id: section.id
                    when 'load_more'
                      render 'load-more', paginate: paginate, infinite: true, section_id: section.id
                    else
                      render 'pagination', paginate: paginate, prefix_class: section_prefix_class, section_id: section.id
                  endcase
                -%}
              {%- endpaginate -%}
            </div>
            {%- else -%}
              <div class="grid-common_empty --align-center" data-render-grid="">
                <i class="grid-common_empty-icn">
                  {%- render 'icons-data', width: 44, height: 44, use_icon: true, icon_reference: 'empty-folder', section_id: section.id -%}
                </i>
                <strong class="grid-common_heading mty {{ section.settings.section_heading_size }} {{ section.settings.section_heading_weight }}">
                  {{- 'collection.empty_heading' | t -}}
                </strong>
                <div class="grid-common_text grid-common_text--empty {{ section.settings.section_description_size }} {{ section.settings.section_description_weight }}">
                  <p>{{- 'filters.use_fewer_filters' | t -}}</p>
                  <facet-remove-button
                    data-name="all"
                  >
                    <button type="button" class="facets-remove-all button button--primary">
                      {{- 'filters.clear_all' | t -}}
                    </button>
                  </facet-remove-button>
                </div>
              </div>
          {%- endunless -%}
        </div>
        {%- else -%}
          <div class="grid-common_empty --align-center" data-render-grid="">
            <i class="grid-common_empty-icn">
              {%- render 'icons-data', width: 44, height: 44, use_icon: true, icon_reference: 'empty-folder', section_id: section.id -%}
            </i>
            <strong class="grid-common_heading mty {{ section.settings.section_heading_size }} {{ section.settings.section_heading_weight }}">
              {{- 'collection.empty_heading' | t -}}
            </strong>
          </div>
      {%- endif -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:sections.main_search.name",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main_blog.settings.blog_card.banner_header.label"
    },
    {
      "type": "image_picker",
      "id": "page_image",
      "label": "t:image.label",
      "info": "t:sections.main_page.settings.image.info"
    },
    {
      "type": "checkbox",
      "label": "t:sections.image_banner.settings.animations.parallax.label",
      "id": "parallax_effect",
      "default": false
    },
    {
      "type": "text",
      "id": "page_caption",
      "label": "t:caption.label",
      "default": "Caption"
    },
    {
      "type": "select",
      "id": "page_caption_size",
      "label": "t:sizes.caption.label",
      "options": [
        {
          "value": "text-size--small",
          "label": "t:sizes.text.options.opt_1.label"
        },
        {
          "value": "text-size--medium",
          "label": "t:sizes.text.options.opt_2.label"
        },
        {
          "value": "text-size--large",
          "label": "t:sizes.text.options.opt_3.label"
        }
      ],
      "default": "text-size--medium"
    },
    {
      "type": "select",
      "id": "page_caption_weight",
      "label": "t:weight.caption.label",
      "options": [
        {
          "value": "--fw-bold",
          "label": "t:weight.heading.options.opt_1.label"
        },
        {
          "value": "--fw-semi-bold",
          "label": "t:weight.heading.options.opt_5.label"
        },
        {
          "value": "--fw-medium",
          "label": "t:weight.heading.options.opt_2.label"
        },
        {
          "value": "--fw-normal",
          "label": "t:weight.heading.options.opt_3.label"
        },
        {
          "value": "--fw-light",
          "label": "t:weight.heading.options.opt_4.label"
        }
      ],
      "default": "--fw-bold"
    },
    {
      "type": "inline_richtext",
      "id": "page_heading",
      "label": "t:heading.label",
      "default": "Search"
    },
    {
      "type": "select",
      "id": "page_heading_size",
      "label": "t:sizes.heading.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sizes.heading.options.opt_1.label"
        },
        {
          "value": "h2",
          "label": "t:sizes.heading.options.opt_2.label"
        },
        {
          "value": "h3",
          "label": "t:sizes.heading.options.opt_3.label"
        },
        {
          "value": "h4",
          "label": "t:sizes.heading.options.opt_4.label"
        },
        {
          "value": "h5",
          "label": "t:sizes.heading.options.opt_5.label"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "page_heading_weight",
      "label": "t:weight.heading.label",
      "options": [
        {
          "value": "--fw-bold",
          "label": "t:weight.heading.options.opt_1.label"
        },
        {
          "value": "--fw-semi-bold",
          "label": "t:weight.heading.options.opt_5.label"
        },
        {
          "value": "--fw-medium",
          "label": "t:weight.heading.options.opt_2.label"
        },
        {
          "value": "--fw-normal",
          "label": "t:weight.heading.options.opt_3.label"
        },
        {
          "value": "--fw-light",
          "label": "t:weight.heading.options.opt_4.label"
        }
      ],
      "default": "--fw-bold"
    },
    {
      "type": "inline_richtext",
      "id": "page_description",
      "label": "t:description_text.label",
      "default": "Experience the Elegance and Style in Every Image"
    },
    {
      "type": "select",
      "id": "page_text_size",
      "label": "t:sizes.description_text.label",
      "options": [
        {
          "value": "text-size--small",
          "label": "t:sizes.text.options.opt_1.label"
        },
        {
          "value": "text-size--medium",
          "label": "t:sizes.text.options.opt_2.label"
        },
        {
          "value": "text-size--large",
          "label": "t:sizes.text.options.opt_3.label"
        },
        {
          "value": "text-size--xlarge",
          "label": "t:sizes.text.options.opt_4.label"
        }
      ],
      "default": "text-size--medium"
    },
    {
      "type": "select",
      "id": "page_description_weight",
      "label": "t:weight.description_text.label",
      "options": [
        {
          "value": "--fw-bold",
          "label": "t:weight.heading.options.opt_1.label"
        },

    {
      "type": "checkbox",
      "id": "form_full_width",
      "label": "t:sections.contact_form.settings.form_full_width.label",
      "default": true
    },
    {
      "type": "text_alignment",
      "id": "form_alignment",
      "label": "t:sections.contact_form.settings.form_alignment.label",
      "default": "center",
      "info": "t:sections.contact_form.settings.form_alignment.info"
    },
    {
      "type": "header",
      "content": "t:layout.content"
    },
    {
      "type": "text_alignment",
      "id": "section_text_alignment",
      "label": "t:alignments.text.desktop.label",
      "default": "left"
    },
    {
      "type": "text_alignment",
      "id": "section_mobile_text_alignment",
      "label": "t:alignments.text.mobile.label",
      "default": "left"
    },
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "default": "scheme1",
      "label": "t:color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:spacing.content"
    },
    {
      "type": "range",
      "id": "section_top_padding",
      "label": "t:spacing.settings.top.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 65,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_bottom_padding",
      "label": "t:spacing.settings.bottom.label",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 65,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact_form.name",
    }
  ]
}
{% endschema %}
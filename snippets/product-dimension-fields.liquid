{%- comment -%}
  Theme dimension UI. Pricing is handled by Custom Price Calculator app (#calculator).
  product-cpc-bridge.js syncs these fields to the hidden app calculator.
{%- endcomment -%}
{{- 'product-dimension-fields.css' | asset_url | stylesheet_tag -}}
{{- 'product-cpc-bridge.css' | asset_url | stylesheet_tag -}}
<script src="{{ 'product-cpc-bridge.js' | asset_url }}" defer="defer"></script>

<div
  class="product-dimension-fields"
  data-dimension-root="{{ section.id }}"
  data-form-id="{{ form_id }}"
  data-main-parent="#{{ section.id }}-description"
  data-price-render="[{{ price_render_attr }}]"
>
  <p class="product-common_variant-title text-size--small --fw-bold product-dimension-fields_heading">
    Enter your dimensions
  </p>
  <div class="product-dimension-fields_grid">
    <div class="product-dimension-fields_cell">
      <label class="product-common_variant-title text-size--small --fw-bold" for="dimension-width-{{ section.id }}">
        Width<span class="product-dimension-fields_required" aria-hidden="true">*</span>
      </label>
      <input
        type="number"
        id="dimension-width-{{ section.id }}"
        class="form-control product-dimension-fields_input"
        inputmode="numeric"
        min="0"
        step="1"
        autocomplete="off"
        data-dimension-width
        placeholder="e.g. 100"
        required
      >
    </div>
    <div class="product-dimension-fields_cell">
      <label class="product-common_variant-title text-size--small --fw-bold" for="dimension-height-{{ section.id }}">
        Height<span class="product-dimension-fields_required" aria-hidden="true">*</span>
      </label>
      <input
        type="number"
        id="dimension-height-{{ section.id }}"
        class="form-control product-dimension-fields_input"
        inputmode="numeric"
        min="0"
        step="1"
        autocomplete="off"
        data-dimension-height
        placeholder="e.g. 100"
        required
      >
    </div>
    <div class="product-dimension-fields_cell product-dimension-fields_cell--units">
      <label class="product-common_variant-title text-size--small --fw-bold" for="dimension-units-{{ section.id }}">
        Measurement units<span class="product-dimension-fields_required" aria-hidden="true">*</span>
      </label>
      <select
        id="dimension-units-{{ section.id }}"
        class="form-control product-dimension-fields_input"
        data-dimension-units
        required
      >
        <option value="" disabled selected>Select unit</option>
        <option value="cm">cm</option>
        <option value="meters">meters</option>
        <option value="in">in</option>
        <option value="ft">ft</option>
      </select>
    </div>
  </div>

  <div class="product-dimension-fields_summary">
    <div class="product-dimension-fields_summary-item">
      <span class="product-common_variant-title text-size--small --fw-bold">Square meters</span>
      <span
        class="product-dimension-fields_summary-value product-dimension-fields_summary-value--placeholder text-size--medium"
        data-dimension-sqm-display
      >
        —
      </span>
    </div>
    <div class="product-dimension-fields_summary-item">
      <span class="product-common_variant-title text-size--small --fw-bold">Calculated price</span>
      <span
        class="product-dimension-fields_summary-value product-dimension-fields_summary-value--placeholder text-size--medium"
        data-dimension-price-display
      >
        Enter dimensions
      </span>
    </div>
  </div>

  <p
    class="product-dimension-fields_error text-size--small --text-error hidden"
    role="alert"
    data-dimension-error
  ></p>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof window.initProductCpcBridge !== 'function') return;
    window.initProductCpcBridge({ sectionId: {{ section.id | json }} });
  });
</script>

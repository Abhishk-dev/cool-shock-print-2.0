{%- comment -%}
  renders top header on section templates
  usage
    {%- render 'top-header' -%}
{%- endcomment -%}
{%- liquid
  assign section_prefix_class = 'page-header'
  assign section_scheme_class = section.settings.section_color_scheme | prepend: 'scheme scheme--'
  assign menu_drawer_scheme_class = section.settings.menu_drawer_color_scheme | prepend: 'scheme scheme--'
  assign cart_view = settings.cart_view

  capture enable_account_dashboard
    if shop.customer_accounts_enabled
      if customer
        echo 'true'
      endif
    endif
  endcapture

  capture sticky_behavior
    case section.settings.enable_sticky
      when 'on_scroll_up'
        echo 'upwards'
      when 'on_scroll'
        echo 'downwards'
      else
        echo 'stacked'
    endcase
  endcapture

  capture mega_menu_exists
    if section.blocks.size > 0
      for block in section.blocks
        if block.type == 'mega_menu'
          echo 'true'
          break
        endif
      endfor
      else
        echo 'false'
    endif
  endcapture

  capture container_class
    if section.settings.section_full_width
      echo 'container-fluid'
      else
        echo 'container'
    endif
  endcapture

  capture mega_menu_exists_two
    if section.blocks.size > 0
      for block in section.blocks
        if block.type == 'mega_menu_2'
          echo 'true'
          break
        endif
      endfor
      else
        echo 'false'
    endif
  endcapture

  capture predictive_tag
    if section.settings.enable_predictive_suggestions
      echo 'predictive-dropdown'
      else
        echo 'dropdown-component'
    endif
  endcapture

  capture media_height
  case section.settings.media_height
  when 'adapt'
      echo '--media-size-adapt'
    when 'small'
      echo '--small-height'
    when 'medium'
      echo '--medium-height'
  endcase
endcapture
-%}

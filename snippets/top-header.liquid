<div class="global-block {{ section_prefix_class }} {{ section_prefix_class }}-{{ section.id }} {% if section.settings.show_bottom_bdr %}--bdr-bottom{% endif %}" style ="--logo-desktop-width: {{ section.settings.logo_desktop_width }}px; --logo-mobile-width: {{ section.settings.logo_mobile_width }}px;">
  {%- if section.settings.header_overlay and template.name == 'index' -%}
    <div class="overlay-header {% if section.settings.enable_sticky == 'none' %}simple-overlay{% endif %}">
  {%- endif -%}
    {%- unless section.settings.enable_sticky == 'none' -%}
      <sticky-block class="sticky-header-wrapper" data-ref-block=".page-header--fixed-area" data-body-class="page-header--fixed" data-revealed="false" data-behavior="{{ sticky_behavior }}" data-spacer="true">
    {%- endunless -%}

{%- comment -%}
  renders mega menu banner on main navigation dropdown item
  usage
    {%- render 'mega-menu-banner', block: block, link: link, link_title: link_title, index: forloop.index, dropdown_link_title: dropdown_link_title, link_handle: link_handle -%}
{%- endcomment -%}
<li class="main-navigation_item mega-menu" {{ block.shopify_attributes }}>
  <strong id="{{- link_handle -}}-{{- index -}}-mega-banner-heading-1st-level-{{ left_search }}" class="visually-hidden">{{- dropdown_link_title -}}</strong>
  <dropdown-component data-level="1" {% if section.settings.enable_dropdown_hover %}data-on-hover="true"{% endif %}>
    <button
      type="button"
      class="dropdown-component_opener {% if section.settings.enable_dropdown_hover %}--hover-opener{% endif %} main-navigation_link main-navigation_link--opener"
      aria-expanded="false"
      aria-controls="{{- link_handle -}}-{{- index -}}-mega-banner-1st-level-{{ left_search }}"
      aria-describedby="{{- link_handle -}}-{{- index -}}-mega-banner-heading-1st-level-{{ left_search }}"
    >
      <span class="dropdown--close dropdown-component_opener-icn dropdown-component_opener--icn-close">
        {%- render 'icons-data', width: 10, height: 10, use_icon: true, icon_reference: 'chevron-down', section_id: section_id -%}
      </span>
      <span class="main-navigation_link-title dropdown-component_opener-icn">{{- link_title -}}</span>
      <span class="dropdown--open dropdown-component_opener-icn dropdown-component_opener--icn-open">
        {%- render 'icons-data', width: 10, height: 10, use_icon: true, icon_reference: 'chevron-down', section_id: section_id -%}
      </span>
    </button>
    <div class="dropdown-component_wrapper main-navigation_dropdown-wrapper main-navigation_dropdown-wrapper--level1 main-navigation_dropdown-wrapper--mega-banner main-navigation_dropdown--inner-wrapper {{ color_scheme }}" id="{{- link_handle -}}-{{- index -}}-mega-banner-1st-level-{{ left_search }}">
      <div class="mega-menu_container">
        {%- if block.settings.mega_menu_heading != blank -%}
          <div class="seach-heading --fw-bold h --fw-normal --word-brek mty">
            {{ block.settings.mega_menu_heading }}
          </div>
        {%- else -%}
          <div class="seach-heading --fw-bold h --fw-normal --word-brek mty">
            {{ 'menu.explore' | t }}
          </div>
        {%- endif -%}
        <div class="mega-menu_banner-wrapper">
          <div class="mega-menu_banner-col mega-menu_banner-col--list">
            <ul class="list-unstyled mega-meu_list">
              {%- if link.links -%}
                {%- for childlink in link.links -%}
                  {%- render 'mega-menu-item', childlink: childlink, index: forloop.index -%}
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        </div>
        <div class="mega-menu_banner">
          <div class="mega-menu_banner-1 anim--shine">
            <div class="mega-menu_banner-1_image mega-banner_image">
              {%- if block.settings.mage_image_banner_1 != blank -%}
                <img
                  srcset="{%- if block.settings.mage_image_banner_1.width >= 152 -%}{{ block.settings.mage_image_banner_1 | image_url: width: 152 }} 152w,{%- endif -%}
                          {%- if block.settings.mage_image_banner_1.width >= 200 -%}{{ block.settings.mage_image_banner_1 | image_url: width: 200 }} 200w,{%- endif -%}
                          {%- if block.settings.mage_image_banner_1.width >= 260 -%}{{ block.settings.mage_image_banner_1 | image_url: width: 260 }} 260w,{%- endif -%}
                           {{ block.settings.mage_image_banner_1 | image_url: width: block.settings.mage_image_banner_1.width }} {{ block.settings.mage_image_banner_1.width }}w"
                  sizes="calc((var(--cp-width-px) / 5) - 10px)"
                  src="{{- block.settings.mage_image_banner_1 | image_url: width: 152 -}}"
                  alt="{{- product.title | escape -}}"
                  loading="lazy"
                  width= "152"
                  height="{{- 152 | divided_by: block.settings.mage_image_banner_1.aspect_ratio | round -}}"
                  class="object-fit object-fit--absolute"
                >
                {%- else -%}
                  {%- render 'placeholder-svgs', type: 'product', index: 1, class: 'object-fit object-fit--absolute' -%}
              {%- endif -%}
            </div>
          </div>
          <div class="mega-menu_banner-2 anim--shine">
            <div class="mega-menu_banner-2_image mega-banner_image">
              {%- if block.settings.mage_image_banner_2 != blank -%}
                <img
                  srcset="{%- if block.settings.mage_image_banner_2.width >= 152 -%}{{ block.settings.mage_image_banner_2 | image_url: width: 152 }} 152w,{%- endif -%}
                          {%- if block.settings.mage_image_banner_2.width >= 200 -%}{{ block.settings.mage_image_banner_2 | image_url: width: 200 }} 200w,{%- endif -%}
                          {%- if block.settings.mage_image_banner_2.width >= 260 -%}{{ block.settings.mage_image_banner_2 | image_url: width: 260 }} 260w,{%- endif -%}
                           {{ block.settings.mage_image_banner_2 | image_url: width: block.settings.mage_image_banner_2.width }} {{ block.settings.mage_image_banner_2.width }}w"
                  sizes="calc((var(--cp-width-px) / 5) - 10px)"
                  src="{{- block.settings.mage_image_banner_2 | image_url: width: 152 -}}"
                  alt="{{- product.title | escape -}}"
                  loading="lazy"
                  width= "152"
                  height="{{- 152 | divided_by: block.settings.mage_image_banner_2.aspect_ratio | round -}}"
                  class="object-fit object-fit--absolute"
                >
                {%- else -%}
                  {%- render 'placeholder-svgs', type: 'product', index: 2, class: 'object-fit object-fit--absolute' -%}
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </dropdown-component>
</li>